<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Genie.App.ViewModels"
        x:Class="Genie.App.Views.UpdatesDialog"
        x:DataType="vm:UpdatesDialogViewModel"
        Title="Updates"
        Width="780" Height="520"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <!-- Shared DataTemplate for one feed row in the Maps, Plugins, and Scripts lists.
         The grid columns lay out: enable checkbox | name + source | per-row
         status text | the three action buttons | remove button. Buttons are
         narrow on purpose — wide enough to read, narrow enough that 5+ rows
         fit without scrolling on a typical window. -->
    <DataTemplate x:Key="FeedRowTemplate" x:DataType="vm:UpdateFeedRow">
      <Grid ColumnDefinitions="Auto,2*,3*,Auto,Auto,Auto" Margin="0,3" VerticalAlignment="Center">
        <CheckBox  Grid.Column="0"
                   IsChecked="{Binding Enabled}"
                   Margin="2,0,10,0"
                   ToolTip.Tip="Include this source in 'Check All' and background checks."/>

        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding Source}" FontSize="11" Foreground="#9aa"/>
        </StackPanel>

        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0" Spacing="3">
          <TextBlock Text="{Binding Status}"
                     FontSize="11" Foreground="#9c9"
                     TextWrapping="Wrap"/>
          <!-- Inline bar: determinate for Maps (real N/M), marquee for the
               unmeasured plugin steps and Check polls. Hidden at rest. -->
          <ProgressBar Minimum="0" Maximum="100"
                       Value="{Binding Progress}"
                       IsIndeterminate="{Binding ProgressIndeterminate}"
                       IsVisible="{Binding ProgressActive}"
                       Height="4"/>
        </StackPanel>

        <Button    Grid.Column="3" Content="Check"
                   Command="{Binding CheckCommand}"
                   MinWidth="60" Margin="2,0"/>
        <Button    Grid.Column="4" Content="Update"
                   Command="{Binding UpdateCommand}"
                   MinWidth="64" Margin="2,0"/>
        <Button    Grid.Column="5" Content="✕"
                   Command="{Binding RemoveCommand}"
                   Width="28"  Margin="6,0,0,0"
                   ToolTip.Tip="Remove this source from the feed list. Files already on disk are left alone."/>
      </Grid>
    </DataTemplate>
  </Window.Resources>

  <Grid RowDefinitions="*,Auto" Margin="14">

    <TabControl Grid.Row="0">

      <!-- ── Core ──────────────────────────────────────────────────────── -->
      <TabItem Header="Core">
        <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
          <TextBlock Grid.Row="0" Text="Core Game"
                     FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

          <Grid Grid.Row="1" ColumnDefinitions="120,*" Margin="0,4">
            <TextBlock Grid.Column="0" Text="Installed:" Foreground="#aab"/>
            <TextBlock Grid.Column="1" Text="{Binding CoreInstalledVersion}" FontWeight="SemiBold"/>
          </Grid>

          <!-- Platform channel — the RELEASES-{x} file Velopack is configured
               to read from this install. Useful for confirming a Mac/Linux
               install routes to the right per-platform RELEASES file. -->
          <Grid Grid.Row="2" ColumnDefinitions="120,*" Margin="0,4">
            <TextBlock Grid.Column="0" Text="Platform:" Foreground="#aab"/>
            <TextBlock Grid.Column="1" Text="{Binding CorePlatformChannel}"
                       Foreground="#9cb"
                       ToolTip.Tip="Velopack platform channel for this install — drives which RELEASES file is read on GitHub. Windows uses the default (empty) channel."/>
          </Grid>

          <Grid Grid.Row="3" ColumnDefinitions="120,Auto" Margin="0,4">
            <TextBlock Grid.Column="0" Text="Channel:" Foreground="#aab" VerticalAlignment="Center"/>
            <ComboBox  Grid.Column="1"
                       ItemsSource="{Binding AvailableChannels}"
                       SelectedItem="{Binding CoreChannel}"
                       MinWidth="120"
                       ToolTip.Tip="Stable: latest non-prerelease GitHub release. Beta: includes prereleases."/>
          </Grid>

          <Grid Grid.Row="4" ColumnDefinitions="120,*" Margin="0,12,0,4">
            <TextBlock Grid.Column="0" Text="Status:" Foreground="#aab"/>
            <TextBlock Grid.Column="1" Text="{Binding CoreLatestVersion}"
                       Foreground="#9c9" TextWrapping="Wrap"/>
          </Grid>

          <!-- Action buttons + live progress. Check is always available (cheap
               GitHub poll). Update is gated on CoreCanUpdate (running from a
               Velopack install) AND CoreUpdateAvailable (last Check found
               something newer). The progress block appears only while an update
               runs; the bar goes indeterminate during the delta-reconstruction
               tail so it never reads as frozen at ~70%. -->
          <StackPanel Grid.Row="5" Spacing="8" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Check"  Command="{Binding CheckCoreCommand}"  MinWidth="80"/>
              <Button Content="Update and Restart" Command="{Binding UpdateCoreCommand}" MinWidth="160"
                      ToolTip.Tip="Download the new version, then restart Genie 5 in place."/>
            </StackPanel>

            <Grid ColumnDefinitions="*,Auto"
                  IsVisible="{Binding CoreProgressActive}"
                  Margin="0,4,0,0">
              <ProgressBar Grid.Column="0"
                           Minimum="0" Maximum="100"
                           Value="{Binding CoreProgress}"
                           IsIndeterminate="{Binding CoreProgressIndeterminate}"
                           Height="6" VerticalAlignment="Center"/>
              <TextBlock   Grid.Column="1"
                           Text="{Binding CoreProgressPhase}"
                           Foreground="#9cb" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>
          </StackPanel>

          <!-- Dev-build advisory: shows only when CoreCanUpdate is false.
               That means UpdateManager.IsInstalled returned false → we're
               running from `dotnet run` or a raw publish/, not a vpk install. -->
          <Border Grid.Row="6"
                  IsVisible="{Binding !CoreCanUpdate}"
                  BorderBrush="#5a4a2a" BorderThickness="1"
                  Background="#2a2418" CornerRadius="3"
                  Padding="10,8" Margin="0,14,0,0">
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#cca"
                       Text="Running from a development build (not a Velopack-built install). Check still works for version awareness, but Update is disabled — to enable in-app updates, install Genie 5 from the Velopack installer artifact."/>
          </Border>

          <TextBlock Grid.Row="7" Margin="0,16,0,0" Foreground="#9aa" FontSize="11" TextWrapping="Wrap"
                     Text="Updates are delivered via the Velopack framework: it downloads the delta package and pivots a helper process to replace the running binaries while preserving your settings."/>
        </Grid>
      </TabItem>

      <!-- ── Maps ──────────────────────────────────────────────────────── -->
      <TabItem Header="Maps">
        <Grid Margin="12" RowDefinitions="Auto,*,Auto">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap"
                       Text="Map zone repositories. Each row is a GitHub repo of zone XML files; updates merge upstream changes while preserving your stamped ServerRoomIds."
                       Foreground="#cdd" FontSize="12"/>
            <Button    Grid.Column="1" Content="Add Source…"
                       Command="{Binding AddMapsSourceCommand}"
                       MinWidth="100" Margin="8,0,0,0"/>
          </Grid>

          <ItemsControl Grid.Row="1"
                        ItemsSource="{Binding MapsFeeds}"
                        ItemTemplate="{StaticResource FeedRowTemplate}">
            <ItemsControl.Template>
              <ControlTemplate>
                <ScrollViewer>
                  <ItemsPresenter/>
                </ScrollViewer>
              </ControlTemplate>
            </ItemsControl.Template>
          </ItemsControl>

          <TextBlock Grid.Row="2"
                     Text="Tip: Update merges per-file. Locally-collected room IDs survive an update."
                     Foreground="#9aa" FontSize="11" Margin="0,8,0,0"/>
        </Grid>
      </TabItem>

      <!-- ── Plugins ───────────────────────────────────────────────────── -->
      <TabItem Header="Plugins">
        <Grid Margin="12" RowDefinitions="Auto,*,Auto">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap"
                       Text="Plugin DLL sources. Updates download the asset, unload the running plugin, replace the DLL, and reload — no restart needed."
                       Foreground="#cdd" FontSize="12"/>
            <Button    Grid.Column="1" Content="Add Source…"
                       Command="{Binding AddPluginsSourceCommand}"
                       MinWidth="100" Margin="8,0,0,0"/>
          </Grid>

          <ItemsControl Grid.Row="1"
                        ItemsSource="{Binding PluginsFeeds}"
                        ItemTemplate="{StaticResource FeedRowTemplate}">
            <ItemsControl.Template>
              <ControlTemplate>
                <ScrollViewer>
                  <ItemsPresenter/>
                </ScrollViewer>
              </ControlTemplate>
            </ItemsControl.Template>
          </ItemsControl>

          <TextBlock Grid.Row="2"
                     Text="Tip: Plugin DLLs run inside Genie 5 with full access. Only add sources from authors you trust."
                     Foreground="#9aa" FontSize="11" Margin="0,8,0,0"/>
        </Grid>
      </TabItem>

      <!-- ── Scripts ───────────────────────────────────────────────────── -->
      <TabItem Header="Scripts">
        <Grid Margin="12" RowDefinitions="Auto,*,Auto">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap"
                       Text="Script repositories. Each row is a GitHub repo of .cmd / .js scripts; Update pulls new and changed files (subfolders included) into your Scripts folder — like a git pull. Files the repo doesn't know about are never touched."
                       Foreground="#cdd" FontSize="12"/>
            <Button    Grid.Column="1" Content="Add Source…"
                       Command="{Binding AddScriptsSourceCommand}"
                       MinWidth="100" Margin="8,0,0,0"/>
          </Grid>

          <ItemsControl Grid.Row="1"
                        ItemsSource="{Binding ScriptsFeeds}"
                        ItemTemplate="{StaticResource FeedRowTemplate}">
            <ItemsControl.Template>
              <ControlTemplate>
                <ScrollViewer>
                  <ItemsPresenter/>
                </ScrollViewer>
              </ControlTemplate>
            </ItemsControl.Template>
          </ItemsControl>

          <TextBlock Grid.Row="2"
                     Text="Tip: there is no merge — a locally-edited script with the same name as a repo file is overwritten on Update. Rename scripts you customize."
                     Foreground="#9aa" FontSize="11" Margin="0,8,0,0"/>
        </Grid>
      </TabItem>

    </TabControl>

    <!-- ── Footer ─────────────────────────────────────────────────────── -->
    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,12,0,0">
      <Button     Grid.Column="0" Content="Check All"
                  Command="{Binding CheckAllCommand}"
                  MinWidth="100"
                  ToolTip.Tip="Run a check against every enabled Maps, Plugins, and Scripts source."/>
      <TextBlock  Grid.Column="1" Text="{Binding Status}"
                  VerticalAlignment="Center" Foreground="#9c9"
                  FontSize="11" Margin="12,0"
                  TextWrapping="Wrap"/>
      <Button     Grid.Column="3" Content="Close" Width="80"
                  IsCancel="True" Click="OnClose"/>
    </Grid>

  </Grid>
</Window>
