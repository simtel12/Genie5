<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Genie.App.ViewModels"
        x:Class="Genie.App.Views.DisplaySettingsDialog"
        x:DataType="vm:DisplaySettingsViewModel"
        Title="Display Settings"
        Width="500" Height="480"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="*,Auto" Margin="16">

    <TabControl Grid.Row="0" Padding="0,8,0,0">

      <!-- ══ General ═══════════════════════════════════════════════════ -->
      <TabItem Header="General">
        <StackPanel Spacing="10" Margin="0,8,0,0">

          <!-- ── Font family / size ──────────────────────────────────── -->
          <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto">

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Font family" VerticalAlignment="Center"/>
            <ComboBox  Grid.Row="0" Grid.Column="1"
                       ItemsSource="{Binding SystemFonts}"
                       SelectedItem="{Binding FontFamily}"
                       HorizontalAlignment="Stretch"
                       MaxDropDownHeight="300">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <!-- Render each entry in the font it represents so the user
                       can preview the typeface as they scroll the list. -->
                  <TextBlock Text="{Binding}" FontFamily="{Binding}" FontSize="13"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Font size" VerticalAlignment="Center" Margin="0,8,0,0"/>
            <NumericUpDown Grid.Row="1" Grid.Column="1"
                           Value="{Binding FontSize}"
                           Minimum="8" Maximum="48" Increment="1"
                           FormatString="0"
                           Margin="0,8,0,0"/>
          </Grid>

          <Separator Margin="0,4,0,4"/>

          <!-- ── Colors (Avalonia ColorPicker — palette + HSV sliders + hex) ── -->
          <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Game text" VerticalAlignment="Center"/>
            <ColorPicker Grid.Row="0" Grid.Column="1"
                         Color="{Binding GameColor}"
                         HorizontalAlignment="Stretch"
                         IsAlphaVisible="False"
                         IsAlphaEnabled="False"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Echoes" VerticalAlignment="Center" Margin="0,8,0,0"/>
            <ColorPicker Grid.Row="1" Grid.Column="1"
                         Color="{Binding EchoColor}"
                         HorizontalAlignment="Stretch"
                         IsAlphaVisible="False"
                         IsAlphaEnabled="False"
                         Margin="0,8,0,0"/>
          </Grid>

          <CheckBox Content="Italicize local echoes (typed commands, #echo, scripts)"
                    IsChecked="{Binding EchoItalic}"
                    Margin="0,4,0,0"/>

          <Separator Margin="0,4,0,4"/>

          <!-- ── External editor (Edit Script + #edit foo) ────────────── -->
          <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="External editor for &quot;Edit Script&quot; (✏ in Script Bar, #edit command)"
                       FontSize="11" Foreground="{DynamicResource Theme.TextMuted}"
                       TextWrapping="Wrap" Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                     Text="{Binding EditorPath}"
                     Watermark="Leave empty to use OS default — e.g. C:\Program Files\Notepad++\notepad++.exe"
                     FontFamily="Consolas,Courier New,monospace"
                     FontSize="11"/>
          </Grid>

        </StackPanel>
      </TabItem>

      <!-- ══ Theme (#20) ════════════════════════════════════════════════ -->
      <TabItem Header="Theme">
        <StackPanel Spacing="10" Margin="0,8,0,0">

          <Grid ColumnDefinitions="110,*">
            <TextBlock Grid.Column="0" Text="Theme" VerticalAlignment="Center"/>
            <ComboBox  Grid.Column="1"
                       ItemsSource="{Binding ThemeNames}"
                       SelectedItem="{Binding SelectedThemeName}"
                       HorizontalAlignment="Stretch"
                       MaxDropDownHeight="300"/>
          </Grid>

          <TextBlock Text="Picking a theme applies it immediately so you can see it behind this dialog. Cancel puts the previous theme back."
                     FontSize="11" Foreground="{DynamicResource Theme.TextMuted}"
                     TextWrapping="Wrap"/>

          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
            <Button Content="Import…"    Click="OnImportThemeClick"
                    ToolTip.Tip="Add a shared theme JSON file to your Config\Themes folder and apply it."/>
            <Button Content="Export…"    Click="OnExportThemeClick"
                    ToolTip.Tip="Save the selected theme as a JSON file to share or hand-edit."/>
            <Button Content="Duplicate…" Click="OnDuplicateThemeClick"
                    ToolTip.Tip="Copy the selected theme to a new custom theme — the usual way to start editing a built-in."/>
            <Button Content="Delete"     Click="OnDeleteThemeClick"
                    IsEnabled="{Binding CanDeleteTheme}"
                    ToolTip.Tip="Delete the selected custom theme file. Built-in themes can't be deleted."/>
          </StackPanel>

          <TextBlock Text="{Binding ThemeStatus}"
                     FontSize="11" Foreground="{DynamicResource Theme.SectionHeader}"
                     TextWrapping="Wrap"
                     IsVisible="{Binding ThemeStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

          <Separator Margin="0,4,0,4"/>

          <TextBlock Text="Custom themes are hand-editable JSON files in Config\Themes. For a full color-role editor with live preview, use Edit → Theme → Edit Theme…"
                     FontSize="11" Foreground="{DynamicResource Theme.TextMuted}"
                     TextWrapping="Wrap"/>

        </StackPanel>
      </TabItem>

    </TabControl>

    <!-- ── Action buttons ───────────────────────────────────────────── -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="8" Margin="0,16,0,0">
      <Button Content="Reset"  Command="{Binding ResetCommand}"  Width="80"/>
      <Button Content="Cancel" Command="{Binding CancelCommand}" Width="80"/>
      <Button Content="OK"     Command="{Binding OkCommand}"     Width="80"
              IsDefault="True"/>
    </StackPanel>

  </Grid>
</Window>
