<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Genie.App.Views.SubstitutesPanel">

  <Grid RowDefinitions="Auto,*">

    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="4,4,4,0">
      <Button Content="Add New" Click="OnAdd"/>
      <Button Content="Delete"  Click="OnDelete"/>
      <Button Content="Toggle"  Click="OnToggle"/>
      <Button Content="Import…" Click="OnImport"/>
      <TextBox Name="FilterBox" Width="220" Margin="12,0,0,0"
               VerticalAlignment="Center" Watermark="Find… (pattern, replacement or class)"
               TextChanged="OnFilterChanged"/>
    </StackPanel>

    <Grid Grid.Row="1" RowDefinitions="*,Auto" Margin="4">
      <DataGrid Name="ItemsList"
                Grid.Row="0"
                Margin="0,0,0,4"
                IsReadOnly="True"
                SelectionMode="Single"
                CanUserSortColumns="True"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                x:CompileBindings="False"
                SelectionChanged="OnSelectionChanged">
        <DataGrid.Columns>
          <DataGridTextColumn Header="On"          Binding="{Binding EnabledGlyph}" Width="40"/>
          <DataGridTextColumn Header="Pattern"     Binding="{Binding Pattern}"      Width="*"/>
          <DataGridTextColumn Header="Replacement" Binding="{Binding Replacement}"  Width="*"/>
          <DataGridTextColumn Header="Class"       Binding="{Binding ClassName}"    Width="Auto"/>
        </DataGrid.Columns>
      </DataGrid>

      <Grid Grid.Row="1"
            ColumnDefinitions="Auto,*,Auto,*"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto"
            Margin="0,4,0,0">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Pattern:" VerticalAlignment="Center" Margin="0,0,8,4"/>
        <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                   Name="PatternBox" Margin="0,0,0,4"
                   FontFamily="Consolas,Courier New,monospace"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Replacement:" VerticalAlignment="Center" Margin="0,0,8,4"/>
        <TextBox   Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                   Name="ReplacementBox" Margin="0,0,0,4"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Class:" VerticalAlignment="Center" Margin="0,0,8,4"/>
        <TextBox   Grid.Row="2" Grid.Column="1" Name="ClassBox" Margin="0,0,8,4"/>

        <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                    Orientation="Horizontal" Spacing="16" Margin="0,2,0,4">
          <CheckBox Name="CaseSensitiveCheck" Content="Case sensitive"/>
          <CheckBox Name="EnabledCheck"       Content="Enabled" IsChecked="True"/>
          <Button   Content="Save"  Click="OnSave"/>
          <Button   Content="Clear" Click="OnClear"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                   Name="StatusText" Margin="0,6,0,0"
                   Foreground="Gray" FontStyle="Italic"/>
      </Grid>
    </Grid>

  </Grid>
</UserControl>
