<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie.App.Views.MapperSettingsDialog"
        Title="AutoMapper Settings"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

  <StackPanel Margin="20" Spacing="14">

    <CheckBox x:Name="EnableCheck"
              Content="Enable AutoMapper"
              ToolTip.Tip="Track your location on the map and record rooms/exits as you walk. Same as #config automapper and Window ▸ Show Mapper's engine."/>

    <StackPanel Spacing="4">
      <TextBlock Text="Map overlay opacity"/>
      <Grid ColumnDefinitions="*,Auto">
        <Slider x:Name="AlphaSlider" Grid.Column="0" Minimum="0" Maximum="255"
                TickFrequency="15" IsSnapToTickEnabled="False"/>
        <TextBlock x:Name="AlphaValue" Grid.Column="1" VerticalAlignment="Center"
                   Width="40" TextAlignment="Right"/>
      </Grid>
    </StackPanel>

    <Separator/>

    <CheckBox x:Name="PauseUnfocusCheck"
              Content="Pause auto-walk when the window is unfocused"
              ToolTip.Tip="Stop an attended walk if Genie loses focus, so you don't keep moving while looking at another window."/>
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Seconds unfocused before pausing:" VerticalAlignment="Center"/>
      <NumericUpDown x:Name="UnfocusSecondsBox" Minimum="60" Maximum="3600"
                     Increment="10" FormatString="0" Width="120"/>
    </StackPanel>

    <Separator/>

    <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="12">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Map background" VerticalAlignment="Center"/>
      <ColorPicker Grid.Row="0" Grid.Column="1" x:Name="BgPicker" IsAlphaEnabled="False"/>
      <TextBlock Grid.Row="1" Grid.Column="0" Text="Map text" VerticalAlignment="Center"/>
      <ColorPicker Grid.Row="1" Grid.Column="1" x:Name="TextPicker" IsAlphaEnabled="False"/>
    </Grid>

    <TextBlock Text="Changes apply immediately and are saved automatically."
               FontSize="11" Opacity="0.7"/>

    <Button Content="_Close" MinWidth="88" HorizontalAlignment="Right"
            IsDefault="True" IsCancel="True" Click="OnClose"/>
  </StackPanel>
</Window>
