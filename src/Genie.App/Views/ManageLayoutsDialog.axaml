<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Genie.App.ViewModels"
        x:Class="Genie.App.Views.ManageLayoutsDialog"
        x:DataType="vm:ManageLayoutsViewModel"
        Title="Manage Layouts"
        Width="520" Height="440"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="Auto,*,Auto,Auto,Auto" Margin="16">

    <TextBlock Grid.Row="0"
               Text="Layouts for the connected profile and the shared Global set. ★ marks the default applied on connect."
               TextWrapping="Wrap" Foreground="{DynamicResource Theme.TextPrimary}" FontSize="12"
               Margin="0,0,0,10"/>

    <!-- Layout list -->
    <ListBox Grid.Row="1"
             AutomationProperties.Name="Layouts"
             ItemsSource="{Binding Entries}"
             SelectedItem="{Binding Selected}"
             FontSize="12">
      <ListBox.ItemTemplate>
        <DataTemplate DataType="vm:LayoutEntry">
          <TextBlock Text="{Binding Display}"/>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Copy destination -->
    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,10,0,0">
      <TextBlock Grid.Column="0" Text="Copy to:" VerticalAlignment="Center" Margin="0,0,8,0"/>
      <ComboBox  Grid.Column="1"
                 AutomationProperties.Name="Copy to"
                 ItemsSource="{Binding Targets}"
                 SelectedItem="{Binding SelectedTarget}"
                 HorizontalAlignment="Stretch">
        <ComboBox.ItemTemplate>
          <DataTemplate DataType="vm:CopyTarget">
            <TextBlock Text="{Binding Label}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Button    Grid.Column="2" Content="Copy" Margin="8,0,0,0" MinWidth="72"
                 Command="{Binding CopyCommand}"/>
    </Grid>

    <!-- Per-layout actions -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
      <Button Content="Set as Default" Command="{Binding SetDefaultCommand}" MinWidth="110"/>
      <Button x:Name="RenameButton" Content="Rename…" MinWidth="80" Click="OnRename"/>
      <Button Content="Delete" Command="{Binding DeleteCommand}" MinWidth="72"/>
    </StackPanel>

    <!-- Status + close -->
    <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,14,0,0">
      <TextBlock Grid.Column="0" Text="{Binding Status}"
                 Foreground="{DynamicResource Theme.Success}" FontSize="11" VerticalAlignment="Center"
                 TextWrapping="Wrap"/>
      <Button Grid.Column="1" Content="Close" Width="80" IsCancel="True" Click="OnClose"/>
    </Grid>

  </Grid>
</Window>
