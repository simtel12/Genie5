<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie.App.Views.SaveLayoutDialog"
        Title="Save Layout As"
        Width="400" Height="380"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="16">

    <!-- Target scope -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,10">
      <TextBlock Text="Save to:" VerticalAlignment="Center" Foreground="{DynamicResource Theme.TextPrimary}" FontSize="12"/>
      <RadioButton x:Name="ProfileRadio" GroupName="scope" Content="This profile" FontSize="12"/>
      <RadioButton x:Name="GlobalRadio"  GroupName="scope" Content="Global"       FontSize="12"/>
    </StackPanel>

    <TextBlock Grid.Row="1"
               Text="Existing (click to overwrite, or type a new name below):"
               Foreground="{DynamicResource Theme.TextPrimary}" FontSize="12" TextWrapping="Wrap"
               Margin="0,0,0,6"/>

    <ListBox x:Name="ExistingList" Grid.Row="2"
             AutomationProperties.Name="Existing layouts"
             SelectionMode="Single" FontSize="12"
             Margin="0,0,0,10"/>

    <TextBox x:Name="NameInput" Grid.Row="3"
             AutomationProperties.Name="Layout name"
             FontSize="12" VerticalAlignment="Top"/>

    <StackPanel Grid.Row="4" Orientation="Horizontal"
                HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="Cancel" Width="80" IsCancel="True" Click="OnCancel"/>
      <Button Content="OK"     Width="80" IsDefault="True" Click="OnOk"/>
    </StackPanel>

  </Grid>
</Window>
