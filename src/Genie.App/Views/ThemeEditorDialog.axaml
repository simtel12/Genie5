<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Genie.App.ViewModels"
        x:Class="Genie.App.Views.ThemeEditorDialog"
        x:DataType="vm:ThemeEditorViewModel"
        Title="Edit Theme"
        Width="520" Height="640"
        WindowStartupLocation="CenterOwner">

  <!-- #20: theme editor. Every picker change live-previews through
       ThemeService.Preview (throttled in the VM) — the app behind the
       dialog repaints as you drag. Save persists a custom theme; Cancel
       (or closing the window) restores the pre-edit palette via the
       code-behind. -->
  <Grid RowDefinitions="Auto,*,Auto" Margin="16">

    <!-- ── Name + base variant ─────────────────────────────────────────── -->
    <StackPanel Grid.Row="0" Spacing="6">
      <Grid ColumnDefinitions="110,*">
        <TextBlock Grid.Column="0" Text="Theme name" VerticalAlignment="Center"/>
        <TextBox   Grid.Column="1" Text="{Binding ThemeName}"/>
      </Grid>
      <TextBlock Text="Built-in themes can't be overwritten — editing one saves a custom copy under this name (Config/Themes)."
                 FontSize="11" Foreground="{DynamicResource Theme.TextMuted}"
                 TextWrapping="Wrap"
                 IsVisible="{Binding IsEditingBuiltIn}"/>
      <Grid ColumnDefinitions="110,Auto,Auto">
        <TextBlock Grid.Column="0" Text="Base variant" VerticalAlignment="Center"
                   ToolTip.Tip="Drives the standard controls (menus, buttons, text boxes, scrollbars): Dark or Light Fluent styling."/>
        <RadioButton Grid.Column="1" Content="Dark"  GroupName="variant"
                     IsChecked="{Binding !IsLightVariant, Mode=TwoWay}" Margin="0,0,16,0"/>
        <RadioButton Grid.Column="2" Content="Light" GroupName="variant"
                     IsChecked="{Binding IsLightVariant, Mode=TwoWay}"/>
      </Grid>
    </StackPanel>

    <!-- ── Colour roles ────────────────────────────────────────────────── -->
    <ScrollViewer Grid.Row="1" Margin="0,10,0,0"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="4">
        <StackPanel.Styles>
          <Style Selector="TextBlock.section">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Theme.SectionHeader}"/>
            <Setter Property="Margin"     Value="0,10,0,2"/>
          </Style>
        </StackPanel.Styles>

        <!-- One row per role: label + drop-down colour picker. -->
        <StackPanel.DataTemplates>
          <DataTemplate DataType="vm:ThemeColorEntry">
            <Grid ColumnDefinitions="210,*" Margin="0,1">
              <TextBlock Grid.Column="0" Text="{Binding Label}"
                         VerticalAlignment="Center" FontSize="12"/>
              <ColorPicker Grid.Column="1"
                           Color="{Binding Value, Mode=TwoWay}"
                           IsAlphaEnabled="True" IsAlphaVisible="True"
                           HorizontalAlignment="Stretch"/>
            </Grid>
          </DataTemplate>
        </StackPanel.DataTemplates>

        <TextBlock Classes="section" Text="SURFACES" Margin="0,0,0,2"/>
        <ItemsControl ItemsSource="{Binding Surfaces}"/>

        <TextBlock Classes="section" Text="TEXT"/>
        <ItemsControl ItemsSource="{Binding TextRoles}"/>

        <TextBlock Classes="section" Text="ACCENTS"/>
        <ItemsControl ItemsSource="{Binding Accents}"/>

        <TextBlock Classes="section" Text="VITALS BARS"/>
        <ItemsControl ItemsSource="{Binding Vitals}"/>

        <TextBlock Classes="section" Text="GAME TEXT"/>
        <ItemsControl ItemsSource="{Binding GameRoles}"/>
        <TextBlock Text="Per-window and per-stream (preset) colour overrides still win over these defaults."
                   FontSize="11" Foreground="{DynamicResource Theme.TextMuted}"
                   TextWrapping="Wrap"/>
      </StackPanel>
    </ScrollViewer>

    <!-- ── Actions ─────────────────────────────────────────────────────── -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="8" Margin="0,12,0,0">
      <Button Content="Cancel" Width="80" Click="OnCancel"/>
      <Button Content="Save"   Width="80" Click="OnSave" IsDefault="True"
              IsEnabled="{Binding CanSave}"
              ToolTip.Tip="Save as a custom theme and make it active."/>
    </StackPanel>

  </Grid>
</Window>
