<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Genie.App.ViewModels"
        xmlns:dockc="using:Dock.Avalonia.Controls"
        xmlns:controls="using:Genie.App.Controls"
        x:Class="Genie.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Icon="avares://Genie5/Assets/app.png"
        Topmost="{Binding Display.AlwaysOnTop}"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500">

  <!-- Ctrl+Shift+C copies the entire visible game-text buffer to the OS
       clipboard. Workaround for the Avalonia per-line SelectableTextBlock
       limitation that drag-selection can't cross lines — see
       GameTextViewModel.CopyAllCommand. Visual multi-line drag-select is on
       the backlog. -->
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+Shift+C" Command="{Binding GameText.CopyAllCommand}"/>
  </Window.KeyBindings>

  <DockPanel>

    <!-- ── Menu bar ──────────────────────────────────────────────────────── -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="_Connect..."    Command="{Binding ConnectCommand}"/>
        <MenuItem Header="_Disconnect"    Command="{Binding DisconnectCommand}"/>
        <Separator/>
        <MenuItem Header="_Auto Log"
                  ToggleType="CheckBox"
                  IsChecked="{Binding AutoLogEnabled}"
                  ToolTip.Tip="Automatically write the rendered game text (what you see in the Game window) to AppData/Genie5/Logs/ — one file per character per day; same-day sessions append. Same as `#config autolog`; saved to settings.cfg. Takes effect immediately, even mid-session."/>
        <MenuItem Header="_Record Session (raw XML)"
                  ToggleType="CheckBox"
                  IsChecked="{Binding IsRecording, Mode=OneWay}"
                  Command="{Binding ToggleRecordingCommand}"
                  ToolTip.Tip="Capture the raw game XML stream to a file under AppData/Genie5/Logs/ for later review. One file per Start. Stops automatically on disconnect. While active, the title bar shows ● REC. Use AFTER you connect — toggling before a live session is open captures nothing."/>
        <MenuItem Header="Open _Directory"
                  ToolTip.Tip="Open a Genie data folder in your file browser — Genie 4's File ▸ Open Directory, split out per folder. Each entry also lives on its own menu (Maps, Scripts, Plugins).">
          <MenuItem Header="_Data Folder"
                    Command="{Binding OpenDataFolderCommand}"
                    ToolTip.Tip="The whole Genie data tree — Config, Logs, Maps, Scripts, Plugins, Profiles side by side. {AppData}/Genie5/ (or the portable folder next to the exe)."/>
          <Separator/>
          <MenuItem Header="_Config"
                    Command="{Binding OpenConfigFolderCommand}"
                    ToolTip.Tip="Your active settings files (aliases.cfg, triggers.cfg, highlights.cfg, …). Opens the current character's profile folder when connected, otherwise the shared Config folder."/>
          <MenuItem Header="_Logs"
                    Command="{Binding OpenRecordingsFolderCommand}"
                    ToolTip.Tip="Session logs and raw-XML recordings — Auto Log text files and File ▸ Record Session `.xml` captures both save here."/>
          <MenuItem Header="_Maps"
                    Command="{Binding OpenMapsFolderCommand}"
                    ToolTip.Tip="The map zone XML files the Mapper reads (shared across all characters)."/>
          <MenuItem Header="_Scripts"
                    Command="{Binding OpenScriptsFolderCommand}"
                    ToolTip.Tip="Your .cmd and .js script files."/>
          <MenuItem Header="_Plugins"
                    Command="{Binding OpenPluginsFolderCommand}"
                    ToolTip.Tip="Installed plugin DLLs (shared across all characters)."/>
        </MenuItem>
        <Separator/>
        <MenuItem Header="_Mute Sounds"
                  ToggleType="CheckBox"
                  IsChecked="{Binding IsMuted, Mode=OneWay}"
                  Command="{Binding ToggleMuteCommand}"
                  ToolTip.Tip="Silence all sound effects — trigger/highlight sounds and #play. Same as `#config muted true`; saved to settings.cfg so it persists across sessions. Does not affect #speak text-to-speech."/>
        <Separator/>
        <MenuItem Header="Master _Toggles"
                  ToolTip.Tip="Turn whole features on or off without touching their rules or data — rules stay loaded and editable, they just stop applying. Genie 4 File-menu parity. Saved to settings.cfg; same as `#config triggers off` etc. Rule toggles apply to new lines — already-rendered text is unchanged.">
          <MenuItem Header="_Highlights"  ToggleType="CheckBox" IsChecked="{Binding HighlightsEnabled}"
                    ToolTip.Tip="User highlight rules — colours and highlight sounds (built-in default highlights and Names are unaffected)."/>
          <MenuItem Header="_Triggers"    ToggleType="CheckBox" IsChecked="{Binding TriggersEnabled}"
                    ToolTip.Tip="User triggers — no trigger fires while off."/>
          <MenuItem Header="_Substitutes" ToggleType="CheckBox" IsChecked="{Binding SubstitutesEnabled}"
                    ToolTip.Tip="Substitute rules — lines render exactly as the game sent them while off."/>
          <MenuItem Header="_Gags"        ToggleType="CheckBox" IsChecked="{Binding GagsEnabled}"
                    ToolTip.Tip="Gag rules — nothing is hidden while off."/>
          <MenuItem Header="_Aliases"     ToggleType="CheckBox" IsChecked="{Binding AliasesEnabled}"
                    ToolTip.Tip="Alias expansion — typed commands go to the game exactly as typed while off."/>
          <Separator/>
          <MenuItem Header="_Images"      ToggleType="CheckBox" IsChecked="{Binding ImagesEnabled}"
                    ToolTip.Tip="Room/scene artwork in the Portrait panel — same as `#config showimages`. Off clears the current picture immediately; on re-fetches it."/>
        </MenuItem>
        <Separator/>
        <MenuItem Header="_Import from Genie 4..."
                  Command="{Binding Genie4ImportCommand}"
                  ToolTip.Tip="One-time migration of your Genie 4 settings: highlights, triggers, substitutes, gags, aliases, macros, variables, classes. Choose Global (all characters) or per-character. Your Genie 4 install is left untouched."/>
        <Separator/>
        <MenuItem Header="E_xit"          Command="{Binding ExitCommand}"/>
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="Paste _Multi Line" Click="OnPasteMultiLine"
                  ToolTip.Tip="Paste the clipboard into the command bar with each line joined by the command separator, so every line runs as its own command."/>
        <Separator/>
        <MenuItem Header="_Configuration..."    Command="{Binding ConfigurationCommand}"/>
        <Separator/>
        <MenuItem Header="_Display Settings..." Command="{Binding DisplaySettingsCommand}"/>
        <!-- #20: theme presets + customs, rebuilt on open (code-behind — the
             submenu mixes dynamic radio entries with static Save/Reset items,
             which a single ItemsSource can't express). -->
        <MenuItem x:Name="ThemeMenu" Header="_Theme" SubmenuOpened="OnThemeMenuOpened">
          <MenuItem Header="(loading…)"/>
        </MenuItem>
      </MenuItem>
      <MenuItem Header="_Layout" SubmenuOpened="OnLayoutMenuOpened">
        <MenuItem Header="_Save Layout As..."
                  Command="{Binding SaveLayoutAsCommand}"
                  ToolTip.Tip="Save the current arrangement of panels + hands strip + RT badge etc as a named preset. Each preset lives at {AppData}/Genie5/Layouts/{Name}.json so you can copy / share between machines."/>
        <MenuItem Header="_Load Layout"
                  Classes="layouts-host"
                  ItemsSource="{Binding SavedLayouts}"
                  ToolTip.Tip="Switch to a saved layout preset.">
          <!-- Style the auto-generated container MenuItem per item. Each
               container's DataContext is the LayoutMenuItem record, so the
               Header / Command / CommandParameter bindings resolve against
               it. The :not(.layouts-host) excludes THIS MenuItem itself —
               otherwise Avalonia would also apply the bindings to the host
               (its Styles include the host) and try to coerce the parent
               VM's `Command` property (a CommandViewModel) into ICommand,
               breaking the host menu item mid-hover. -->
          <MenuItem.Styles>
            <Style Selector="MenuItem:not(.layouts-host)">
              <Setter Property="Header"           Value="{Binding Display}"/>
              <Setter Property="Command"          Value="{Binding Command}"/>
              <Setter Property="CommandParameter" Value="{Binding}"/>
            </Style>
          </MenuItem.Styles>
        </MenuItem>
        <MenuItem Header="_Manage Layouts..."
                  Command="{Binding ManageLayoutsCommand}"
                  ToolTip.Tip="Copy layouts between this profile and Global (or other profiles), set the default layout applied on connect, rename, and delete."/>
        <Separator/>
        <MenuItem Header="_Reset to Default Layout"
                  Command="{Binding ResetLayoutCommand}"
                  ToolTip.Tip="Restore the factory-default 3-column arrangement (Room+Streams / Game+Mapper / Inventory)."/>

        <Separator/>
        <!-- ════════════════════════════════════════════════════════════════
             Window-chrome + layout-mode settings moved here from the Window
             menu (per request — Window keeps only panel show/hide toggles).
             Layout still needs a tidy-up pass to regroup these.
             ════════════════════════════════════════════════════════════════ -->

        <!-- ── Hands strip (top / bottom chrome, not a dockable tool) ──── -->
        <!-- All hands-strip controls grouped here so the user sees the toggle,
             the variant toggle, and the two relevant Position submenus
             contiguously. RT lives on the strip in the default arrangement
             (or on the command bar — user's pick), so its Position submenu
             belongs in this group, not floating among the chrome toggles. -->
        <MenuItem Header="Hands _Strip"
                  ToggleType="CheckBox"
                  IsChecked="{Binding Display.ShowHandsBar}"
                  Command="{Binding ToggleHandsBarCommand}"
                  ToolTip.Tip="Show/hide the hands &amp; prepared-spell strip"/>
        <MenuItem Header="_Enhanced Hands Strip"
                  ToggleType="CheckBox"
                  IsChecked="{Binding Display.UseEnhancedHandsStrip}"
                  Command="{Binding ToggleEnhancedHandsStripCommand}"
                  ToolTip.Tip="Add the dylb0t-derived icon widgets (compass rose, posture sprite, status-effect strip) to the hands strip. Layered on top of the existing text widgets — see CREDITS.md for art attribution."/>
        <MenuItem Header="Hands Strip P_osition"
                  ToolTip.Tip="Where the hands strip docks. Top = just below the menu. Bottom = between the command bar and the vitals strip (Genie 4 muscle memory).">
          <MenuItem Header="_Top"
                    ToggleType="Radio" GroupName="HandsPos"
                    IsChecked="{Binding Display.HandsAtTop, Mode=OneWay}"
                    Command="{Binding HandsBarToTopCommand}"
                    ToolTip.Tip="Dock the hands strip at the top of the window, just below the menu."/>
          <MenuItem Header="_Bottom (Genie 4)"
                    ToggleType="Radio" GroupName="HandsPos"
                    IsChecked="{Binding Display.HandsAtBottom, Mode=OneWay}"
                    Command="{Binding HandsBarToBottomCommand}"
                    ToolTip.Tip="Dock the hands strip at the bottom of the window, just above the vitals strip — Genie 4 layout."/>
        </MenuItem>
        <MenuItem Header="_Roundtime Position"
                  ToolTip.Tip="Where the &quot;⏱ N.Ns&quot; roundtime badge appears while you're locked in RT.">
          <MenuItem Header="_Command Bar"
                    ToggleType="Radio" GroupName="RtPos"
                    IsChecked="{Binding Display.RoundTimeOnCommandBar, Mode=OneWay}"
                    Command="{Binding RoundTimeToCommandBarCommand}"
                    ToolTip.Tip="Show the RT badge inline with the command input row at the bottom — Genie 4 layout."/>
          <MenuItem Header="_Hands Strip"
                    ToggleType="Radio" GroupName="RtPos"
                    IsChecked="{Binding Display.RoundTimeOnHandsStrip, Mode=OneWay}"
                    Command="{Binding RoundTimeToHandsStripCommand}"
                    ToolTip.Tip="Show the RT badge as an inline R-badge on the L/R/S hands strip, so the &quot;what's locked&quot; indicators all live together."/>
        </MenuItem>

        <Separator/>

        <!-- ── Global chrome (not part of the hands strip) ──────────────── -->
        <MenuItem Header="Stat_us Bar"
                  ToggleType="CheckBox"
                  IsChecked="{Binding Display.ShowStatusBar}"
                  Command="{Binding ToggleStatusBarCommand}"
                  ToolTip.Tip="Show/hide the Wrayth-style vitals strip at the bottom of the window"/>
        <MenuItem Header="I_con Bar"
                  ToggleType="CheckBox"
                  IsChecked="{Binding Display.ShowIconBar, Mode=OneWay}"
                  Command="{Binding ToggleIconBarCommand}"
                  ToolTip.Tip="Show/hide the character status chips below the vitals bar — posture plus stunned / bleeding / hidden / invisible / webbed / joined / poisoned / diseased (Genie 4's Icon Bar)."/>
        <MenuItem Header="_Magic Panels"
                  ToggleType="CheckBox"
                  IsChecked="{Binding Display.ShowMagicPanels}"
                  Command="{Binding ToggleMagicPanelsCommand}"
                  ToolTip.Tip="Show the magic widgets (Genie 4 parity): the mana bar on the status bar plus the prepared-spell label and cast bar on the hands strip. Turn off to reclaim the space on a non-caster."/>
        <MenuItem Header="_Zone / Room ID"
                  ToggleType="CheckBox"
                  IsChecked="{Binding Display.ShowZoneRoomId}"
                  Command="{Binding ToggleZoneRoomIdCommand}"
                  ToolTip.Tip="Show the current mapper zone and $roomid on a line at the bottom of the window (#66)"/>
        <MenuItem Header="Zone as _Number"
                  ToggleType="CheckBox"
                  IsChecked="{Binding Display.ZoneRoomShowNumber}"
                  Command="{Binding ToggleZoneRoomNumberCommand}"
                  IsEnabled="{Binding Display.ShowZoneRoomId}"
                  ToolTip.Tip="On the Zone / Room ID line, show the numeric $zoneid (e.g. 33) instead of the zone name. Room is always $roomid."/>
        <MenuItem Header="_Windowed Mode (MDI)"
                  ToggleType="CheckBox"
                  IsChecked="{Binding Display.WindowedMode, Mode=OneWay}"
                  Command="{Binding ToggleWindowedModeCommand}"
                  ToolTip.Tip="Genie 4-style windowed mode: every panel becomes a free-floating child window inside the main window, instead of the tabbed/docked layout. The choice and each window's position/size are remembered."/>
        <MenuItem Header="G_uild in Title Bar"
                  ToggleType="CheckBox"
                  IsChecked="{Binding Display.ShowGuildInTitle}"
                  Command="{Binding ToggleGuildInTitleCommand}"
                  ToolTip.Tip="Append the character's guild to the window title (after you've run 'info' this session). Off hides it."/>
        <MenuItem Header="Always on _Top"
                  ToggleType="CheckBox"
                  IsChecked="{Binding Display.AlwaysOnTop}"
                  Command="{Binding ToggleAlwaysOnTopCommand}"
                  ToolTip.Tip="Keep the Genie window above all other applications. Also settable as #config alwaysontop on|off."/>
        <MenuItem Header="Align _Input to Game Window"
                  ToggleType="CheckBox"
                  IsChecked="{Binding AlignInputToGame}"
                  ToolTip.Tip="Line the command bar up horizontally under the Game window instead of spanning the full width (Genie 4 parity). Follows the Game window as you re-dock or resize it; a floated-out Game window falls back to full width. Also settable as #config sizeinputtogame on|off."/>
        <MenuItem Header="_Disconnect Popup"
                  ToggleType="CheckBox"
                  IsChecked="{Binding Display.ShowDisconnectPopup}"
                  Command="{Binding ToggleDisconnectPopupCommand}"
                  ToolTip.Tip="Show a modal 'Disconnected' notice when a session ends and is not auto-reconnecting (server exit/quit, manual disconnect, or a dead link). The timestamped 'disconnected' line in the Game window always appears regardless. (#114)"/>

        <Separator/>

        <!-- Layout reset (moved from the Window menu; dedupe with
             "Reset to Default Layout" above in the cleanup pass). -->
        <MenuItem Header="Reset _Layout"
                  Command="{Binding ResetLayoutCommand}"
                  ToolTip.Tip="Restore all windows to visible (does not move them back to default positions)"/>

      </MenuItem>
      <MenuItem Header="_Window" SubmenuOpened="OnWindowMenuOpened">

        <!-- ── Main document ─────────────────────────────────────────── -->
        <MenuItem Header="_Game"
                  ToggleType="CheckBox"
                  IsChecked="{Binding GameVisible, Mode=OneWay}"
                  Command="{Binding ToggleGameCommand}"
                  ToolTip.Tip="Show/hide the main game text document"/>

        <!-- ── Per-tag visibility within the Game window ─────────────── -->
        <!-- Lets the user mute classes of line without losing game text:
             unchecking "Script Lines" hides [script]…[recorder]… etc.,
             unchecking "Echo Lines" hides typed-command echoes ("> look"),
             unchecking "Game Text" hides server-emitted text (rare to want
             this, but useful in scripted hunting where the user only wants
             to see their own input + script chatter). -->
        <MenuItem Header="Game _Window">
          <MenuItem Header="_Game Text"
                    ToggleType="CheckBox"
                    IsChecked="{Binding Display.ShowGameText}"
                    ToolTip.Tip="Server-emitted text (room descriptions, combat, NPC speech, …). Uncheck to hide all game text from the main window."/>
          <MenuItem Header="_Echo Lines"
                    ToggleType="CheckBox"
                    IsChecked="{Binding Display.ShowEchoText}"
                    ToolTip.Tip="Typed-command echoes (the &quot;&gt; look&quot;-style local echo when you submit input). Uncheck to hide them."/>
          <MenuItem Header="_Script Lines"
                    ToggleType="CheckBox"
                    IsChecked="{Binding Display.ShowScriptText}"
                    ToolTip.Tip="Script-engine and system diagnostics (&quot;[script] foo done&quot;, &quot;[recorder] subscribed&quot;, etc.). Uncheck to hide them during scripted play."/>
        </MenuItem>

        <Separator/>

        <!-- ── Side-dock tools (OneWay IsChecked: only the Command changes
             the bool — no spurious target→source pushes during binding init) -->
        <MenuItem Header="_Vitals"
                  ToggleType="CheckBox"
                  IsChecked="{Binding VitalsVisible, Mode=OneWay}"
                  Command="{Binding ToggleVitalsCommand}"/>
        <MenuItem Header="In_juries"
                  ToggleType="CheckBox"
                  IsChecked="{Binding InjuriesVisible, Mode=OneWay}"
                  Command="{Binding ToggleInjuriesCommand}"
                  ToolTip.Tip="Body-region wound/scar display from the server's injuries panel. Shows whichever view your injury display mode (_injury) has selected."/>
        <MenuItem Header="_Room"
                  ToggleType="CheckBox"
                  IsChecked="{Binding RoomVisible, Mode=OneWay}"
                  Command="{Binding ToggleRoomCommand}"/>
        <MenuItem Header="_Mobs"
                  ToggleType="CheckBox"
                  IsChecked="{Binding MobsVisible, Mode=OneWay}"
                  Command="{Binding ToggleMobsCommand}"
                  ToolTip.Tip="Creatures in the current room, one per line (Genie 3/4 Mobs window). Filtered through the ignore list, so ground items don't show."/>
        <MenuItem Header="Pla_yers"
                  ToggleType="CheckBox"
                  IsChecked="{Binding PlayersVisible, Mode=OneWay}"
                  Command="{Binding TogglePlayersCommand}"
                  ToolTip.Tip="Other players in the current room, one per line (Genie 3/4 Players window)."/>
        <MenuItem Header="_Inventory"
                  ToggleType="CheckBox"
                  IsChecked="{Binding BackpackVisible, Mode=OneWay}"
                  Command="{Binding ToggleBackpackCommand}"/>

        <Separator/>

        <!-- ── Stream tools ──────────────────────────────────────────── -->
        <MenuItem Header="_Logons"
                  ToggleType="CheckBox"
                  IsChecked="{Binding LogonsVisible, Mode=OneWay}"
                  Command="{Binding ToggleLogonsCommand}"/>
        <MenuItem Header="_Talk"
                  ToggleType="CheckBox"
                  IsChecked="{Binding TalkVisible, Mode=OneWay}"
                  Command="{Binding ToggleTalkCommand}"/>
        <MenuItem Header="_Whispers"
                  ToggleType="CheckBox"
                  IsChecked="{Binding WhispersVisible, Mode=OneWay}"
                  Command="{Binding ToggleWhispersCommand}"/>
        <MenuItem Header="T_houghts"
                  ToggleType="CheckBox"
                  IsChecked="{Binding ThoughtsVisible, Mode=OneWay}"
                  Command="{Binding ToggleThoughtsCommand}"/>
        <MenuItem Header="_Combat"
                  ToggleType="CheckBox"
                  IsChecked="{Binding CombatVisible, Mode=OneWay}"
                  Command="{Binding ToggleCombatCommand}"/>
        <MenuItem Header="_Familiar"
                  ToggleType="CheckBox"
                  IsChecked="{Binding FamiliarVisible, Mode=OneWay}"
                  Command="{Binding ToggleFamiliarCommand}"
                  ToolTip.Tip="Familiar / creature-watching feed — the server `familiar` stream."/>
        <MenuItem Header="_Deaths"
                  ToggleType="CheckBox"
                  IsChecked="{Binding DeathVisible, Mode=OneWay}"
                  Command="{Binding ToggleDeathCommand}"
                  ToolTip.Tip="Death log — the server `death` stream (e.g. &quot;* X was just struck down!&quot;)."/>
        <MenuItem Header="_Assess"
                  ToggleType="CheckBox"
                  IsChecked="{Binding AssessVisible, Mode=OneWay}"
                  Command="{Binding ToggleAssessCommand}"
                  ToolTip.Tip="Assess feed — the server `assess` stream."/>
        <MenuItem Header="At_mospherics"
                  ToggleType="CheckBox"
                  IsChecked="{Binding AtmosphericsVisible, Mode=OneWay}"
                  Command="{Binding ToggleAtmosphericsCommand}"
                  ToolTip.Tip="Atmospherics / ambient feed — the server `atmospherics` stream (weather + room flavour)."/>
        <MenuItem Header="Lo_g"
                  ToggleType="CheckBox"
                  IsChecked="{Binding LogVisible, Mode=OneWay}"
                  Command="{Binding ToggleLogCommand}"
                  ToolTip.Tip="Consolidated conversation log — mirrors the Talk and Whispers speech streams. Also the target for script `#echo &gt;log`."/>
        <MenuItem Header="_Item Log"
                  ToggleType="CheckBox"
                  IsChecked="{Binding ItemLogVisible, Mode=OneWay}"
                  Command="{Binding ToggleItemLogCommand}"
                  ToolTip.Tip="Item / loot log — fed by the server itemLog stream and by script `#echo &gt;itemlog`."/>

        <Separator/>

        <MenuItem Header="_Experience"
                  ToggleType="CheckBox"
                  IsChecked="{Binding ExperienceVisible, Mode=OneWay}"
                  Command="{Binding ToggleExperienceCommand}"
                  ToolTip.Tip="Skill ranks and learning rates, tracked by the Experience plugin. Train a skill or type 'exp' to populate it."/>
        <MenuItem Header="A_nalytics"
                  ToggleType="CheckBox"
                  IsChecked="{Binding AnalyticsVisible, Mode=OneWay}"
                  Command="{Binding ToggleAnalyticsCommand}"
                  ToolTip.Tip="Skill-history charts — XP/hour, gain curves, and session comparison from locally recorded history (#config analytics)."/>
        <MenuItem Header="_Active Spells"
                  ToggleType="CheckBox"
                  IsChecked="{Binding ActiveSpellsVisible, Mode=OneWay}"
                  Command="{Binding ToggleActiveSpellsCommand}"
                  ToolTip.Tip="Active spell durations, tracked by the Spell Timer. Populates when you have spells running."/>
        <MenuItem Header="Time Trac_ker"
                  ToggleType="CheckBox"
                  IsChecked="{Binding TimeTrackerVisible, Mode=OneWay}"
                  Command="{Binding ToggleTimeTrackerCommand}"
                  ToolTip.Tip="Elanthian date, moon/sun rise-set countdowns and observed sky, tracked by the built-in Time Tracker (/tt help)."/>
        <MenuItem Header="In_ventory View"
                  ToggleType="CheckBox"
                  IsChecked="{Binding InventoryViewVisible, Mode=OneWay}"
                  Command="{Binding ToggleInventoryViewCommand}"
                  ToolTip.Tip="Searchable catalog of every scanned character's items — person, vault, deeds, home, trader (/iv scan)."/>
        <MenuItem Header="P_ortrait"
                  ToggleType="CheckBox"
                  IsChecked="{Binding SceneVisible, Mode=OneWay}"
                  Command="{Binding ToggleSceneCommand}"
                  ToolTip.Tip="DR room/scene artwork for locations that have it — Genie 4's Portrait window (previously named Scene here). Requires #config showimages true (default). Empty for rooms without art."/>
        <MenuItem Header="Raw _XML"
                  ToggleType="CheckBox"
                  IsChecked="{Binding RawXmlVisible, Mode=OneWay}"
                  Command="{Binding ToggleRawXmlCommand}"
                  ToolTip.Tip="Live verbatim server XML stream — the raw bytes the parser sees, before tag stripping. Covers Genie 4's Debug and Raw windows. For parser development and 'where did that come from?' debugging. Local view only; default hidden."/>

        <!-- ── Plugin-created windows (dynamic) ─────────────────────────── -->
        <!-- Populated at runtime from the dock factory whenever a plugin     -->
        <!-- writes to a named window (IPluginHost.SetWindow/EchoToWindow).   -->
        <!-- Each child is a checkbox toggling that panel's visibility.       -->
        <MenuItem Header="Plugin _Windows"
                  Classes="plugin-windows-host"
                  ItemsSource="{Binding PluginWindowMenuItems}"
                  ToolTip.Tip="Windows created by plugins (e.g. Inventory View). Each plugin that opens its own panel appears here — toggle to show/hide. Empty until a plugin opens a window.">
          <MenuItem.Styles>
            <Style Selector="MenuItem:not(.plugin-windows-host)">
              <Setter Property="Header"     Value="{Binding Title}"/>
              <Setter Property="ToggleType" Value="CheckBox"/>
              <Setter Property="IsChecked"  Value="{Binding IsVisible, Mode=OneWay}"/>
              <Setter Property="Command"    Value="{Binding ToggleCommand}"/>
            </Style>
          </MenuItem.Styles>
        </MenuItem>

      </MenuItem>

      <!-- ── Plugins ─────────────────────────────────────────────────────── -->
      <MenuItem Header="_Plugins" SubmenuOpened="OnPluginsMenuOpened">
        <MenuItem Header="_Open Plugins Folder"
                  Command="{Binding OpenPluginsFolderCommand}"
                  ToolTip.Tip="Open {AppData}/Genie5/Plugins — drop plugin .dll files here. Loaded on connect (and via Reload)."/>
        <MenuItem Header="_Reload Plugins"
                  Command="{Binding ReloadPluginsCommand}"
                  ToolTip.Tip="Re-scan the Plugins folder and load any new .dll plugins into the current session."/>
        <Separator/>
        <MenuItem Header="_Load"
                  Classes="plugins-load-host"
                  ItemsSource="{Binding AvailablePluginFiles}"
                  ToolTip.Tip="Load an individual plugin .dll sitting in the Plugins folder that isn't loaded yet.">
          <MenuItem.Styles>
            <Style Selector="MenuItem:not(.plugins-load-host)">
              <Setter Property="Header"  Value="{Binding Display}"/>
              <Setter Property="Command" Value="{Binding LoadCommand}"/>
            </Style>
          </MenuItem.Styles>
        </MenuItem>
        <MenuItem Header="Enable / _Disable"
                  Classes="plugins-host"
                  ItemsSource="{Binding PluginMenuItems}"
                  ToolTip.Tip="Enable/disable each loaded plugin for this session. Disabled plugins stay loaded (re-enable is instant); the plugin's window blanks while off.">
          <MenuItem.Styles>
            <!-- Per-plugin checkbox. :not(.plugins-host) excludes this host item
                 so the bindings only apply to the generated child containers. -->
            <Style Selector="MenuItem:not(.plugins-host)">
              <Setter Property="Header"     Value="{Binding Display}"/>
              <Setter Property="ToggleType" Value="CheckBox"/>
              <Setter Property="IsChecked"  Value="{Binding Enabled, Mode=OneWay}"/>
              <Setter Property="Command"    Value="{Binding ToggleCommand}"/>
            </Style>
          </MenuItem.Styles>
        </MenuItem>
        <MenuItem Header="_Unload"
                  Classes="plugins-unload-host"
                  ItemsSource="{Binding PluginMenuItems}"
                  ToolTip.Tip="Fully unload a plugin — removes it and releases its .dll so it can be replaced/deleted. Use Reload Plugins to bring it back.">
          <MenuItem.Styles>
            <Style Selector="MenuItem:not(.plugins-unload-host)">
              <Setter Property="Header"  Value="{Binding Display}"/>
              <Setter Property="Command" Value="{Binding UnloadCommand}"/>
            </Style>
          </MenuItem.Styles>
        </MenuItem>
      </MenuItem>

      <!-- ── Scripts menu (Genie 4 parity) ────────────────────────────────── -->
      <!-- Mirrors Genie 4's Scripts menu (Forms/FormMain.cs Abort/Pause/      -->
      <!-- Resume/List/Trace All Scripts). Command-bar equivalents:             -->
      <!--   #scripts, #stopall, #pauseall, #resumeall, #traceall N              -->
      <!-- For per-script operations (Run, Edit, Stop one), use the Script Bar  -->
      <!-- (auto-shown at the bottom when any script is running) or the         -->
      <!-- dockable Scripts panel (toggle via Window menu).                     -->
      <MenuItem Header="_Scripts" SubmenuOpened="OnWindowMenuOpened">
        <!-- The Script Manager panel toggle lives here (not under Window) —
             it's the scripts workspace, so this is where users look for it.
             OnWindowMenuOpened refreshes the check mark from the dock's true
             state, same as the Window menu. -->
        <MenuItem Header="Script _Manager"
                  ToggleType="CheckBox"
                  IsChecked="{Binding ScriptsVisible, Mode=OneWay}"
                  Command="{Binding ToggleScriptsCommand}"
                  ToolTip.Tip="Browse, run, and edit your script library, and manage running scripts (.cmd and .js) — pause, stop, reload, vars, trace. Also opens via #script explorer."/>
        <Separator/>
        <MenuItem Header="_List Running Scripts"
                  Command="{Binding ListRunningScriptsCommand}"
                  ToolTip.Tip="Echo the names of currently running scripts to the Game window. Same as #scripts."/>
        <Separator/>
        <MenuItem Header="_Pause All Scripts"
                  Command="{Binding PauseAllScriptsCommand}"
                  ToolTip.Tip="Pause every running script. State is preserved; resume with the entry below. Same as #pauseall."/>
        <MenuItem Header="_Resume All Scripts"
                  Command="{Binding ResumeAllScriptsCommand}"
                  ToolTip.Tip="Clear UserPaused on every script. Same as #resumeall."/>
        <MenuItem Header="_Abort All Scripts"
                  Command="{Binding AbortAllScriptsCommand}"
                  ToolTip.Tip="Stop every running script. Same as #stopall."/>
        <Separator/>
        <MenuItem Header="_Trace All Scripts"
                  ToolTip.Tip="Apply a debug / tracing level to every running script. 0 disables; higher values surface more script-internal echoes. Same as #traceall N.">
          <MenuItem Header="_Off (no traces)"
                    Command="{Binding TraceAllScriptsCommand}" CommandParameter="0"/>
          <MenuItem Header="_1 — minimal"
                    Command="{Binding TraceAllScriptsCommand}" CommandParameter="1"/>
          <MenuItem Header="_3 — moderate"
                    Command="{Binding TraceAllScriptsCommand}" CommandParameter="3"/>
          <MenuItem Header="_5 — verbose"
                    Command="{Binding TraceAllScriptsCommand}" CommandParameter="5"/>
          <MenuItem Header="_10 — maximum"
                    Command="{Binding TraceAllScriptsCommand}" CommandParameter="10"/>
        </MenuItem>
        <Separator/>
        <!-- External editor for Edit Script (Script Manager, Script Bar ✏,
             #edit). Shows the resolved launch-ladder rung; Change… writes the
             Display-settings override (same value as Display Settings →
             External editor), Use OS Default clears it. -->
        <MenuItem Header="External _Editor"
                  SubmenuOpened="OnScriptsEditorMenuOpened"
                  ToolTip.Tip="The program Edit Script opens files with — override → #config editor → OS default.">
          <MenuItem Header="{Binding Scripts.EditorDisplay}" IsEnabled="False"/>
          <Separator/>
          <MenuItem Header="_Change…"
                    Command="{Binding Scripts.ChangeEditorCommand}"
                    ToolTip.Tip="Pick the editor program via file picker."/>
          <MenuItem Header="Use OS _Default"
                    Command="{Binding Scripts.DefaultEditorCommand}"
                    ToolTip.Tip="Clear the override — fall back to #config editor, then the OS default text editor."/>
        </MenuItem>
        <Separator/>
        <MenuItem Header="_Open Scripts Folder"
                  Command="{Binding OpenScriptsFolderCommand}"
                  ToolTip.Tip="Open the per-character Scripts directory in your OS file browser (the folder where .cmd scripts are loaded from)."/>
      </MenuItem>

      <!-- ── Analyst menu — redacted, analyst-readable session captures ────── -->
      <!-- Policy-safe data gathering: redaction is ON by default (other         -->
      <!-- players' speech stripped), captures are local-only, and recipes never -->
      <!-- auto-run — the user starts each one. OFF by default each session.     -->
      <MenuItem Header="_Analyst">
        <MenuItem Header="_Enable Analyst Capture"
                  ToggleType="CheckBox"
                  IsChecked="{Binding AnalystCaptureEnabled, Mode=OneWay}"
                  Command="{Binding ToggleAnalystCaptureCommand}"
                  ToolTip.Tip="Capture a REDACTED copy of the session (other players' speech stripped) to a folder you choose, for parser / analysis work. Local-only; nothing is sent anywhere automatically. OFF by default each session."/>
        <Separator/>
        <MenuItem Header="_Run Capture Recipe"
                  Classes="recipes-host"
                  IsEnabled="{Binding AnalystCaptureEnabled}"
                  ItemsSource="{Binding CaptureRecipes}"
                  ToolTip.Tip="Run a predefined capture recipe. A confirmation dialog shows its preconditions and the exact commands it sends; capture runs while the recipe plays.">
          <!-- Same container-style trick as Layout → Load (see that menu): the
               :not(.recipes-host) selector styles only the generated child
               items (each a RecipeMenuItem), not this host item. -->
          <MenuItem.Styles>
            <Style Selector="MenuItem:not(.recipes-host)">
              <Setter Property="Header"           Value="{Binding Display}"/>
              <Setter Property="Command"          Value="{Binding Command}"/>
              <Setter Property="CommandParameter" Value="{Binding}"/>
            </Style>
          </MenuItem.Styles>
        </MenuItem>
        <MenuItem Header="_Start Manual Capture"
                  Command="{Binding StartManualCaptureCommand}"
                  IsEnabled="{Binding AnalystCaptureEnabled}"
                  ToolTip.Tip="Begin a capture with no recipe — you drive the game, then Stop Capture when done."/>
        <MenuItem Header="S_top Capture"
                  Command="{Binding StopCaptureCommand}"
                  IsEnabled="{Binding IsCapturing}"
                  ToolTip.Tip="End the active capture and write its .meta.json sidecar."/>
        <Separator/>
        <MenuItem Header="_Open Capture Folder"
                  Command="{Binding OpenCaptureFolderCommand}"
                  ToolTip.Tip="Open the capture output folder in your file browser."/>
        <MenuItem Header="Set _Capture Folder…"
                  Command="{Binding SetCaptureFolderCommand}"
                  ToolTip.Tip="Choose where captures are written — point this at a folder the analyst (or an AI assistant) can read directly."/>
        <MenuItem Header="Set Recipe _Folder…"
                  Command="{Binding SetRecipeFolderCommand}"
                  ToolTip.Tip="Add a folder of your own .cmd + .json capture recipes, loaded alongside the built-ins."/>
      </MenuItem>

      <!-- ── Performance menu — live pipeline timing + regex safety ───────── -->
      <!-- Safety (regex match-timeout + literal pre-filter) is ON by default    -->
      <!-- and toggleable per component; the overlay shows per-stage timing and  -->
      <!-- only collects metrics while it is open. The two axes are independent: -->
      <!-- you can run a component safely without watching it, or watch it       -->
      <!-- without the safety net.                                               -->
      <!-- ── Help menu (badge appears when UpdatesAvailable) ─────────────── -->
      <!-- Link set mirrors the Genie 4 Help menu (Forms/FormMain). Repo links   -->
      <!-- (Latest Release / GitHub / Wiki) point at GenieClient/Genie5; the      -->
      <!-- Community Links submenu carries over Genie 4's game/community links.   -->
      <MenuItem Header="{Binding HelpMenuHeader}">
        <MenuItem Header="Check for _Updates…"
                  Command="{Binding ShowUpdatesCommand}"
                  ToolTip.Tip="Open the Updates dialog — Core / Maps / Plugins / Scripts, with per-source enable, check, and update."/>
        <MenuItem Header="Update _Settings"
                  ToolTip.Tip="What the silent startup update check covers, and what it's allowed to install by itself. Everything here is also visible in the Updates dialog.">
          <MenuItem Header="Check on Startup">
            <MenuItem Header="_Genie (Core App)" ToggleType="CheckBox" IsChecked="{Binding CheckCoreOnStartup}"
                      ToolTip.Tip="Look for a newer Genie release at launch. Found updates light the Help ● badge and the status-bar notice — nothing installs without you."/>
            <MenuItem Header="_Maps"             ToggleType="CheckBox" IsChecked="{Binding CheckMapsOnStartup}"
                      ToolTip.Tip="Check the enabled map sources at launch."/>
            <MenuItem Header="_Plugins"          ToggleType="CheckBox" IsChecked="{Binding CheckPluginsOnStartup}"
                      ToolTip.Tip="Check the enabled plugin sources at launch."/>
            <MenuItem Header="_Scripts"          ToggleType="CheckBox" IsChecked="{Binding CheckScriptsOnStartup}"
                      ToolTip.Tip="Check the enabled script repositories at launch."/>
          </MenuItem>
          <MenuItem Header="Auto-Apply"
                    ToolTip.Tip="Install what the startup check finds, without a click. All OFF by default — updates only ever download automatically if you opt in here.">
            <MenuItem Header="_Genie (Core App)" ToggleType="CheckBox" IsChecked="{Binding AutoUpdateCore}"
                      ToolTip.Tip="Download a found Genie update in the background and install it when you CLOSE Genie — never a restart mid-session. The status bar notes when a version is staged."/>
            <MenuItem Header="_Maps"             ToggleType="CheckBox" IsChecked="{Binding AutoUpdateMaps}"
                      ToolTip.Tip="Pull new/changed map files at startup (pure data — safest to automate)."/>
            <MenuItem Header="_Plugins"          ToggleType="CheckBox" IsChecked="{Binding AutoUpdatePlugins}"
                      ToolTip.Tip="Install plugin updates at startup. Plugins are executable code — enable only for sources you trust."/>
            <MenuItem Header="_Scripts"          ToggleType="CheckBox" IsChecked="{Binding AutoUpdateScripts}"
                      ToolTip.Tip="Pull script updates at startup. Scripts act as your character, and a repo file with the same name OVERWRITES a locally edited copy — enable only for sources you trust."/>
          </MenuItem>
        </MenuItem>
        <MenuItem Header="_Latest Release Page"
                  Command="{Binding OpenLatestReleaseCommand}"
                  ToolTip.Tip="Open the Genie 5 releases page on GitHub — download the newest signed build for your platform."/>
        <MenuItem Header="_Changelog"
                  Command="{Binding ShowChangelogCommand}"
                  ToolTip.Tip="Read this build's release notes in-app — what changed in this and previous versions."/>
        <Separator/>
        <MenuItem Header="Join _Discord"
                  Command="{Binding OpenDiscordCommand}"
                  ToolTip.Tip="Opens the Genie community Discord (shared with Genie 4) in your default browser. Drop in for alpha-tester chat, scripting help, mapper questions."/>
        <MenuItem Header="_GitHub"
                  Command="{Binding OpenGitHubCommand}"
                  ToolTip.Tip="Open the Genie 5 source repository on GitHub."/>
        <MenuItem Header="_Wiki"
                  Command="{Binding OpenWikiCommand}"
                  ToolTip.Tip="Open the Genie 5 wiki — setup guides, scripting reference, and FAQ."/>
        <Separator/>
        <MenuItem Header="_Performance">
          <MenuItem Header="Show Performance _Overlay"
                    ToggleType="CheckBox"
                    IsChecked="{Binding Perf.OverlayVisible, Mode=OneWay}"
                    Command="{Binding TogglePerfOverlayCommand}"
                    ToolTip.Tip="Show a live overlay of per-stage pipeline timing — parse, scripts, triggers, highlights, substitutes, gags, plugins — with average / peak ms and caught-timeout counts. Metrics are collected only while the overlay is shown."/>
          <MenuItem Header="_Reset Counters"
                    Command="{Binding Perf.ResetCommand}"
                    ToolTip.Tip="Zero all timing samples and timeout counts for a fresh reading."/>
          <Separator/>
          <MenuItem Header="_Safety — regex timeout + pre-filter"
                    ToolTip.Tip="Each engine's user regexes run with a match-timeout (a catastrophic pattern is caught and skipped, never hangs the feed) plus a literal pre-filter. ON by default; turn off per component only to reproduce a raw-regex issue.">
            <MenuItem Header="_Triggers"    ToggleType="CheckBox" IsChecked="{Binding TriggersSafety}"
                      ToolTip.Tip="Match-timeout + pre-filter for user triggers (runs on the read thread — the highest-value protection)."/>
            <MenuItem Header="_Highlights"  ToggleType="CheckBox" IsChecked="{Binding HighlightsSafety}"
                      ToolTip.Tip="Match-timeout + pre-filter for regex-type highlight rules (render path)."/>
            <MenuItem Header="_Substitutes" ToggleType="CheckBox" IsChecked="{Binding SubstitutesSafety}"
                      ToolTip.Tip="Match-timeout + pre-filter for substitute rules (display path)."/>
            <MenuItem Header="_Gags"        ToggleType="CheckBox" IsChecked="{Binding GagsSafety}"
                      ToolTip.Tip="Match-timeout + pre-filter for gag rules (display path)."/>
          </MenuItem>
          <MenuItem Header="Overlay _Components"
                    Classes="perf-rows-host"
                    ItemsSource="{Binding Perf.Rows}"
                    ToolTip.Tip="Choose which pipeline stages appear in the overlay. Independent of safety — hiding a row doesn't change protection.">
            <!-- Container style targets only the generated per-row items (each a
                 PerfRowViewModel), not this host — same trick as Layout → Load. -->
            <MenuItem.Styles>
              <Style Selector="MenuItem:not(.perf-rows-host)">
                <Setter Property="Header"     Value="{Binding Name}"/>
                <Setter Property="ToggleType" Value="CheckBox"/>
                <Setter Property="IsChecked"  Value="{Binding Visible}"/>
              </Style>
            </MenuItem.Styles>
          </MenuItem>
        </MenuItem>
        <Separator/>
        <MenuItem Header="_Community Links">
          <MenuItem Header="_Play.net"
                    Command="{Binding OpenPlayNetCommand}"
                    ToolTip.Tip="Simutronics' Play.net portal for DragonRealms — account, billing, and game launch."/>
          <MenuItem Header="_Elanthipedia"
                    Command="{Binding OpenElanthipediaCommand}"
                    ToolTip.Tip="Elanthipedia — the community DragonRealms wiki (lore, mechanics, item data)."/>
          <MenuItem Header="_DR Service"
                    Command="{Binding OpenDrServiceCommand}"
                    ToolTip.Tip="DR Service (drservice.info) — community status and service tools for DragonRealms."/>
          <MenuItem Header="_Lich Discord"
                    Command="{Binding OpenLichDiscordCommand}"
                    ToolTip.Tip="The Lich 5 community Discord — proxy scripts and Ruby automation support."/>
          <MenuItem Header="_Isharon's Genie Settings"
                    Command="{Binding OpenIsharonSettingsCommand}"
                    ToolTip.Tip="Isharon's curated Genie settings collection (elanthia.org/GenieSettings) — highlights, names, presets, and more."/>
        </MenuItem>
        <Separator/>
        <MenuItem Header="_About Genie 5…"
                  Command="{Binding ShowAboutCommand}"
                  ToolTip.Tip="Version, links, license, and credits."/>
      </MenuItem>
      <MenuItem Header="_Maps">
        <MenuItem Header="_Show Mapper"
                  ToggleType="CheckBox"
                  IsChecked="{Binding MapperVisible, Mode=OneWay}"
                  Command="{Binding ToggleMapperCommand}"
                  ToolTip.Tip="Show or hide the Mapper panel."/>
        <MenuItem Header="_Float Mapper Window"
                  Command="{Binding Mapper.FloatCommand}"
                  ToolTip.Tip="Pop the Mapper out into its own OS window. Drag its title bar back over Genie to re-dock."/>
        <MenuItem Header="AutoMapper _Settings..."
                  Command="{Binding ShowMapperSettingsCommand}"
                  ToolTip.Tip="AutoMapper on/off, map overlay opacity, auto-walk pause-on-unfocus, and map colours — in one place."/>
        <MenuItem Header="Show Map _Legend"
                  ToggleType="CheckBox"
                  IsChecked="{Binding Mapper.ShowMapLegend, Mode=TwoWay}"
                  ToolTip.Tip="Show the on-map colour key (room / path / exit-stub colours) in the top-left of the map."/>
        <Separator/>
        <MenuItem Header="_Update from Official Repo..."
                  Command="{Binding Mapper.UpdateMapsCommand}"
                  ToolTip.Tip="Download the latest zone XML files from github.com/GenieClient/Maps and merge with your local maps directory."/>
        <MenuItem Header="_Open Maps Folder"
                  Command="{Binding OpenMapsFolderCommand}"
                  ToolTip.Tip="Open the current Maps directory in your file browser so you can see / hand-edit the .xml zone files."/>
        <MenuItem Header="C_hange Maps Directory..."
                  Command="{Binding SetMapsDirectoryCommand}"
                  ToolTip.Tip="Pick a DIFFERENT folder to use as your Maps directory. Useful for pointing at a local git clone of github.com/GenieClient/Maps for git workflow (pull / push / pull-request)."/>
        <Separator/>
        <MenuItem Header="Cross-_Zone Connections..."
                  Command="{Binding ZoneConnectionsCommand}"
                  ToolTip.Tip="Open the meta-graph editor: transit links between zones (boats, climb-walls, ferry crossings) that the multi-zone pathfinder consults. Saves to {MapsDirectory}/ZoneConnections.xml."/>
      </MenuItem>
    </Menu>

    <!-- ── Hands / prepared-spell strip (Wrayth-style) ──────────────────── -->
    <!-- Two declarations, one at top, one at bottom — IsVisible picks which     -->
    <!-- one is realized based on Display.HandsAtBottom. Both bind to the same   -->
    <!-- VitalsViewModel data, so flipping the toggle is instant and lossless.   -->
    <!-- (DataTemplate-via-Resource would dedupe the markup, but a direct        -->
    <!-- duplicate keeps the file self-contained and easy to read.)              -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding Display.ShowHandsTop}"
            Background="{DynamicResource Theme.StripBg}"
            BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,0,0,1"
            Padding="10,5">
      <StackPanel Orientation="Horizontal" Spacing="24">

        <!-- ── Roundtime (optional position) ─────────────────────────
             Inline RT badge — visible only when the user chose "Hands Strip"
             for the roundtime position. ShowRtOnHandsStrip is computed on
             MainWindowViewModel as (Vitals.InRoundTime AND
             Display.RoundTimeOnHandsStrip). Red palette matches the command-
             bar version so the indicator means the same thing wherever it
             sits. -->
        <StackPanel Orientation="Horizontal" Spacing="6"
                    IsVisible="{Binding ShowRtOnHandsStrip}">
          <Border Background="#5a1a1a" BorderBrush="#8a2a2a" BorderThickness="1"
                  CornerRadius="2" Padding="6,1">
            <TextBlock Text="R" Foreground="#ffd0d0" FontWeight="SemiBold" FontSize="11"
                       ToolTip.Tip="Roundtime — your character can't act until this expires"/>
          </Border>
          <TextBlock Text="{Binding Vitals.RoundTimeSeconds, StringFormat='{}{0:F1}s'}"
                     AutomationProperties.Name="{Binding Vitals.RoundTimeSeconds, StringFormat='Roundtime: {0:F1} seconds'}"
                     Foreground="#ffd0d0" FontSize="12" MinWidth="40"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── Enhanced (dylb0t-derived) icon widgets ─────────────────
             Collapsed by default; toggled on via Window → Enhanced Hands
             Strip. Compass = pixel-art rose with one overlay per active
             exit; Body = posture sprite (standing/sitting/kneeling/prone/
             dead); StatusIcons = 6-slot row covering stunned, bleeding,
             invisible, hidden, joined, webbed. All three subscribe to
             VitalsViewModel directly; no extra bindings to maintain.
             Art credit: @dylb0t — see CREDITS.md. -->
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                    IsVisible="{Binding Display.UseEnhancedHandsStrip}">
          <controls:CompassView   Vitals="{Binding Vitals}" VerticalAlignment="Center"
                                  AutomationProperties.Name="Compass"
                                  ToolTip.Tip="Compass — pixel-art rose with one overlay per active exit (data from the server's &lt;compass&gt; payload)."/>
          <controls:BodyView      Vitals="{Binding Vitals}" VerticalAlignment="Center"
                                  AutomationProperties.Name="Posture"
                                  ToolTip.Tip="Posture sprite — standing / sitting / kneeling / prone / dead."/>
          <controls:StatusIconBar Vitals="{Binding Vitals}" VerticalAlignment="Center"
                                  AutomationProperties.Name="Status effects"
                                  ToolTip.Tip="Active afflictions: stunned, bleeding, invisible, hidden, joined, webbed. Empty slots stay blank."/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="6">
          <Border Background="#2a2a2a" CornerRadius="2" Padding="6,1">
            <TextBlock Text="L" Foreground="{DynamicResource Theme.TextSecondary}" FontWeight="SemiBold" FontSize="11"/>
          </Border>
          <TextBlock Text="{Binding Vitals.LeftHand, FallbackValue=Empty}"
                     AutomationProperties.Name="{Binding Vitals.LeftHand, StringFormat='Left hand: {0}'}"
                     AutomationProperties.LiveSetting="Polite"
                     Foreground="{DynamicResource Theme.TextPrimary}" FontSize="12" MinWidth="140"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="6">
          <Border Background="#2a2a2a" CornerRadius="2" Padding="6,1">
            <TextBlock Text="R" Foreground="{DynamicResource Theme.TextSecondary}" FontWeight="SemiBold" FontSize="11"/>
          </Border>
          <TextBlock Text="{Binding Vitals.RightHand, FallbackValue=Empty}"
                     AutomationProperties.Name="{Binding Vitals.RightHand, StringFormat='Right hand: {0}'}"
                     AutomationProperties.LiveSetting="Polite"
                     Foreground="{DynamicResource Theme.TextPrimary}" FontSize="12" MinWidth="140"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── Stance ────────────────────────────────────────────────
             Six mutually-exclusive badges (one per DR stance) wired to
             mutually-exclusive bools on VitalsViewModel. Color follows the
             red→green gradient that matches the stance gauge in Genie 4:
             red for all-out attack, green for full defense. Whole sub-group
             collapses to zero width pre-connect (no badge true) but as soon
             as the server pushes the first <component id="pc stance"> the
             matching one lights up. -->
        <Border IsVisible="{Binding Vitals.IsStanceOffensive}"
                Background="#3a1818" CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                ToolTip.Tip="Stance: Offensive — maximum damage out, minimum defense.">
          <TextBlock Text="OFF" Foreground="#ff5050" FontSize="10" FontWeight="SemiBold"
                     AutomationProperties.HelpText="Stance: Offensive — maximum damage out, minimum defense."/>
        </Border>
        <Border IsVisible="{Binding Vitals.IsStanceAdvance}"
                Background="#3a2418" CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                ToolTip.Tip="Stance: Advance — favors attack over defense.">
          <TextBlock Text="ADV" Foreground="#ff8040" FontSize="10" FontWeight="SemiBold"
                     AutomationProperties.HelpText="Stance: Advance — favors attack over defense."/>
        </Border>
        <Border IsVisible="{Binding Vitals.IsStanceForward}"
                Background="#3a3018" CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                ToolTip.Tip="Stance: Forward — slight tilt toward attack.">
          <TextBlock Text="FWD" Foreground="#ffb040" FontSize="10" FontWeight="SemiBold"
                     AutomationProperties.HelpText="Stance: Forward — slight tilt toward attack."/>
        </Border>
        <Border IsVisible="{Binding Vitals.IsStanceNeutral}"
                Background="#2a2a2a" CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                ToolTip.Tip="Stance: Neutral — balanced offense and defense.">
          <TextBlock Text="NEU" Foreground="#d8c060" FontSize="10" FontWeight="SemiBold"
                     AutomationProperties.HelpText="Stance: Neutral — balanced offense and defense."/>
        </Border>
        <Border IsVisible="{Binding Vitals.IsStanceGuarded}"
                Background="#1c3018" CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                ToolTip.Tip="Stance: Guarded — slight tilt toward defense.">
          <TextBlock Text="GRD" Foreground="#80c060" FontSize="10" FontWeight="SemiBold"
                     AutomationProperties.HelpText="Stance: Guarded — slight tilt toward defense."/>
        </Border>
        <Border IsVisible="{Binding Vitals.IsStanceDefensive}"
                Background="#143a14" CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                ToolTip.Tip="Stance: Defensive — maximum defense, minimum damage out.">
          <TextBlock Text="DEF" Foreground="#40d060" FontSize="10" FontWeight="SemiBold"
                     AutomationProperties.HelpText="Stance: Defensive — maximum defense, minimum damage out."/>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="6">
          <!-- Hidden entirely when Magic Panels is off (Genie 4 SetMagicPanels
               hides LabelSpell/LabelSpellC too), AND-ed with the existing
               #config spelltimer gate. -->
          <StackPanel.IsVisible>
            <MultiBinding Converter="{x:Static BoolConverters.And}">
              <Binding Path="Vitals.IsSpellTimerVisible"/>
              <Binding Path="Display.ShowMagicPanels"/>
            </MultiBinding>
          </StackPanel.IsVisible>
          <Border Background="#2a2a2a" CornerRadius="2" Padding="6,1">
            <TextBlock Text="S" Foreground="{DynamicResource Theme.TextSecondary}" FontWeight="SemiBold" FontSize="11"
                       ToolTip.Tip="Prepared spell. (N) is seconds since prep started."/>
          </Border>
          <!-- The label is "(N) Spell Name" while a spell is held, or empty
               when nothing is prepared. VitalsViewModel rebuilds it each tick
               so (N) counts up automatically — no XAML side computation.
               MinWidth=170 accommodates the longest DR spell names ("Refractive
               Field", "Whole Displacement") so the bar (in the next sub-group)
               doesn't crowd against the trailing letter. -->
          <TextBlock Text="{Binding Vitals.PreparedSpellLabel}"
                     AutomationProperties.Name="{Binding Vitals.PreparedSpellLabel, StringFormat='Prepared spell: {0}'}"
                     AutomationProperties.LiveSetting="Polite"
                     Foreground="#c8a8e0" FontSize="12" MinWidth="170"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Magenta prep-countdown bar — separate StackPanel sibling so the
             parent's Spacing=24 puts visible breathing room between the spell
             name and the bar. IsVisible collapses the whole strip when no
             prep is active, so the layout doesn't reserve dead space. -->
        <!-- Margin gives extra breathing room on both sides so the bar reads
             as its own widget — the track's dark plum (#2a1024) sits in the
             same value range as the status-badge backgrounds (#2a2a2a) and
             the strip background (#1c1c1c), so without explicit padding the
             bar visually blurs into KNEEL/HIDE/etc. on the right and into
             the spell name on the left. A faint BorderBrush draws the edge
             so even when the bar is mostly empty (low remaining seconds) the
             outline is clearly demarcated. -->
        <Border MinWidth="90" Width="100"
                Margin="6,0,6,0"
                VerticalAlignment="Center"
                BorderBrush="#7a3580" BorderThickness="1" CornerRadius="3"
                ToolTip.Tip="Seconds remaining until the prepared spell is fully harnessed.">
          <!-- Genie 4's SetMagicPanels hides the Castbar too — AND-ed with
               the only-while-prepping collapse. -->
          <Border.IsVisible>
            <MultiBinding Converter="{x:Static BoolConverters.And}">
              <Binding Path="Vitals.IsPrepping"/>
              <Binding Path="Display.ShowMagicPanels"/>
            </MultiBinding>
          </Border.IsVisible>
          <Grid>
            <ProgressBar Value="{Binding Vitals.CastBarSecondsRemaining}"
                         Maximum="{Binding Vitals.CastBarSecondsTotal}"
                         AutomationProperties.Name="Spell preparation"
                         Foreground="#D040C0" Background="#2a1024"
                         Height="14" CornerRadius="2"/>
            <TextBlock Text="{Binding Vitals.CastBarSecondsRemaining}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="10" Foreground="#fff" FontWeight="SemiBold"/>
          </Grid>
        </Border>

        <!-- ── Status indicators ──────────────────────────────────────
             Each badge is IsVisible-bound to the matching Vitals bool, so
             only active statuses render and the whole sub-group naturally
             collapses to zero width when standing-upright with no afflictions.
             Ordering goes posture → stealth → combat-condition → affliction
             → critical, so the most situational badges sit nearer the front
             and DEAD lands far right where the eye notices it last (but
             unmistakably). Colors hint at severity: dim grays for benign
             postures, warm yellows for "watch out", orange/red for combat
             conditions, red for blood, green for poison/disease, bright red
             for dead. -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <!-- Posture (mutually exclusive with each other and with Standing) -->
          <Border IsVisible="{Binding Vitals.IsKneeling}"
                  Background="#2a2a2a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are kneeling.">
            <TextBlock Text="KNEEL" Foreground="#d8c060" FontSize="10" FontWeight="SemiBold"/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsProne}"
                  Background="#2a2a2a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are prone.">
            <TextBlock Text="PRONE" Foreground="#d8a040" FontSize="10" FontWeight="SemiBold"/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsSitting}"
                  Background="#2a2a2a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are sitting.">
            <TextBlock Text="SIT" Foreground="#a0a0a0" FontSize="10" FontWeight="SemiBold"/>
          </Border>

          <!-- Stealth -->
          <Border IsVisible="{Binding Vitals.IsHidden}"
                  Background="#2a2a2a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are hidden.">
            <TextBlock Text="HIDE" Foreground="#8090a8" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are hidden."/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsInvisible}"
                  Background="#2a2a2a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are invisible.">
            <TextBlock Text="INVIS" Foreground="#6080a0" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are invisible."/>
          </Border>

          <!-- Combat conditions -->
          <Border IsVisible="{Binding Vitals.IsStunned}"
                  Background="#3a2a20" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are stunned — input ignored.">
            <TextBlock Text="STUN" Foreground="#ffa040" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are stunned — input ignored."/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsWebbed}"
                  Background="#3a3020" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are webbed.">
            <TextBlock Text="WEB" Foreground="#d0c060" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are webbed."/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsJoined}"
                  Background="#202a3a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are joined to someone.">
            <TextBlock Text="JOIN" Foreground="#80a0d0" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are joined to someone."/>
          </Border>

          <!-- Health afflictions -->
          <Border IsVisible="{Binding Vitals.IsBleeding}"
                  Background="#3a1a20" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are bleeding.">
            <TextBlock Text="BLEED" Foreground="#e04060" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are bleeding."/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsPoisoned}"
                  Background="#1f3a20" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are poisoned.">
            <TextBlock Text="POIS" Foreground="#60d060" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are poisoned."/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsDiseased}"
                  Background="#3a3a1a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are diseased.">
            <TextBlock Text="DIS" Foreground="#a0a040" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are diseased."/>
          </Border>

          <!-- Critical — bright + bold so it can't be missed at a glance -->
          <Border IsVisible="{Binding Vitals.IsDead}"
                  Background="#5a1010" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are dead.">
            <TextBlock Text="DEAD" Foreground="#ff6060" FontSize="10" FontWeight="Bold"/>
          </Border>
        </StackPanel>

      </StackPanel>
    </Border>

    <!-- ── Icon Bar (Genie 4 ComponentIconBar parity, #26) ──────────────── -->
    <!-- Character status chips: posture (dead > standing > kneeling >        -->
    <!-- sitting > prone, G4 priority) + condition flags, all fed by          -->
    <!-- IndicatorEvent via IconBarViewModel. Declared BEFORE the vitals      -->
    <!-- status bar so DockPanel stacks it BELOW it (very bottom edge).       -->
    <!-- Dims while disconnected (G4 grayed icons). Layout ▸ Icon Bar.        -->
    <Border DockPanel.Dock="Bottom"
            IsVisible="{Binding Display.ShowIconBar}"
            Background="{DynamicResource Theme.StripBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0"
            Padding="6,2"
            Classes.offline="{Binding !IsConnected}">
      <Border.Styles>
        <Style Selector="Border.offline"><Setter Property="Opacity" Value="0.4"/></Style>
        <Style Selector="Border.chip">
          <Setter Property="CornerRadius" Value="3"/>
          <Setter Property="Padding" Value="7,1"/>
          <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.chip TextBlock">
          <Setter Property="FontSize" Value="11"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
      </Border.Styles>
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Border Classes="chip" Background="#223042" BorderBrush="#3a5570"
                IsVisible="{Binding IconBar.PostureText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                ToolTip.Tip="Posture — what the server says your body is doing (dead beats everything, then standing / kneeling / sitting / prone).">
          <TextBlock Text="{Binding IconBar.PostureText}" Foreground="#9fc0dd"/>
        </Border>
        <Border Classes="chip" Background="#4a3818" BorderBrush="#C09040"
                IsVisible="{Binding IconBar.Stunned}"
                ToolTip.Tip="Stunned — you can't act until it wears off.">
          <TextBlock Text="STUNNED" Foreground="#ffd890"/>
        </Border>
        <Border Classes="chip" Background="#3a1010" BorderBrush="#8a2a2a"
                IsVisible="{Binding IconBar.Bleeding}"
                ToolTip.Tip="Bleeding — you have open wounds. HEALTH shows where.">
          <TextBlock Text="BLEEDING" Foreground="#ffb0b0"/>
        </Border>
        <Border Classes="chip" Background="#22301a" BorderBrush="#6a8a30"
                IsVisible="{Binding IconBar.Poisoned}"
                ToolTip.Tip="Poisoned — venom is in your system.">
          <TextBlock Text="POISONED" Foreground="#cfe08a"/>
        </Border>
        <Border Classes="chip" Background="#322a16" BorderBrush="#8a7430"
                IsVisible="{Binding IconBar.Diseased}"
                ToolTip.Tip="Diseased — infection is setting in.">
          <TextBlock Text="DISEASED" Foreground="#e0cf8a"/>
        </Border>
        <Border Classes="chip" Background="#1d2a33" BorderBrush="#3f5a6e"
                IsVisible="{Binding IconBar.Hidden}"
                ToolTip.Tip="Hidden — you are concealed from view.">
          <TextBlock Text="HIDDEN" Foreground="#9fc4da"/>
        </Border>
        <Border Classes="chip" Background="#2a1444" BorderBrush="#8040C0"
                IsVisible="{Binding IconBar.Invisible}"
                ToolTip.Tip="Invisible.">
          <TextBlock Text="INVISIBLE" Foreground="#d0b0ff"/>
        </Border>
        <Border Classes="chip" Background="#2e2e2e" BorderBrush="{DynamicResource Theme.TextMuted}"
                IsVisible="{Binding IconBar.Webbed}"
                ToolTip.Tip="Webbed / immobilized — you can't move until you break free.">
          <TextBlock Text="WEBBED" Foreground="#d8d8d8"/>
        </Border>
        <Border Classes="chip" Background="#143a14" BorderBrush="#40A040"
                IsVisible="{Binding IconBar.Joined}"
                ToolTip.Tip="Joined — you are following / grouped with another character.">
          <TextBlock Text="JOINED" Foreground="#a8e0a8"/>
        </Border>
      </StackPanel>
    </Border>

    <!-- ── #statusbar slot row (Genie 4 StatusStrip parity, #111) ────────── -->
    <!-- Ten positional cells fed by #statusbar / #status [N] {text} via      -->
    <!-- StatusSlotsViewModel — slot N stays in cell N so scripts that use    -->
    <!-- the slots as columns keep their columns (Genie 4 semantics). Text    -->
    <!-- persists until overwritten or cleared (bare #statusbar N); it is NOT -->
    <!-- dropped when scripts finish. Declared AFTER the Icon Bar and BEFORE  -->
    <!-- the vitals grid so DockPanel stacks it between them. Collapses when  -->
    <!-- every slot is empty; part of the Status Bar toggle.                  -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource Theme.StripBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0"
            ToolTip.Tip="Script status slots — written with #statusbar [N] text; a bare #statusbar N clears slot N, #statusbar clearall empties all ten.">
      <Border.IsVisible>
        <MultiBinding Converter="{x:Static BoolConverters.And}">
          <Binding Path="Display.ShowStatusBar"/>
          <Binding Path="StatusSlots.HasAny"/>
        </MultiBinding>
      </Border.IsVisible>
      <ItemsControl ItemsSource="{Binding StatusSlots.Slots}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="10" Rows="1"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:StatusSlot">
            <Border BorderBrush="#2f363d" BorderThickness="0,0,1,0" Padding="6,2"
                    ToolTip.Tip="{Binding Number, StringFormat='#statusbar slot {0}'}">
              <TextBlock Text="{Binding Text}" FontSize="11" Foreground="{DynamicResource Theme.TextPrimary}"
                         TextTrimming="CharacterEllipsis"/>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>

    <!-- ── Status bar (Wrayth-style, docks below the command bar) ───────── -->
    <!-- Declared BEFORE the command bar so DockPanel puts it at the very     -->
    <!-- bottom edge. Toggle via View → Toggle Status Bar.                    -->
    <!-- The mana column collapses when Magic Panels is off (View → Magic
         Panels) — Genie 4's SetMagicPanels drops the bar row from 5 columns
         to 4 so the remaining vitals stretch equally. The column-width flip
         lives in code-behind (ColumnDefinition isn't bindable from XAML);
         the IsVisible on the mana cell hides the content, the width change
         reclaims the space. -->
    <Grid x:Name="StatusBarGrid"
          DockPanel.Dock="Bottom"
          IsVisible="{Binding Display.ShowStatusBar}"
          ColumnDefinitions="*,*,*,*,*"
          Margin="4,2,4,4">

      <Grid Grid.Column="0" Margin="0,0,2,0">
        <ProgressBar Value="{Binding Vitals.Health}" Maximum="100"
                     AutomationProperties.Name="Health"
                     Foreground="#C04040" Background="#3a1010" Height="18"
                     CornerRadius="3"/>
        <TextBlock Text="{Binding Vitals.Health, StringFormat='health {0}%'}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="11" Foreground="#fff" FontWeight="SemiBold"/>
      </Grid>

      <Grid Grid.Column="1" Margin="2,0"
            IsVisible="{Binding Display.ShowMagicPanels}">
        <ProgressBar Value="{Binding Vitals.Mana}" Maximum="100"
                     AutomationProperties.Name="Mana"
                     Foreground="#4060C0" Background="#172040" Height="18"
                     CornerRadius="3"/>
        <TextBlock Text="{Binding Vitals.Mana, StringFormat='mana {0}%'}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="11" Foreground="#fff" FontWeight="SemiBold"/>
      </Grid>

      <Grid Grid.Column="2" Margin="2,0">
        <ProgressBar Value="{Binding Vitals.Stamina}" Maximum="100"
                     AutomationProperties.Name="Fatigue"
                     Foreground="#C09040" Background="#4a3818" Height="18"
                     CornerRadius="3"/>
        <TextBlock Text="{Binding Vitals.Stamina, StringFormat='fatigue {0}%'}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="11" Foreground="#fff" FontWeight="SemiBold"/>
      </Grid>

      <Grid Grid.Column="3" Margin="2,0">
        <ProgressBar Value="{Binding Vitals.Spirit}" Maximum="100"
                     AutomationProperties.Name="Spirit"
                     Foreground="#40A040" Background="#143a14" Height="18"
                     CornerRadius="3"/>
        <TextBlock Text="{Binding Vitals.Spirit, StringFormat='spirit {0}%'}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="11" Foreground="#fff" FontWeight="SemiBold"/>
      </Grid>

      <Grid Grid.Column="4" Margin="2,0,0,0">
        <ProgressBar Value="{Binding Vitals.Concentration}" Maximum="100"
                     AutomationProperties.Name="Concentration"
                     Foreground="#8040C0" Background="#2a1444" Height="18"
                     CornerRadius="3"/>
        <TextBlock Text="{Binding Vitals.Concentration, StringFormat='concentration {0}%'}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="11" Foreground="#fff" FontWeight="SemiBold"/>
      </Grid>
    </Grid>

    <!-- ── Zone / Room location line (#66, opt-in via View → Zone / Room ID) ── -->
    <!-- Declared AFTER the vitals strip so DockPanel stacks it just ABOVE it.   -->
    <Border DockPanel.Dock="Bottom"
            IsVisible="{Binding Display.ShowZoneRoomId}"
            Background="{DynamicResource Theme.StripBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0"
            Padding="6,2">
      <TextBlock Text="{Binding Mapper.LocationDisplay}"
                 FontFamily="Consolas,Courier New,monospace" FontSize="11"
                 Foreground="{DynamicResource Theme.SectionHeader}" VerticalAlignment="Center"
                 ToolTip.Tip="Current mapper zone and DR server room id (#66)"/>
    </Border>

    <!-- ── Update notice strip (non-intrusive; auto-shows only when the       -->
    <!-- startup check found or auto-applied something, auto-hides otherwise). -->
    <!-- Independent of the vitals Status Bar toggle so the notice survives    -->
    <!-- a hidden status bar. Click opens the Updates dialog; × dismisses.     -->
    <Border DockPanel.Dock="Bottom"
            IsVisible="{Binding UpdateNotice, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Background="{DynamicResource Theme.StripBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0"
            Padding="6,1">
      <DockPanel>
        <Button DockPanel.Dock="Right" Content="✕"
                AutomationProperties.Name="Dismiss update notice"
                AutomationProperties.HelpText="Dismiss this notice (it returns if the next check still finds updates)"
                Command="{Binding DismissUpdateNoticeCommand}"
                Background="Transparent" BorderThickness="0" Padding="4,0"
                FontSize="10" Foreground="{DynamicResource Theme.SectionHeader}"
                ToolTip.Tip="Dismiss this notice (it returns if the next check still finds updates)"/>
        <Button Content="{Binding UpdateNotice}"
                AutomationProperties.HelpText="Click to open the Updates dialog"
                Command="{Binding ShowUpdatesCommand}"
                Background="Transparent" BorderThickness="0" Padding="2,0"
                HorizontalAlignment="Left" FontSize="11" Foreground="{DynamicResource Theme.SectionHeader}"
                ToolTip.Tip="Click to open the Updates dialog"/>
      </DockPanel>
    </Border>

    <!-- ── Report-XML-gap notice strip (parser met an element it doesn't      -->
    <!-- consume). One-click, human-in-the-loop: drafts a REDACTED GitHub issue -->
    <!-- and opens the prefill URL in the browser — nothing is posted           -->
    <!-- automatically. Auto-shows only while a gap is pending; × dismisses.    -->
    <!-- Independent of the vitals Status Bar toggle, like the update strip.    -->
    <Border DockPanel.Dock="Bottom"
            IsVisible="{Binding XmlGapNotice, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Background="{DynamicResource Theme.StripBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0"
            Padding="6,1">
      <DockPanel>
        <Button DockPanel.Dock="Right" Content="✕"
                AutomationProperties.Name="Dismiss XML gap notice"
                AutomationProperties.HelpText="Dismiss (this element won't prompt again this session)"
                Command="{Binding DismissXmlGapNoticeCommand}"
                Background="Transparent" BorderThickness="0" Padding="4,0"
                FontSize="10" Foreground="{DynamicResource Theme.SectionHeader}"
                ToolTip.Tip="Dismiss (this element won't prompt again this session)"/>
        <Button Content="{Binding XmlGapNotice}"
                AutomationProperties.HelpText="Opens a pre-filled, pre-redacted GitHub issue in your browser — you review and submit it"
                Command="{Binding ReportXmlGapCommand}"
                Background="Transparent" BorderThickness="0" Padding="2,0"
                HorizontalAlignment="Left" FontSize="11" Foreground="{DynamicResource Theme.SectionHeader}"
                ToolTip.Tip="Opens a pre-filled, pre-redacted GitHub issue in your browser — you review and submit it"/>
      </DockPanel>
    </Border>

    <!-- ── Hands strip (bottom position — Genie 4 style) ────────────────── -->
    <!-- Declared AFTER the StatusBar and BEFORE the CommandBar so the         -->
    <!-- DockPanel stacks (bottom → top): StatusBar, HandsBottom, CommandBar.  -->
    <!-- IsVisible flips only this copy on; the top copy at the head of the    -->
    <!-- DockPanel handles the inverse position.                               -->
    <Border DockPanel.Dock="Bottom"
            IsVisible="{Binding Display.ShowHandsBottom}"
            Background="{DynamicResource Theme.StripBg}"
            BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0"
            Padding="10,5">
      <StackPanel Orientation="Horizontal" Spacing="24">

        <!-- ── Roundtime (optional position) ─────────────────────────
             Inline RT badge — visible only when the user chose "Hands Strip"
             for the roundtime position. ShowRtOnHandsStrip is computed on
             MainWindowViewModel as (Vitals.InRoundTime AND
             Display.RoundTimeOnHandsStrip). Red palette matches the command-
             bar version so the indicator means the same thing wherever it
             sits. -->
        <StackPanel Orientation="Horizontal" Spacing="6"
                    IsVisible="{Binding ShowRtOnHandsStrip}">
          <Border Background="#5a1a1a" BorderBrush="#8a2a2a" BorderThickness="1"
                  CornerRadius="2" Padding="6,1">
            <TextBlock Text="R" Foreground="#ffd0d0" FontWeight="SemiBold" FontSize="11"
                       ToolTip.Tip="Roundtime — your character can't act until this expires"/>
          </Border>
          <TextBlock Text="{Binding Vitals.RoundTimeSeconds, StringFormat='{}{0:F1}s'}"
                     AutomationProperties.Name="{Binding Vitals.RoundTimeSeconds, StringFormat='Roundtime: {0:F1} seconds'}"
                     Foreground="#ffd0d0" FontSize="12" MinWidth="40"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── Enhanced (dylb0t-derived) icon widgets ─────────────────
             Collapsed by default; toggled on via Window → Enhanced Hands
             Strip. Compass = pixel-art rose with one overlay per active
             exit; Body = posture sprite (standing/sitting/kneeling/prone/
             dead); StatusIcons = 6-slot row covering stunned, bleeding,
             invisible, hidden, joined, webbed. All three subscribe to
             VitalsViewModel directly; no extra bindings to maintain.
             Art credit: @dylb0t — see CREDITS.md. -->
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                    IsVisible="{Binding Display.UseEnhancedHandsStrip}">
          <controls:CompassView   Vitals="{Binding Vitals}" VerticalAlignment="Center"
                                  AutomationProperties.Name="Compass"
                                  ToolTip.Tip="Compass — pixel-art rose with one overlay per active exit (data from the server's &lt;compass&gt; payload)."/>
          <controls:BodyView      Vitals="{Binding Vitals}" VerticalAlignment="Center"
                                  AutomationProperties.Name="Posture"
                                  ToolTip.Tip="Posture sprite — standing / sitting / kneeling / prone / dead."/>
          <controls:StatusIconBar Vitals="{Binding Vitals}" VerticalAlignment="Center"
                                  AutomationProperties.Name="Status effects"
                                  ToolTip.Tip="Active afflictions: stunned, bleeding, invisible, hidden, joined, webbed. Empty slots stay blank."/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="6">
          <Border Background="#2a2a2a" CornerRadius="2" Padding="6,1">
            <TextBlock Text="L" Foreground="{DynamicResource Theme.TextSecondary}" FontWeight="SemiBold" FontSize="11"/>
          </Border>
          <TextBlock Text="{Binding Vitals.LeftHand, FallbackValue=Empty}"
                     AutomationProperties.Name="{Binding Vitals.LeftHand, StringFormat='Left hand: {0}'}"
                     AutomationProperties.LiveSetting="Polite"
                     Foreground="{DynamicResource Theme.TextPrimary}" FontSize="12" MinWidth="140"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="6">
          <Border Background="#2a2a2a" CornerRadius="2" Padding="6,1">
            <TextBlock Text="R" Foreground="{DynamicResource Theme.TextSecondary}" FontWeight="SemiBold" FontSize="11"/>
          </Border>
          <TextBlock Text="{Binding Vitals.RightHand, FallbackValue=Empty}"
                     AutomationProperties.Name="{Binding Vitals.RightHand, StringFormat='Right hand: {0}'}"
                     AutomationProperties.LiveSetting="Polite"
                     Foreground="{DynamicResource Theme.TextPrimary}" FontSize="12" MinWidth="140"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── Stance ────────────────────────────────────────────────
             Six mutually-exclusive badges (one per DR stance) wired to
             mutually-exclusive bools on VitalsViewModel. Color follows the
             red→green gradient that matches the stance gauge in Genie 4:
             red for all-out attack, green for full defense. Whole sub-group
             collapses to zero width pre-connect (no badge true) but as soon
             as the server pushes the first <component id="pc stance"> the
             matching one lights up. -->
        <Border IsVisible="{Binding Vitals.IsStanceOffensive}"
                Background="#3a1818" CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                ToolTip.Tip="Stance: Offensive — maximum damage out, minimum defense.">
          <TextBlock Text="OFF" Foreground="#ff5050" FontSize="10" FontWeight="SemiBold"
                     AutomationProperties.HelpText="Stance: Offensive — maximum damage out, minimum defense."/>
        </Border>
        <Border IsVisible="{Binding Vitals.IsStanceAdvance}"
                Background="#3a2418" CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                ToolTip.Tip="Stance: Advance — favors attack over defense.">
          <TextBlock Text="ADV" Foreground="#ff8040" FontSize="10" FontWeight="SemiBold"
                     AutomationProperties.HelpText="Stance: Advance — favors attack over defense."/>
        </Border>
        <Border IsVisible="{Binding Vitals.IsStanceForward}"
                Background="#3a3018" CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                ToolTip.Tip="Stance: Forward — slight tilt toward attack.">
          <TextBlock Text="FWD" Foreground="#ffb040" FontSize="10" FontWeight="SemiBold"
                     AutomationProperties.HelpText="Stance: Forward — slight tilt toward attack."/>
        </Border>
        <Border IsVisible="{Binding Vitals.IsStanceNeutral}"
                Background="#2a2a2a" CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                ToolTip.Tip="Stance: Neutral — balanced offense and defense.">
          <TextBlock Text="NEU" Foreground="#d8c060" FontSize="10" FontWeight="SemiBold"
                     AutomationProperties.HelpText="Stance: Neutral — balanced offense and defense."/>
        </Border>
        <Border IsVisible="{Binding Vitals.IsStanceGuarded}"
                Background="#1c3018" CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                ToolTip.Tip="Stance: Guarded — slight tilt toward defense.">
          <TextBlock Text="GRD" Foreground="#80c060" FontSize="10" FontWeight="SemiBold"
                     AutomationProperties.HelpText="Stance: Guarded — slight tilt toward defense."/>
        </Border>
        <Border IsVisible="{Binding Vitals.IsStanceDefensive}"
                Background="#143a14" CornerRadius="2" Padding="5,1" VerticalAlignment="Center"
                ToolTip.Tip="Stance: Defensive — maximum defense, minimum damage out.">
          <TextBlock Text="DEF" Foreground="#40d060" FontSize="10" FontWeight="SemiBold"
                     AutomationProperties.HelpText="Stance: Defensive — maximum defense, minimum damage out."/>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="6">
          <!-- Hidden entirely when Magic Panels is off (Genie 4 SetMagicPanels
               hides LabelSpell/LabelSpellC too), AND-ed with the existing
               #config spelltimer gate. -->
          <StackPanel.IsVisible>
            <MultiBinding Converter="{x:Static BoolConverters.And}">
              <Binding Path="Vitals.IsSpellTimerVisible"/>
              <Binding Path="Display.ShowMagicPanels"/>
            </MultiBinding>
          </StackPanel.IsVisible>
          <Border Background="#2a2a2a" CornerRadius="2" Padding="6,1">
            <TextBlock Text="S" Foreground="{DynamicResource Theme.TextSecondary}" FontWeight="SemiBold" FontSize="11"
                       ToolTip.Tip="Prepared spell. (N) is seconds since prep started."/>
          </Border>
          <!-- The label is "(N) Spell Name" while a spell is held, or empty
               when nothing is prepared. VitalsViewModel rebuilds it each tick
               so (N) counts up automatically — no XAML side computation.
               MinWidth=170 accommodates the longest DR spell names ("Refractive
               Field", "Whole Displacement") so the bar (in the next sub-group)
               doesn't crowd against the trailing letter. -->
          <TextBlock Text="{Binding Vitals.PreparedSpellLabel}"
                     AutomationProperties.Name="{Binding Vitals.PreparedSpellLabel, StringFormat='Prepared spell: {0}'}"
                     AutomationProperties.LiveSetting="Polite"
                     Foreground="#c8a8e0" FontSize="12" MinWidth="170"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Magenta prep-countdown bar — separate StackPanel sibling so the
             parent's Spacing=24 puts visible breathing room between the spell
             name and the bar. IsVisible collapses the whole strip when no
             prep is active, so the layout doesn't reserve dead space. -->
        <!-- Margin gives extra breathing room on both sides so the bar reads
             as its own widget — the track's dark plum (#2a1024) sits in the
             same value range as the status-badge backgrounds (#2a2a2a) and
             the strip background (#1c1c1c), so without explicit padding the
             bar visually blurs into KNEEL/HIDE/etc. on the right and into
             the spell name on the left. A faint BorderBrush draws the edge
             so even when the bar is mostly empty (low remaining seconds) the
             outline is clearly demarcated. -->
        <Border MinWidth="90" Width="100"
                Margin="6,0,6,0"
                VerticalAlignment="Center"
                BorderBrush="#7a3580" BorderThickness="1" CornerRadius="3"
                ToolTip.Tip="Seconds remaining until the prepared spell is fully harnessed.">
          <!-- Genie 4's SetMagicPanels hides the Castbar too — AND-ed with
               the only-while-prepping collapse. -->
          <Border.IsVisible>
            <MultiBinding Converter="{x:Static BoolConverters.And}">
              <Binding Path="Vitals.IsPrepping"/>
              <Binding Path="Display.ShowMagicPanels"/>
            </MultiBinding>
          </Border.IsVisible>
          <Grid>
            <ProgressBar Value="{Binding Vitals.CastBarSecondsRemaining}"
                         Maximum="{Binding Vitals.CastBarSecondsTotal}"
                         AutomationProperties.Name="Spell preparation"
                         Foreground="#D040C0" Background="#2a1024"
                         Height="14" CornerRadius="2"/>
            <TextBlock Text="{Binding Vitals.CastBarSecondsRemaining}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="10" Foreground="#fff" FontWeight="SemiBold"/>
          </Grid>
        </Border>

        <!-- ── Status indicators ──────────────────────────────────────
             Each badge is IsVisible-bound to the matching Vitals bool, so
             only active statuses render and the whole sub-group naturally
             collapses to zero width when standing-upright with no afflictions.
             Ordering goes posture → stealth → combat-condition → affliction
             → critical, so the most situational badges sit nearer the front
             and DEAD lands far right where the eye notices it last (but
             unmistakably). Colors hint at severity: dim grays for benign
             postures, warm yellows for "watch out", orange/red for combat
             conditions, red for blood, green for poison/disease, bright red
             for dead. -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <!-- Posture (mutually exclusive with each other and with Standing) -->
          <Border IsVisible="{Binding Vitals.IsKneeling}"
                  Background="#2a2a2a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are kneeling.">
            <TextBlock Text="KNEEL" Foreground="#d8c060" FontSize="10" FontWeight="SemiBold"/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsProne}"
                  Background="#2a2a2a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are prone.">
            <TextBlock Text="PRONE" Foreground="#d8a040" FontSize="10" FontWeight="SemiBold"/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsSitting}"
                  Background="#2a2a2a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are sitting.">
            <TextBlock Text="SIT" Foreground="#a0a0a0" FontSize="10" FontWeight="SemiBold"/>
          </Border>

          <!-- Stealth -->
          <Border IsVisible="{Binding Vitals.IsHidden}"
                  Background="#2a2a2a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are hidden.">
            <TextBlock Text="HIDE" Foreground="#8090a8" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are hidden."/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsInvisible}"
                  Background="#2a2a2a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are invisible.">
            <TextBlock Text="INVIS" Foreground="#6080a0" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are invisible."/>
          </Border>

          <!-- Combat conditions -->
          <Border IsVisible="{Binding Vitals.IsStunned}"
                  Background="#3a2a20" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are stunned — input ignored.">
            <TextBlock Text="STUN" Foreground="#ffa040" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are stunned — input ignored."/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsWebbed}"
                  Background="#3a3020" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are webbed.">
            <TextBlock Text="WEB" Foreground="#d0c060" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are webbed."/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsJoined}"
                  Background="#202a3a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are joined to someone.">
            <TextBlock Text="JOIN" Foreground="#80a0d0" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are joined to someone."/>
          </Border>

          <!-- Health afflictions -->
          <Border IsVisible="{Binding Vitals.IsBleeding}"
                  Background="#3a1a20" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are bleeding.">
            <TextBlock Text="BLEED" Foreground="#e04060" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are bleeding."/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsPoisoned}"
                  Background="#1f3a20" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are poisoned.">
            <TextBlock Text="POIS" Foreground="#60d060" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are poisoned."/>
          </Border>
          <Border IsVisible="{Binding Vitals.IsDiseased}"
                  Background="#3a3a1a" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are diseased.">
            <TextBlock Text="DIS" Foreground="#a0a040" FontSize="10" FontWeight="SemiBold"
                       AutomationProperties.HelpText="You are diseased."/>
          </Border>

          <!-- Critical — bright + bold so it can't be missed at a glance -->
          <Border IsVisible="{Binding Vitals.IsDead}"
                  Background="#5a1010" CornerRadius="2" Padding="5,1"
                  ToolTip.Tip="You are dead.">
            <TextBlock Text="DEAD" Foreground="#ff6060" FontSize="10" FontWeight="Bold"/>
          </Border>
        </StackPanel>

      </StackPanel>
    </Border>

    <!-- ── Script Bar (auto-hides when no scripts running) ───────────────── -->
    <!-- Genie 4 muscle memory — shows what scripts are running with a tiny
         × per item so the user can stop them in-place. Hidden when empty
         so the strip costs zero vertical space during ordinary play.
         Declared AFTER the hands strip and BEFORE the command bar, so it
         stacks between them (DockPanel hands the bottom edge to bottom-docked
         items in declaration order, working upward). The #statusbar text that
         used to dock right lives under the vitals Status Bar now (#111). -->
    <Border DockPanel.Dock="Bottom"
            IsVisible="{Binding ScriptBar.HasScripts}"
            Background="{DynamicResource Theme.ToolbarBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0"
            Padding="6,3">
      <DockPanel LastChildFill="False">
        <TextBlock DockPanel.Dock="Left" Text="Scripts:" Foreground="{DynamicResource Theme.SectionHeader}" FontSize="11"
                   FontWeight="SemiBold" VerticalAlignment="Center"
                   Margin="0,0,2,0"/>
        <ItemsControl DockPanel.Dock="Left" ItemsSource="{Binding ScriptBar.RunningScripts}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="4"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ScriptBarItem">
              <Border Background="#283139" BorderBrush="#3e4a55"
                      BorderThickness="1" CornerRadius="3" Padding="6,1">
                <!-- Right-click menu — Genie 4's Script Bar dropdown (Resume/
                     Pause, Abort, Debug levels, Trace, Vars, Edit) plus the
                     Genie 5 reload. Commands are per-chip (see
                     ScriptBarViewModel.MakeItem) because this popup detaches
                     from the visual tree. -->
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Pause / resume" Command="{Binding MenuPauseResumeCommand}"/>
                    <MenuItem Header="Abort" Command="{Binding AbortCommand}"/>
                    <Separator/>
                    <MenuItem Header="Debug level" IsVisible="{Binding !IsJavaScript}">
                      <MenuItem Header="0 — off"          Command="{Binding SetDebugCommand}" CommandParameter="0"/>
                      <MenuItem Header="1 — goto/gosub"   Command="{Binding SetDebugCommand}" CommandParameter="1"/>
                      <MenuItem Header="2 — + pause/wait" Command="{Binding SetDebugCommand}" CommandParameter="2"/>
                      <MenuItem Header="3 — + if"         Command="{Binding SetDebugCommand}" CommandParameter="3"/>
                      <MenuItem Header="4 — + var/math"   Command="{Binding SetDebugCommand}" CommandParameter="4"/>
                      <MenuItem Header="5 — + actions"    Command="{Binding SetDebugCommand}" CommandParameter="5"/>
                      <MenuItem Header="10 — every line"  Command="{Binding SetDebugCommand}" CommandParameter="10"/>
                    </MenuItem>
                    <MenuItem Header="Show vars"  IsVisible="{Binding !IsJavaScript}" Command="{Binding VarsCommand}"/>
                    <MenuItem Header="Show trace" IsVisible="{Binding !IsJavaScript}" Command="{Binding TraceCommand}"/>
                    <MenuItem Header="Reload at next label" IsVisible="{Binding !IsJavaScript}" Command="{Binding ReloadCommand}"/>
                    <Separator/>
                    <MenuItem Header="Edit" Command="{Binding EditCommand}"/>
                  </ContextMenu>
                </Border.ContextMenu>
                <StackPanel Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Center">
                  <TextBlock Text="{Binding Name}" FontSize="11"
                             Foreground="{DynamicResource Theme.TextPrimary}" VerticalAlignment="Center"/>
                  <!-- Language tag — only shown for .js scripts. -->
                  <Border Background="#2d3b46" CornerRadius="2" Padding="3,0"
                          VerticalAlignment="Center"
                          IsVisible="{Binding IsJavaScript}">
                    <TextBlock Text="js" FontSize="9" Foreground="#e8c97a"
                               VerticalAlignment="Center"/>
                  </Border>
                  <!-- Pause / resume this script (#94). Glyph flips ⏸/▶. -->
                  <Button Content="{Binding PauseGlyph}"
                          FontSize="10" Padding="3,0" MinWidth="0" MinHeight="0"
                          Background="Transparent" BorderThickness="0"
                          Foreground="#9ec59a"
                          AutomationProperties.Name="Pause or resume script"
                          AutomationProperties.HelpText="Pause / resume this script"
                          ToolTip.Tip="Pause / resume this script"
                          Command="{ReflectionBinding $parent[ItemsControl].DataContext.ScriptBar.PauseResumeCommand}"
                          CommandParameter="{Binding}"/>
                  <!-- Per-script debug level (#94): cycles 0→1→5→10. .cmd only. -->
                  <Button Content="{Binding DebugLabel}"
                          FontSize="9" Padding="3,0" MinWidth="0" MinHeight="0"
                          Background="Transparent" BorderThickness="0"
                          Foreground="#c0a060"
                          IsVisible="{Binding !IsJavaScript}"
                          AutomationProperties.Name="Cycle debug level"
                          AutomationProperties.HelpText="Cycle this script's debug/trace level (0→1→5→10)"
                          ToolTip.Tip="Cycle this script's debug/trace level (0→1→5→10)"
                          Command="{ReflectionBinding $parent[ItemsControl].DataContext.ScriptBar.CycleDebugCommand}"
                          CommandParameter="{Binding}"/>
                  <Button Content="✏"
                          FontSize="10" Padding="3,0" MinWidth="0" MinHeight="0"
                          Background="Transparent" BorderThickness="0"
                          Foreground="#80a8c0"
                          AutomationProperties.Name="Edit script"
                          AutomationProperties.HelpText="Edit this script in the configured editor"
                          ToolTip.Tip="Edit this script in the configured editor"
                          Command="{ReflectionBinding $parent[ItemsControl].DataContext.ScriptBar.EditScriptCommand}"
                          CommandParameter="{Binding Name}"/>
                  <Button Content="✕"
                          FontSize="10" Padding="3,0" MinWidth="0" MinHeight="0"
                          Background="Transparent" BorderThickness="0"
                          Foreground="#d08080"
                          AutomationProperties.Name="Stop script"
                          AutomationProperties.HelpText="Stop this script (#stop)"
                          ToolTip.Tip="Stop this script (#stop)"
                          Command="{ReflectionBinding $parent[ItemsControl].DataContext.ScriptBar.StopScriptCommand}"
                          CommandParameter="{Binding Name}"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </DockPanel>
    </Border>

    <!-- ── Command bar (above status bar) ────────────────────────────────── -->
    <!-- Four columns: RT badge | type-ahead counter | input box | Send. The RT
         badge is only visible while a roundtime is active; it ticks down live
         courtesy of the VitalsViewModel timer. The type-ahead counter sits
         between RT and the input and is always visible (dim when idle). -->
    <Grid x:Name="CommandBarGrid" DockPanel.Dock="Bottom" ColumnDefinitions="Auto,Auto,*,Auto" Margin="4,2">

      <Border Grid.Column="0"
              IsVisible="{Binding ShowRtInCommandBar}"
              Background="#5a1a1a" BorderBrush="#8a2a2a" BorderThickness="1"
              CornerRadius="3" Padding="6,2" Margin="0,0,4,0"
              VerticalAlignment="Stretch"
              ToolTip.Tip="Roundtime — your character can't act until this expires. Right-click Window → Roundtime Position to relocate."
              MinWidth="64">
        <TextBlock Foreground="#ffd0d0" FontWeight="SemiBold"
                   AutomationProperties.Name="{Binding Vitals.RoundTimeSeconds, StringFormat='Roundtime: {0:F1} seconds'}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="12">
          <Run Text="⏱ "/><Run Text="{Binding Vitals.RoundTimeSeconds, StringFormat={}{0:F1}s}"/>
        </TextBlock>
      </Border>

      <!-- ── Type-ahead counter ──────────────────────────────────────────
           Pips show the type-ahead buffer: filled = commands queued ahead of
           the game, hollow = free slots, up to the per-account cap (1 free /
           2 premium / 3 +LTB, auto-calibrated from the server). Dim when idle,
           amber at the cap. -->
      <Border Grid.Column="1"
              Background="#2a2a2a" BorderBrush="#444" BorderThickness="1"
              CornerRadius="3" Padding="6,2" Margin="0,0,4,0"
              VerticalAlignment="Stretch"
              ToolTip.Tip="Type-ahead buffer — commands queued ahead of the game (filled = used, hollow = free). DR caps this per account: free 1, premium 2, +1 with the LTB line. Amber means the buffer is full.">
        <TextBlock FontWeight="SemiBold"
                   AutomationProperties.Name="Type-ahead buffer"
                   AutomationProperties.HelpText="Type-ahead buffer — commands queued ahead of the game (filled = used, hollow = free). DR caps this per account: free 1, premium 2, +1 with the LTB line. Amber means the buffer is full."
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontFamily="Consolas,Courier New,monospace" FontSize="12">
          <TextBlock.Text>
            <MultiBinding Converter="{x:Static controls:TypeAheadPipsConverter.Instance}">
              <Binding Path="Vitals.TypeAheadInFlight"/>
              <Binding Path="Vitals.TypeAheadLimit"/>
            </MultiBinding>
          </TextBlock.Text>
          <TextBlock.Foreground>
            <MultiBinding Converter="{x:Static controls:TypeAheadBrushConverter.Instance}">
              <Binding Path="Vitals.TypeAheadInFlight"/>
              <Binding Path="Vitals.TypeAheadLimit"/>
            </MultiBinding>
          </TextBlock.Foreground>
        </TextBlock>
      </Border>

      <TextBox Grid.Column="2"
               x:Name="CommandInput"
               AutomationProperties.Name="Command input"
               AutomationProperties.AutomationId="CommandInput"
               AutomationProperties.HelpText="Type game commands here and press Enter to send them to the game."
               Text="{Binding Command.CommandText}"
               Watermark="Enter command..."
               FontFamily="Consolas,Courier New,monospace"
               KeyDown="CommandInput_KeyDown">
        <TextBox.KeyBindings>
          <KeyBinding Gesture="Return" Command="{Binding Command.SubmitCommand}"/>
        </TextBox.KeyBindings>
      </TextBox>
      <Button Grid.Column="3" Content="Send" Margin="4,0,0,0"
              AutomationProperties.AutomationId="SendButton"
              Command="{Binding Command.SubmitCommand}"/>
    </Grid>

    <!-- ── Dock control (fills remaining space) ──────────────────────────── -->
    <!-- InitializeLayout="False": the VM/factory init the layout explicitly
         (BuildDefaultLayout / BuildLayout call InitLayout) so runtime layout
         swaps are deterministic and don't double-initialise. -->
    <!-- Grid layers the live performance overlay above the dock content without
         disturbing the docking layout. The overlay is top-right, click-through
         to the dock is fine (it only shows numbers). -->
    <Grid>
      <dockc:DockControl x:Name="MainDock"
                         Layout="{Binding DockLayout}"
                         Factory="{Binding DockFactory}"
                         InitializeLayout="False"/>

      <!-- ── Live performance overlay ──────────────────────────────────────── -->
      <Border IsVisible="{Binding Perf.OverlayVisible}"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Margin="0,8,12,0" Padding="9,7"
              Background="#E6101418" BorderBrush="#FF3A4250" BorderThickness="1"
              CornerRadius="6" BoxShadow="0 2 10 0 #80000000">
        <StackPanel MinWidth="210">
          <TextBlock Text="PERFORMANCE  (ms / line)"
                     FontWeight="Bold" FontSize="11" Foreground="#FFE6E6E6" Margin="0,0,0,5"/>
          <Grid ColumnDefinitions="84,52,52,Auto" Margin="0,0,0,2">
            <TextBlock Grid.Column="1" Text="avg"  FontSize="10" TextAlignment="Right" Foreground="#FF8A93A0"/>
            <TextBlock Grid.Column="2" Text="peak" FontSize="10" TextAlignment="Right" Foreground="#FF8A93A0"/>
          </Grid>
          <ItemsControl ItemsSource="{Binding Perf.Rows}">
            <ItemsControl.Styles>
              <!-- Peak cell turns red when the stage is "hot" (peak ≥ a 16 ms
                   frame budget, or a regex timed out). -->
              <Style Selector="Grid.hot TextBlock#PeakCell">
                <Setter Property="Foreground" Value="#FFE05050"/>
              </Style>
            </ItemsControl.Styles>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:PerfRowViewModel">
                <Grid IsVisible="{Binding Visible}" Classes.hot="{Binding Hot}"
                      ColumnDefinitions="84,52,52,Auto" Margin="0,1">
                  <TextBlock Grid.Column="0" Text="{Binding Name}"
                             FontFamily="Consolas,Menlo,monospace" FontSize="11" Foreground="#FFB8C0CC"/>
                  <TextBlock Grid.Column="1" Text="{Binding Avg}"
                             FontFamily="Consolas,Menlo,monospace" FontSize="11" TextAlignment="Right" Foreground="#FFB8C0CC"/>
                  <TextBlock Grid.Column="2" x:Name="PeakCell" Text="{Binding Peak}"
                             FontFamily="Consolas,Menlo,monospace" FontSize="11" TextAlignment="Right" Foreground="#FFB8C0CC"/>
                  <TextBlock Grid.Column="3" Text="{Binding Timeouts, StringFormat='  ⏱ {0}'}"
                             IsVisible="{Binding HasTimeouts}"
                             FontSize="11" Foreground="#FFE05050" ToolTip.Tip="Regex match-timeouts caught and skipped for this component"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Running .js scripts (off-thread; name + wall-clock elapsed) -->
          <StackPanel IsVisible="{Binding Perf.HasJsScripts}" Margin="0,6,0,0">
            <Border Height="1" Background="#FF2A313C" Margin="0,0,0,5"/>
            <TextBlock Text="RUNNING .js" FontWeight="Bold" FontSize="10"
                       Foreground="#FF8A93A0" Margin="0,0,0,3"/>
            <ItemsControl ItemsSource="{Binding Perf.JsScripts}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:JsScriptRowViewModel">
                  <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                               FontFamily="Consolas,Menlo,monospace" FontSize="11" Foreground="#FFB8C0CC"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="paused" IsVisible="{Binding Paused}"
                                 FontSize="10" Foreground="#FFE0B050"/>
                      <TextBlock Text="{Binding Elapsed}" FontFamily="Consolas,Menlo,monospace"
                                 FontSize="11" TextAlignment="Right" Foreground="#FF8AC0A0"/>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

  </DockPanel>
</Window>
