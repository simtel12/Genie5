<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Genie.App.Views.VariablesPanel">

  <Grid RowDefinitions="Auto,*">

    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="4,4,4,0">
      <Button Content="Add New" Click="OnAdd"/>
      <Button Content="Delete"  Click="OnDelete"/>
      <Button Content="Import…" Click="OnImport"/>
    </StackPanel>

    <Grid Grid.Row="1" RowDefinitions="*,Auto" Margin="4">
      <DataGrid Name="ItemsList"
                Grid.Row="0"
                Margin="0,0,0,4"
                IsReadOnly="True"
                SelectionMode="Extended"
                CanUserSortColumns="True"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                x:CompileBindings="False"
                SelectionChanged="OnSelectionChanged">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Copy"       Click="OnCopy"/>
            <MenuItem Header="Select All" Click="OnSelectAll"/>
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTextColumn Header="Name"  Binding="{Binding Name}"  Width="Auto"/>
          <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
        </DataGrid.Columns>
      </DataGrid>

      <Grid Grid.Row="1"
            ColumnDefinitions="Auto,*"
            RowDefinitions="Auto,Auto,Auto,Auto"
            Margin="0,4,0,0">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:"  VerticalAlignment="Center" Margin="0,0,8,4"/>
        <TextBox   Grid.Row="0" Grid.Column="1" Name="NameBox"  Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Value:" VerticalAlignment="Center" Margin="0,0,8,4"/>
        <TextBox   Grid.Row="1" Grid.Column="1" Name="ValueBox" Margin="0,0,0,4"/>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="0,2,0,4">
          <Button Content="Save"  Click="OnSave"/>
          <Button Content="Clear" Click="OnClear"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Grid.Column="1" Name="StatusText" Margin="0,6,0,0"
                   Foreground="Gray" FontStyle="Italic"/>
      </Grid>
    </Grid>

  </Grid>
</UserControl>
