<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Genie.App.ViewModels"
        xmlns:profiles="using:Genie.Core.Profiles"
        x:Class="Genie.App.Views.ConnectDialog"
        x:DataType="vm:ConnectDialogViewModel"
        Title="Connect to DragonRealms"
        Width="460" Height="540"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">

    <!-- ── Profile picker row ──────────────────────────────────────────── -->
    <Grid Grid.Row="0" ColumnDefinitions="90,*,Auto,Auto" Margin="0,0,0,4">
      <TextBlock Grid.Column="0" Text="Profile" VerticalAlignment="Center"/>
      <ComboBox  Grid.Column="1"
                 AutomationProperties.Name="Profile"
                 ItemsSource="{Binding Profiles}"
                 SelectedItem="{Binding SelectedProfile}"
                 PlaceholderText="(none)"
                 HorizontalAlignment="Stretch">
        <ComboBox.ItemTemplate>
          <DataTemplate DataType="profiles:ConnectionProfile">
            <!-- PickerLabel = "Name — Character-Account" so two same-named
                 characters on different accounts are distinguishable (#4). -->
            <TextBlock Text="{Binding PickerLabel}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Button Grid.Column="2" Content="Save"   Margin="4,0,0,0"
              Command="{Binding SaveProfileCommand}"
              ToolTip.Tip="Save the current fields under the given Name"/>
      <Button Grid.Column="3" Content="Delete" Margin="4,0,0,0"
              Command="{Binding DeleteProfileCommand}"
              ToolTip.Tip="Delete the selected profile"/>
    </Grid>

    <Separator Grid.Row="1" Margin="0,4,0,8"/>

    <!-- ── Editable fields ─────────────────────────────────────────────── -->
    <StackPanel Grid.Row="2" Spacing="8">

      <!-- Shared: profile name + connection method + data folder (always visible) -->
      <Grid ColumnDefinitions="90,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"   VerticalAlignment="Center"/>
        <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                   AutomationProperties.Name="Profile name"
                   Text="{Binding ProfileName}"
                   Watermark="Profile name (e.g. MyCharacter)"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Mode"   VerticalAlignment="Center" Margin="0,8,0,0"/>
        <ComboBox  Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0"
                   AutomationProperties.Name="Connection mode"
                   AutomationProperties.HelpText="Direct logs in via SGE. Lich proxy attaches to a locally-running Lich 5 that has already authenticated."
                   ItemsSource="{x:Static vm:ConnectDialogViewModel.ConnectionModes}"
                   SelectedItem="{Binding SelectedMode}"
                   HorizontalAlignment="Stretch"
                   ToolTip.Tip="Direct logs in via SGE. Lich proxy attaches to a locally-running Lich 5 that has already authenticated."/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Data folder" VerticalAlignment="Center" Margin="0,8,0,0"/>
        <TextBox   Grid.Row="2" Grid.Column="1" Margin="0,8,0,0"
                   AutomationProperties.Name="Data folder"
                   AutomationProperties.HelpText="Where this profile's data (Config, Scripts, Maps, Plugins, Logs) lives. Leave blank to use the default location, or pick a folder (e.g. on a synced drive or USB stick) to keep this character's data there."
                   Text="{Binding DataDirectory}"
                   Watermark="Optional — defaults to the standard location"
                   ToolTip.Tip="Where this profile's data (Config, Scripts, Maps, Plugins, Logs) lives. Leave blank to use the default location, or pick a folder (e.g. on a synced drive or USB stick) to keep this character's data there."/>
        <Button    Grid.Row="2" Grid.Column="2" Content="Browse…" Margin="4,8,0,0"
                   Command="{Binding BrowseDataDirCommand}"/>

        <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                   Text="Leave blank for the default location. Set it to keep this character's data in a folder you choose."
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource Theme.TextMuted}" FontSize="11" Margin="0,2,0,0"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Layout" VerticalAlignment="Center" Margin="0,8,0,0"/>
        <ComboBox  Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0"
                   AutomationProperties.Name="Startup layout"
                   AutomationProperties.HelpText="Saved layout applied automatically when this character connects. Save layouts from the Layout menu."
                   ItemsSource="{Binding AvailableLayouts}"
                   SelectedItem="{Binding SelectedLayout}"
                   HorizontalAlignment="Stretch"
                   ToolTip.Tip="Saved layout applied automatically when this character connects. Save layouts from the Layout menu."/>
      </Grid>

      <!-- Direct (SGE) fields -->
      <Grid ColumnDefinitions="90,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
            IsVisible="{Binding IsDirectMode}">

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Instance"  VerticalAlignment="Center"/>
        <ComboBox  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                   AutomationProperties.Name="Instance"
                   ItemsSource="{x:Static vm:ConnectDialogViewModel.Instances}"
                   SelectedItem="{Binding Instance}"
                   HorizontalAlignment="Stretch"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Account"   VerticalAlignment="Center" Margin="0,8,0,0"/>
        <TextBox   Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0"
                   AutomationProperties.Name="Account"
                   Text="{Binding Account}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Password"  VerticalAlignment="Center" Margin="0,8,0,0"/>
        <TextBox   Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0"
                   AutomationProperties.Name="Password"
                   Text="{Binding Password}"
                   PasswordChar="●"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Character" VerticalAlignment="Center" Margin="0,8,0,0"/>
        <ComboBox  Grid.Row="3" Grid.Column="1" Margin="0,8,0,0"
                   x:Name="CharacterCombo"
                   AutomationProperties.Name="Character"
                   ItemsSource="{Binding AvailableCharacters}"
                   SelectedItem="{Binding Character}"
                   PlaceholderText="(click Fetch)"
                   HorizontalAlignment="Stretch"/>
        <Button    Grid.Row="3" Grid.Column="2" Margin="4,8,0,0" MinWidth="70"
                   Content="{Binding FetchButtonLabel}"
                   AutomationProperties.Name="Fetch characters"
                   AutomationProperties.HelpText="Ask SGE for the character list on this account"
                   Command="{Binding FetchCharactersCommand}"
                   ToolTip.Tip="Ask SGE for the character list on this account"/>

        <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                   Text="{Binding FetchStatus}"
                   Foreground="{DynamicResource Theme.TextMuted}" FontSize="11" Margin="0,2,0,0"/>

        <CheckBox  Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2"
                   IsChecked="{Binding UseTls}"
                   AutomationProperties.HelpText="Authenticate over TLS (port 7910). Recommended — otherwise the password is only obfuscated over the wire. Uncheck to use plaintext port 7900."
                   Content="Secure connection (TLS)" Margin="0,4,0,0"
                   ToolTip.Tip="Authenticate over TLS (port 7910). Recommended — otherwise the password is only obfuscated over the wire. Uncheck to use plaintext port 7900."/>

        <!-- FE:STORM checkbox removed May 25, 2026 after empirical A/B
             testing showed no observable XML difference between FE:GENIE
             and FE:STORM identifiers across the info-verb surface
             (news / news help / dir list / help index / profile help /
             toggle list). The underlying ConnectionConfig.FrontEndId field
             still exists (defaults to "GENIE") so wider-surface testing
             can re-enable the toggle if needed. See backlog.md →
             "FE:STORM hypothesis — disconfirmed" for the experiment. -->
      </Grid>

      <!-- Lich proxy fields -->
      <Grid ColumnDefinitions="90,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
            IsVisible="{Binding IsLichMode}">

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Host"      VerticalAlignment="Center"/>
        <TextBox   Grid.Row="0" Grid.Column="1"
                   AutomationProperties.Name="Host"
                   Text="{Binding LichHost}"
                   Watermark="127.0.0.1"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Port"      VerticalAlignment="Center" Margin="0,8,0,0"/>
        <TextBox   Grid.Row="1" Grid.Column="1" Margin="0,8,0,0"
                   AutomationProperties.Name="Port"
                   Text="{Binding LichPort}"
                   Watermark="Port Lich is listening on (see the Lich window)"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Character" VerticalAlignment="Center" Margin="0,8,0,0"/>
        <TextBox   Grid.Row="2" Grid.Column="1" Margin="0,8,0,0"
                   AutomationProperties.Name="Character"
                   Text="{Binding Character}"
                   Watermark="Optional — used for the title bar / profile name"/>

        <!-- Seeds $game for scripts until the server's <app game=…> tag
             confirms the real instance a few lines into the stream. -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Instance"  VerticalAlignment="Center" Margin="0,8,0,0"/>
        <ComboBox  Grid.Row="3" Grid.Column="1" Margin="0,8,0,0"
                   AutomationProperties.Name="Instance"
                   AutomationProperties.HelpText="Which DR instance Lich is logged into. Scripts read this as $game; the server corrects it automatically after connect."
                   ItemsSource="{x:Static vm:ConnectDialogViewModel.Instances}"
                   SelectedItem="{Binding Instance}"
                   HorizontalAlignment="Stretch"
                   ToolTip.Tip="Which DR instance Lich is logged into. Scripts read this as $game; the server corrects it automatically after connect."/>

        <TextBlock Grid.Row="4" Grid.Column="1"
                   Text="Lich must already be running and authenticated for this character. Genie just attaches to its local port."
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource Theme.TextMuted}" FontSize="11" Margin="0,6,0,0"/>
      </Grid>
    </StackPanel>

    <!-- ── Action buttons ──────────────────────────────────────────────── -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="8" Margin="0,12,0,0">
      <Button Content="Cancel"  Command="{Binding CancelCommand}" Width="80"/>
      <Button Content="Connect" Command="{Binding OkCommand}"     Width="80"
              IsDefault="True"/>
    </StackPanel>

  </Grid>
</Window>
