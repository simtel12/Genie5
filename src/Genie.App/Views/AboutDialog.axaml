<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie.App.Views.AboutDialog"
        Title="About Genie 5"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False" ShowInTaskbar="False">

  <StackPanel Margin="26,22,26,18" Spacing="11">

    <!-- Wordmark + tagline -->
    <TextBlock Text="Genie 5" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource Theme.TextPrimary}"/>
    <TextBlock Text="A cross-platform client for DragonRealms — the modern successor to Genie 4."
               TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource Theme.TextSecondary}"/>

    <Border Height="1" Background="{DynamicResource Theme.Border}" Margin="0,3"/>

    <!-- Version + runtime -->
    <Grid ColumnDefinitions="92,*" RowDefinitions="Auto,Auto" >
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}"/>
      <TextBlock Grid.Row="0" Grid.Column="1" x:Name="VersionText"
                 FontFamily="Consolas,Menlo,monospace" FontSize="13" Foreground="{DynamicResource Theme.TextPrimary}"/>
      <TextBlock Grid.Row="1" Grid.Column="0" Text="Runtime" FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" Margin="0,3,0,0"/>
      <TextBlock Grid.Row="1" Grid.Column="1" Text=".NET 8 · Avalonia · Windows / macOS / Linux"
                 FontSize="13" Foreground="{DynamicResource Theme.TextSecondary}" Margin="0,3,0,0"/>
    </Grid>

    <!-- Links -->
    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3,0,0">
      <Button Content="GitHub"   Click="OnGitHub"   MinWidth="78"/>
      <Button Content="Wiki"     Click="OnWiki"     MinWidth="78"/>
      <Button Content="Discord"  Click="OnDiscord"  MinWidth="78"/>
      <Button Content="Releases" Click="OnReleases" MinWidth="78"/>
    </StackPanel>

    <Border Height="1" Background="{DynamicResource Theme.Border}" Margin="0,3"/>

    <!-- License + credits -->
    <StackPanel Spacing="3">
      <TextBlock Text="Licensed under GPL-3.0." FontSize="12" Foreground="{DynamicResource Theme.TextMuted}"/>
      <TextBlock Text="App icon, status-indicator glyphs &amp; compass icons by @dylb0t (GPL-3.0)."
                 FontSize="12" Foreground="{DynamicResource Theme.TextMuted}" TextWrapping="Wrap"/>
      <TextBlock Text="© 2026 the Genie 5 contributors." FontSize="12" Foreground="{DynamicResource Theme.TextMuted}"/>
    </StackPanel>

    <!-- Close -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
      <Button x:Name="CloseButton" Content="_Close" MinWidth="92"
              IsDefault="True" IsCancel="True" Click="OnClose"/>
    </StackPanel>

  </StackPanel>
</Window>
