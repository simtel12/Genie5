<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:docking="using:Genie.App.Docking"
             xmlns:vm="using:Genie.App.ViewModels"
             xmlns:controls="using:Genie.App.Controls"
             xmlns:core="using:Dock.Model.Core"
             x:Class="Genie.App.App"
             RequestedThemeVariant="Dark">

  <!-- Genie 4-style skinned chrome for windowed (MDI) child windows. Overrides
       the default MdiDocumentWindow ControlTheme from DockFluentTheme, so it
       must be merged here in Application.Resources. -->
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://Genie/Themes/MdiDocumentWindowSkin.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <DockFluentTheme />
    <!-- ColorPicker ships its own theme in Avalonia.Controls.ColorPicker;
         without this include the picker renders as blank space. -->
    <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml"/>
    <!-- DataGrid likewise — used by the Configuration dialog's rule tables. -->
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>

    <!-- Tool header: just the title -->
    <Style Selector="ToolControl">
      <Setter Property="HeaderTemplate">
        <DataTemplate DataType="core:IDockable">
          <TextBlock Text="{Binding Title}" Padding="2"/>
        </DataTemplate>
      </Setter>
    </Style>

    <!-- Document header: title -->
    <Style Selector="DocumentControl">
      <Setter Property="HeaderTemplate">
        <DataTemplate DataType="core:IDockable">
          <TextBlock Text="{Binding Title}" Padding="2"/>
        </DataTemplate>
      </Setter>
    </Style>

    <!-- Local-echo lines: italic + echo colour, driven by DisplaySettings.
         Use :is(TextBlock) so SelectableTextBlock (which subclasses TextBlock)
         also picks up the .echo class style. -->
    <Style Selector=":is(TextBlock).echo">
      <Setter Property="Foreground" Value="{DynamicResource EchoBrush}"/>
      <Setter Property="FontStyle"  Value="{DynamicResource EchoFontStyle}"/>
    </Style>

    <!-- Menu font: 80% of FluentTheme default (14 → 11). Both selectors
         needed because popup submenus live in a separate visual tree, so
         a FontSize on the top-level Menu doesn't propagate to nested
         MenuItems opened in popups. -->
    <Style Selector="Menu">
      <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style Selector="MenuItem">
      <Setter Property="FontSize" Value="11"/>
      <!-- Tooltip timing tuned for menu navigation:
           • ShowDelay 1200ms — a tip only appears if you deliberately rest on
             an item, so sweeping through the menu doesn't pop tips that cover
             adjacent items / the window beneath.
           • BetweenShowDelay 0 — disables the "chain instantly" behavior, so
             every tip waits the full delay instead of flashing as you move
             from one item to the next (the main cause of the covering). -->
      <Setter Property="ToolTip.ShowDelay" Value="1200"/>
      <Setter Property="ToolTip.BetweenShowDelay" Value="0"/>
    </Style>
  </Application.Styles>

  <Application.DataTemplates>

    <!-- ── Game text ──────────────────────────────────────────────────────── -->
    <DataTemplate DataType="docking:GameTextDocument">
      <Grid Background="{Binding ToolBackground}">
        <ScrollViewer x:Name="gameScroll"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Width="{Binding $parent[Grid].Bounds.Width}"
                      Height="{Binding $parent[Grid].Bounds.Height}"
                      controls:AutoScrollBehavior.ItemsSource="{Binding ViewModel.Lines}">
          <!-- Plain ItemsControl (keeps its default control-theme so it renders),
               with controls:LineSelection.Enabled adding browser-style selection
               ACROSS line items — Avalonia's per-control text selection can't
               span controls, so the behavior owns pointer input, drives each
               line's SelectionStart/End, and handles Ctrl+C / Ctrl+A. -->
          <ItemsControl ItemsSource="{Binding ViewModel.Lines}"
                        controls:LineSelection.Enabled="True"
                        FontFamily="{Binding ToolFontFamily}"
                        FontSize="{Binding ToolFontSize}"
                        Foreground="{Binding ToolForeground}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:TextLine">
                <!-- Foreground inherited from the control above (bound to the
                     tool's per-window setting). Highlight Inlines with their own
                     foreground still override; the .echo class style still wins
                     for typed-input echoes. SelectionBrush gives the cross-line
                     drag a visible highlight. -->
                <SelectableTextBlock TextWrapping="Wrap"
                                     Classes.echo="{Binding IsEcho}"
                                     SelectionBrush="#553A6EA5"
                                     controls:InlinesBehavior.Source="{Binding Inlines}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,20,8"
                IsVisible="{Binding #gameScroll.Tag.IsScrolledUp}"
                Command="{Binding #gameScroll.Tag.JumpToBottomCommand}"
                Content="↓ Bottom" FontSize="11" Padding="8,4" Opacity="0.85"/>
      </Grid>
    </DataTemplate>

    <!-- ── Vitals ─────────────────────────────────────────────────────────── -->
    <DataTemplate DataType="docking:VitalsTool">
      <ScrollViewer>
        <StackPanel Spacing="6" Margin="8">
          <Grid ColumnDefinitions="55,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Health"  Foreground="#aaa" FontSize="11" VerticalAlignment="Center"/>
            <ProgressBar Grid.Row="0" Grid.Column="1" Value="{Binding ViewModel.Health}"        Maximum="100" Foreground="#e05050" Height="10"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Mana"    Foreground="#aaa" FontSize="11" VerticalAlignment="Center"/>
            <ProgressBar Grid.Row="1" Grid.Column="1" Value="{Binding ViewModel.Mana}"          Maximum="100" Foreground="#5090e0" Height="10"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Spirit"  Foreground="#aaa" FontSize="11" VerticalAlignment="Center"/>
            <ProgressBar Grid.Row="2" Grid.Column="1" Value="{Binding ViewModel.Spirit}"        Maximum="100" Foreground="#50e0a0" Height="10"/>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Stamina" Foreground="#aaa" FontSize="11" VerticalAlignment="Center"/>
            <ProgressBar Grid.Row="3" Grid.Column="1" Value="{Binding ViewModel.Stamina}"       Maximum="100" Foreground="#e0c050" Height="10"/>
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Conc"    Foreground="#aaa" FontSize="11" VerticalAlignment="Center"/>
            <ProgressBar Grid.Row="4" Grid.Column="1" Value="{Binding ViewModel.Concentration}" Maximum="100" Foreground="#c050e0" Height="10"/>
          </Grid>
          <Separator/>
          <TextBlock Foreground="#aaa" FontSize="11">
            <Run Text="RT: "/><Run Text="{Binding ViewModel.RoundTimeSeconds, StringFormat={}{0:F1}s}"/>
          </TextBlock>
          <TextBlock Foreground="#aaa" FontSize="11">
            <Run Text="Spell: "/><Run Text="{Binding ViewModel.PreparedSpell}"/>
          </TextBlock>
          <TextBlock Foreground="#aaa" FontSize="11">
            <Run Text="L: "/><Run Text="{Binding ViewModel.LeftHand}"/>
            <Run Text="   R: "/><Run Text="{Binding ViewModel.RightHand}"/>
          </TextBlock>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <!-- ── Room ───────────────────────────────────────────────────────────── -->
    <!-- Every field wraps (Genie5.Kzin parity). The Exits/Players/Objects
         section labels are intentionally omitted — the content is colour-coded
         (blue=exits, green=players, grey=objects) and the game text is already
         self-describing. Each field collapses when empty so the panel doesn't
         show blank rows for sections the current room lacks. -->
    <DataTemplate DataType="docking:RoomTool">
      <ScrollViewer>
        <StackPanel Spacing="4" Margin="8">
          <SelectableTextBlock Text="{Binding ViewModel.Title}"       FontWeight="Bold" Foreground="#ccc" TextWrapping="Wrap"/>
          <SelectableTextBlock Text="{Binding ViewModel.Description}" Foreground="#aaa" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                               IsVisible="{Binding ViewModel.Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          <SelectableTextBlock Text="{Binding ViewModel.Exits}"   Foreground="#6af" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                               IsVisible="{Binding ViewModel.Exits,   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          <SelectableTextBlock Text="{Binding ViewModel.Players}" Foreground="#8d8" FontSize="11" TextWrapping="Wrap"
                               IsVisible="{Binding ViewModel.Players, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          <SelectableTextBlock Text="{Binding ViewModel.Objects}" Foreground="#aaa" FontSize="11" TextWrapping="Wrap"
                               IsVisible="{Binding ViewModel.Objects, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <!-- ── Scene ─────────────────────────────────────────────────────────── -->
    <!-- DR room/scene artwork (the <resource picture> image). Empty for rooms
         without art (most), so a placeholder fills the panel until one loads. -->
    <DataTemplate DataType="docking:SceneTool">
      <Grid Margin="6">
        <TextBlock Text="No scene image for this room."
                   Foreground="#777" FontSize="11" TextWrapping="Wrap"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsVisible="{Binding !ViewModel.HasImage}"/>
        <Image Source="{Binding ViewModel.Image}" Stretch="Uniform"
               IsVisible="{Binding ViewModel.HasImage}"/>
      </Grid>
    </DataTemplate>

    <!-- ── Mapper ────────────────────────────────────────────────────────── -->
    <!-- Map-dominant layout:                                                 -->
    <!--   row 0: thin toolbar (zone + level + zoom + pop-out)                -->
    <!--   row 1: 2-column split — map on left, Details panel on right        -->
    <!--          (separated by a draggable splitter so users can resize or   -->
    <!--          drag the Details column all the way closed)                 -->
    <!--   row 2: status strip (current room title + exits) — compact, spans  -->
    <!--          both columns                                                -->
    <DataTemplate DataType="docking:MapperTool">
      <Grid RowDefinitions="Auto,*,Auto" Margin="0">

        <!-- ── ROW 0: toolbar ────────────────────────────────────────── -->
        <!-- Pop-out button sits LEFT of the zone dropdown so it's clearly  -->
        <!-- a window-level action (move the panel) rather than a map-data -->
        <!-- action (zone / level / zoom). Keeping it in the right-side    -->
        <!-- cluster put it next to "zoom in" which made it easy to click  -->
        <!-- by accident while intending a zoom action.                    -->
        <Border Grid.Row="0" Background="#252525" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="4,3">
          <StackPanel Spacing="3">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="4">
            <!-- Pop out (window-level action, separated from data-level cluster) -->
            <Button Grid.Column="0" Content="⬈" Padding="6,1" FontSize="11"
                    Command="{Binding ViewModel.FloatCommand}"
                    ToolTip.Tip="Pop out to a separate window"/>
            <!-- Zone selector — takes available width -->
            <ComboBox Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      ItemsSource="{Binding ViewModel.AvailableZones}"
                      SelectedItem="{Binding ViewModel.SelectedZoneFile}"
                      PlaceholderText="(pick a zone)"
                      MinHeight="24"
                      ToolTip.Tip="Pick a zone XML from the Maps directory. Auto-detect normally handles this for you when you connect and walk."/>
            <!-- Level -->
            <TextBlock Grid.Column="2" Text="{Binding ViewModel.Level, StringFormat='L{0}'}"
                       Foreground="#cdd" VerticalAlignment="Center" FontSize="11"/>
            <Button Grid.Column="3" Content="▲" Padding="6,1" FontSize="10"
                    Command="{Binding ViewModel.LevelUpCommand}"
                    ToolTip.Tip="Z-level up"/>
            <Button Grid.Column="4" Content="▼" Padding="6,1" FontSize="10"
                    Command="{Binding ViewModel.LevelDownCommand}"
                    ToolTip.Tip="Z-level down"/>
            <!-- Zoom -->
            <Button Grid.Column="5" Content="−" Padding="8,1" FontSize="11"
                    Command="{Binding ViewModel.ZoomOutCommand}"
                    ToolTip.Tip="Zoom out (or mouse-wheel down over the map)"/>
            <Button Grid.Column="6" Content="+" Padding="8,1" FontSize="11"
                    Command="{Binding ViewModel.ZoomInCommand}"
                    ToolTip.Tip="Zoom in (or mouse-wheel up over the map)"/>
          </Grid>

          <!-- Editor toolbar (Genie 4 AutoMapper edit tools). Edit + Record + -->
          <!-- New + Save are always available; the node-edit cluster (Remove / -->
          <!-- Reset IDs / Snap / Lock / Dup) only shows in Edit mode.          -->
          <WrapPanel Orientation="Horizontal">
            <ToggleButton Content="✎ Edit" IsChecked="{Binding ViewModel.EditMode}"
                          Margin="0,0,4,0" Padding="6,1" FontSize="11"
                          ToolTip.Tip="Edit mode: click a room to select it, drag to move it. Turn off to navigate (click = nothing, right-click = Go Here)."/>
            <ToggleButton Content="⏺ Record" IsChecked="{Binding ViewModel.AutoCreateEnabled}"
                          Margin="0,0,4,0" Padding="6,1" FontSize="11"
                          ToolTip.Tip="Record mode: add new rooms to the active zone as you walk into them (Genie 4 Record Mode)."/>
            <Button Content="New" Command="{Binding ViewModel.NewZoneCommand}"
                    Margin="0,0,4,0" Padding="6,1" FontSize="11"
                    ToolTip.Tip="Start a new, empty zone. Save writes it to the Maps directory."/>
            <Button Command="{Binding ViewModel.SaveMapCommand}"
                    Margin="0,0,8,0" Padding="6,1" FontSize="11"
                    ToolTip.Tip="Save the active zone to its XML file (Genie 4 compatible).">
              <StackPanel Orientation="Horizontal" Spacing="3">
                <TextBlock Text="Save"/>
                <TextBlock Text="●" Foreground="#e0a060"
                           IsVisible="{Binding ViewModel.IsZoneDirty}"
                           ToolTip.Tip="Unsaved edits"/>
              </StackPanel>
            </Button>
            <ToggleButton Content="Labels" IsChecked="{Binding ViewModel.FullLabels}"
                          Margin="8,0,0,0" Padding="6,1" FontSize="11"
                          ToolTip.Tip="OFF: show only each room's primary name. ON: show the full |-separated label list. Labels auto-place around rooms and skip when crowded; the full set is always in the hover tooltip."/>

            <!-- Edit-only cluster -->
            <StackPanel Orientation="Horizontal" Spacing="4"
                        IsVisible="{Binding ViewModel.EditMode}">
              <Button Content="Remove" Command="{Binding ViewModel.RemoveSelectedCommand}"
                      Padding="6,1" FontSize="11" Background="#3a2424" Foreground="#ffcccc"
                      ToolTip.Tip="Delete the selected room (or press Delete on the map)."/>
              <Button Content="Reset IDs" Command="{Binding ViewModel.ResetMapIdsCommand}"
                      Padding="6,1" FontSize="11"
                      ToolTip.Tip="Renumber all room IDs to a dense 1..N sequence (fixes sparse ids after lots of add/remove)."/>
              <ToggleButton Content="Snap" IsChecked="{Binding ViewModel.SnapToGrid}"
                            Padding="6,1" FontSize="11"
                            ToolTip.Tip="Snap dragged rooms to the grid. Genie 5 maps are grid-based, so positions always align."/>
              <ToggleButton Content="Lock" IsChecked="{Binding ViewModel.LockPositions}"
                            Padding="6,1" FontSize="11"
                            ToolTip.Tip="Lock positions: rooms can be selected but not dragged."/>
              <ToggleButton Content="Dup" IsChecked="{Binding ViewModel.AllowDuplicate}"
                            Padding="6,1" FontSize="11"
                            ToolTip.Tip="Allow duplicate rooms while recording — don't merge a new room into an existing one that merely looks the same."/>
            </StackPanel>
          </WrapPanel>
          </StackPanel>
        </Border>

        <!-- ── ROW 1: map + auto-hiding Details flyout ───────────────── -->
        <!-- Single overlay cell: the map fills the row (less a thin strip  -->
        <!-- reserved on the right), and the Details panel is an auto-hiding -->
        <!-- flyout pinned to the right edge. Collapsed it shows a vertical  -->
        <!-- "DETAILS" strip; hovering the strip (or the open panel) slides  -->
        <!-- the full panel out OVER the map, and moving the pointer away    -->
        <!-- auto-hides it again. The pin button in the header keeps it open -->
        <!-- (ViewModel.DetailsPinned). -->
        <Grid Grid.Row="1">

          <!-- Map — background lives on the MapCanvas itself
               (user-customisable); leave the Border transparent so the
               chosen colour bleeds to the scroll viewport edges.
               The auto-walk indicator overlays the top of the column when a
               walk is active; visibility is gated on AutoWalk.Current.
               Right margin (24) reserves room for the always-present
               collapsed Details strip so it never covers the map scrollbar. -->
          <Grid RowDefinitions="Auto,Auto,*" Margin="0,0,24,0">
            <!-- Skills prompt — visible when a zone is loaded but we have
                 no skill data yet AND the user hasn't dismissed-forever.
                 Sits at the very top so it's visible before the user
                 clicks anything; auto-hides on Fetch / Skip / first
                 skill rank arriving from the parser. -->
            <Border Grid.Row="0"
                    IsVisible="{Binding ViewModel.ShowSkillsPrompt}"
                    Background="#2a3a1a" BorderBrush="#5a7a3a" BorderThickness="0,0,0,1"
                    Padding="8,5">
              <StackPanel Orientation="Vertical" Spacing="4">
                <TextBlock Text="ℹ Pathfinding uses your skill ranks"
                           Foreground="#cdd" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock TextWrapping="Wrap"
                           Foreground="#aab" FontSize="11"
                           Text="The mapper filters out climbs/swims/etc you can't take. Genie 5 needs to read your `info` and `exp all` once to know your guild, circle, and skill ranks — otherwise every gated exit is assumed reachable."/>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,3,0,0">
                  <Button Content="Fetch skills now" FontSize="11" Padding="8,2"
                          Background="#1e3a1e" Foreground="#cdd"
                          Command="{Binding ViewModel.FetchSkillsCommand}"
                          ToolTip.Tip="Sends `info` and `exp all` to the game now. The replies prime the pathfinder's guild, circle, and skill tables."/>
                  <Button Content="Skip" FontSize="11" Padding="8,2"
                          Command="{Binding ViewModel.DismissSkillsPromptCommand}"
                          ToolTip.Tip="Dismiss for this session — will prompt again next launch."/>
                  <Button Content="Don't ask again" FontSize="11" Padding="8,2"
                          Foreground="#aab"
                          Command="{Binding ViewModel.DontAskAboutSkillsCommand}"
                          ToolTip.Tip="Hide this prompt permanently. Pathfinder will still work but exits gated by skills you actually lack may not error until you try to walk them."/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- AutoWalk indicator — appears at the top of the map when a
                 walk is in flight. Shows current progress, lets the user
                 see what's happening, and gives an explicit Cancel button.
                 Auto-hides when no session is active. Includes the boat-
                 wait countdown bar inline when a cross-zone hop is mid-
                 transit (matches the spell-cast bar visual pattern from
                 the Hands Strip — magenta draining bar). -->
            <Border Grid.Row="1"
                    IsVisible="{Binding ViewModel.AutoWalk.Current, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Background="#1a3344" BorderBrush="#3a6688" BorderThickness="0,0,0,1"
                    Padding="8,4">
              <StackPanel Spacing="4">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                              VerticalAlignment="Center">
                    <TextBlock Text="⚡" Foreground="#8ad8e8" FontSize="13"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ViewModel.AutoWalk.Current.StatusMessage}"
                               Foreground="#cdd" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <!-- Resume only visible while paused -->
                    <Button Content="Resume" FontSize="11" Padding="6,2"
                            IsVisible="{Binding ViewModel.AutoWalk.IsCurrentPaused}"
                            Command="{Binding ViewModel.AutoWalk.ResumeCommand}"/>
                    <Button Content="Cancel" FontSize="11" Padding="6,2"
                            Background="#5a2828" Foreground="#ffcccc"
                            Command="{Binding ViewModel.AutoWalk.CancelCommand}"
                            ToolTip.Tip="Stop the current walk (Esc also cancels)"/>
                  </StackPanel>
                </Grid>

                <!-- Boat-wait countdown — visible only during a cross-zone
                     transit with a known wait window. Magenta to match the
                     spell-cast bar pattern from the Hands Strip. Bar drains
                     from full → empty over the expected wait; when 0 it
                     pegs and the walker keeps listening for the room
                     change (the actual ETA is fingerprint-driven). -->
                <Grid ColumnDefinitions="*,Auto"
                      IsVisible="{Binding ViewModel.AutoWalk.IsWaitingForCrossZone}">
                  <ProgressBar Grid.Column="0"
                               Value="{Binding ViewModel.AutoWalk.CurrentWaitSecondsLeft}"
                               Maximum="{Binding ViewModel.AutoWalk.CurrentWaitTotalSeconds}"
                               Minimum="0"
                               Foreground="#d066c8"
                               Background="#3a1a3a"
                               Height="14"
                               VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Margin="8,0,0,0"
                             VerticalAlignment="Center"
                             Foreground="#e0c0e8" FontSize="11"
                             FontFamily="Consolas,Courier New,monospace">
                    <Run Text="{Binding ViewModel.AutoWalk.CurrentWaitLabel}"/><Run Text=" · "/><Run Text="{Binding ViewModel.AutoWalk.CurrentWaitDisplay}"/>
                  </TextBlock>
                </Grid>
              </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="{Binding ViewModel.MapBackgroundBrush}">
              <ScrollViewer HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                <controls:MapCanvas Zone="{Binding ViewModel.ActiveZone}"
                                    CurrentNode="{Binding ViewModel.ActiveNode}"
                                    Level="{Binding ViewModel.Level}"
                                    RenderTick="{Binding ViewModel.RenderTick}"
                                    Zoom="{Binding ViewModel.ZoomLevel}"
                                    MapBackgroundBrush="{Binding ViewModel.MapBackgroundBrush}"
                                    AutoMapperAlpha="{Binding ViewModel.AutoMapperAlpha}"
                                    NodeClickedCommand="{Binding ViewModel.GotoNodeCommand}"
                                    EditExitCommand="{Binding ViewModel.EditExitCommand}"
                                    EditMode="{Binding ViewModel.EditMode}"
                                    SnapToGrid="{Binding ViewModel.SnapToGrid}"
                                    LockPositions="{Binding ViewModel.LockPositions}"
                                    FullLabels="{Binding ViewModel.FullLabels}"
                                    SelectedNode="{Binding ViewModel.SelectedNode, Mode=TwoWay}"
                                    NodeMovedCommand="{Binding ViewModel.NodeMovedCommand}"
                                    RemoveNodeCommand="{Binding ViewModel.RemoveNodeCommand}"/>
              </ScrollViewer>
            </Border>
          </Grid>

          <!-- Auto-hiding Details flyout — pinned right, drawn OVER the    -->
          <!-- map (last child of the single-cell row). `DetailsFlyout` is   -->
          <!-- the hover host: its IsPointerOver, OR ViewModel.DetailsPinned, -->
          <!-- decides which child shows. Both the strip and the open panel  -->
          <!-- are children of this one host, so moving between them never   -->
          <!-- drops the hover — no open/close flicker. -->
          <Border x:Name="DetailsFlyout"
                  HorizontalAlignment="Right" VerticalAlignment="Stretch">
            <Grid>

              <!-- Collapsed strip — shown whenever the panel is hidden. -->
              <Border x:Name="DetailsStrip" Width="24"
                      Background="#1a1a1a" BorderBrush="#333" BorderThickness="1,0,0,0"
                      IsVisible="{Binding !#DetailsPanel.IsVisible}"
                      ToolTip.Tip="Hover to open the Details panel; use the pin inside to keep it open.">
                <TextBlock Text="DETAILS" Foreground="#7a92a8" FontSize="10"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           RenderTransformOrigin="50%,50%">
                  <TextBlock.RenderTransform>
                    <RotateTransform Angle="-90"/>
                  </TextBlock.RenderTransform>
                </TextBlock>
              </Border>

              <!-- Expanded panel — visible while hovered or pinned. Wrapped  -->
              <!-- in a ScrollViewer so the content scrolls if the panel is   -->
              <!-- short / the user adds long Notes text. -->
              <Border x:Name="DetailsPanel" Width="260"
                      Background="#1a1a1a" BorderBrush="#333" BorderThickness="1,0,0,0">
                <Border.IsVisible>
                  <MultiBinding Converter="{x:Static controls:BoolOrConverter.Instance}">
                    <Binding Path="#DetailsFlyout.IsPointerOver"/>
                    <Binding Path="ViewModel.DetailsPinned"/>
                  </MultiBinding>
                </Border.IsVisible>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              Padding="6,4">
              <StackPanel Spacing="10">

                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="DETAILS" Foreground="#cdd" FontSize="11"
                             FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <ToggleButton Grid.Column="1" Content="📌"
                                IsChecked="{Binding ViewModel.DetailsPinned}"
                                FontSize="11" Padding="5,0" MinHeight="0"
                                ToolTip.Tip="Pin the Details panel open. When unpinned, it auto-hides to a strip when the pointer leaves."/>
                </Grid>

                <!-- ── Current Room ─────────────────────────────────── -->
                <StackPanel Spacing="3">
                  <TextBlock Text="CURRENT ROOM" Foreground="#7a92a8" FontSize="9"
                             FontWeight="SemiBold" Margin="0,0,0,2"/>
                  <Grid ColumnDefinitions="60,*"
                        IsVisible="{Binding ViewModel.CurrentServerId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Grid.Column="0" Text="Server id" Foreground="#888" FontSize="11"/>
                    <SelectableTextBlock Grid.Column="1" Text="{Binding ViewModel.CurrentServerId}"
                                         Foreground="#cdd" FontSize="11" FontFamily="Consolas,monospace"
                                         TextWrapping="Wrap"/>
                  </Grid>
                  <TextBlock Text="Notes" Foreground="#888" FontSize="11"/>
                  <TextBox  Text="{Binding ViewModel.CurrentNotes}"
                            FontSize="11" MinHeight="60" MaxHeight="120"
                            AcceptsReturn="True" TextWrapping="Wrap"
                            Watermark="e.g. Pawnshop, Empath's Guild, Bank teller"
                            ToolTip.Tip="Short label for this room — shown as text next to the dot on the map canvas. Pick the gameplay-meaningful name (vendor / NPC role / dungeon entry / etc.)."/>
                  <Button Content="Save Notes" Padding="8,2" FontSize="11"
                          HorizontalAlignment="Right"
                          Command="{Binding ViewModel.SaveNotesCommand}"
                          ToolTip.Tip="Save the edited Notes back to the zone XML file. Updates immediately on disk and on the map."/>
                </StackPanel>

                <!-- ── Edit Room (edit mode only) ───────────────────── -->
                <!-- Genie 4 AutoMapper "Edit Panel": properties of the      -->
                <!-- selected node. Title/server-id feed the lookup index,   -->
                <!-- so Apply rebuilds it; Color is a hex like #FFAA00.      -->
                <StackPanel Spacing="3" IsVisible="{Binding ViewModel.EditMode}">
                  <TextBlock Text="EDIT ROOM" Foreground="#7a92a8" FontSize="9"
                             FontWeight="SemiBold" Margin="0,0,0,2"/>
                  <TextBlock Text="Click a room on the map to select it."
                             Foreground="#888" FontSize="11" TextWrapping="Wrap"
                             IsVisible="{Binding ViewModel.SelectedNode, Converter={x:Static ObjectConverters.IsNull}}"/>
                  <StackPanel Spacing="3"
                              IsVisible="{Binding ViewModel.SelectedNode, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="Title" Foreground="#888" FontSize="11"/>
                    <TextBox Text="{Binding ViewModel.SelNodeTitle}" FontSize="11"/>
                    <TextBlock Text="Notes / label" Foreground="#888" FontSize="11"/>
                    <TextBox Text="{Binding ViewModel.SelNodeNotes}" FontSize="11"
                             Watermark="e.g. Bank|Teller (| separates #goto labels)"/>
                    <TextBlock Text="Color (hex)" Foreground="#888" FontSize="11"/>
                    <TextBox Text="{Binding ViewModel.SelNodeColor}" FontSize="11"
                             FontFamily="Consolas,monospace" Watermark="#FFAA00"/>
                    <TextBlock Text="Server id" Foreground="#888" FontSize="11"/>
                    <TextBox Text="{Binding ViewModel.SelNodeServerId}" FontSize="11"
                             FontFamily="Consolas,monospace"/>
                    <Button Content="Apply" Padding="8,2" FontSize="11"
                            HorizontalAlignment="Right"
                            Command="{Binding ViewModel.ApplyNodePropsCommand}"
                            ToolTip.Tip="Write these fields back into the room. Save the zone to persist to disk."/>
                  </StackPanel>
                </StackPanel>

                <!-- ── Zone ─────────────────────────────────────────── -->
                <StackPanel Spacing="3">
                  <TextBlock Text="ZONE" Foreground="#7a92a8" FontSize="9"
                             FontWeight="SemiBold" Margin="0,0,0,2"/>
                  <Grid ColumnDefinitions="60,*">
                    <TextBlock Grid.Column="0" Text="Rooms"      Foreground="#888" FontSize="11"/>
                    <TextBlock Grid.Column="1" Text="{Binding ViewModel.RoomCount}" Foreground="#cdd" FontSize="11"/>
                  </Grid>
                  <Grid ColumnDefinitions="60,*"
                        IsVisible="{Binding ViewModel.ZoneAgeDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Grid.Column="0" Text="Updated" Foreground="#888" FontSize="11"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding ViewModel.ZoneAgeDisplay}"
                                 Foreground="#cdd" FontSize="11" VerticalAlignment="Center"/>
                      <Border Background="#3a2818" CornerRadius="2" Padding="4,1"
                              VerticalAlignment="Center"
                              IsVisible="{Binding ViewModel.IsZoneStale}"
                              ToolTip.Tip="This zone hasn't been updated in over a month. The community Maps repo may have newer data — try File → Update Maps from Official Repo.">
                        <TextBlock Text="may be stale" Foreground="#e0a060" FontSize="9" FontWeight="SemiBold"/>
                      </Border>
                    </StackPanel>
                  </Grid>
                  <TextBlock Text="{Binding ViewModel.MapsDirectory, StringFormat='Maps: {0}'}"
                             Foreground="#668" FontSize="10" TextWrapping="Wrap"/>
                  <Border Background="#1e3a1e" CornerRadius="2" Padding="4,1"
                          HorizontalAlignment="Left"
                          IsVisible="{Binding ViewModel.IsGitManaged}"
                          ToolTip.Tip="This directory is a git working copy. Use your preferred git client to pull / commit / push / open pull requests — Genie does not run git itself.">
                    <TextBlock Text="git-managed" Foreground="#a0e0a0" FontSize="9" FontWeight="SemiBold"/>
                  </Border>
                </StackPanel>

                <!-- ── Behavior + Appearance ────────────────────────── -->
                <StackPanel Spacing="3">
                  <TextBlock Text="BEHAVIOR" Foreground="#7a92a8" FontSize="9"
                             FontWeight="SemiBold" Margin="0,0,0,2"/>
                  <CheckBox Content="Auto-create new rooms"
                            IsChecked="{Binding ViewModel.AutoCreateEnabled}"
                            FontSize="11"
                            ToolTip.Tip="When ON, walking into an unmapped room adds a new node to the active zone. When OFF, the mapper only matches against existing zone data."/>
                  <TextBlock Text="Map background:" Foreground="#888" FontSize="11"/>
                  <ColorPicker Color="{Binding ViewModel.MapBackground, Mode=TwoWay}"
                               IsAlphaEnabled="False"
                               HorizontalAlignment="Left"
                               ToolTip.Tip="Pick any colour for the map canvas. Cream/tan (e.g. #F5EFD8) matches the Genie 4 AutoMapper look."/>
                </StackPanel>

                <TextBlock Text="Tip: hover a room for details, right-click for a context menu, mouse-wheel to zoom."
                           Foreground="#668" FontSize="10" TextWrapping="Wrap"/>
              </StackPanel>
                </ScrollViewer>
              </Border>
            </Grid>
          </Border>
        </Grid>

        <!-- ── ROW 2: compact status strip — current room + exits + diag ─ -->
        <Border Grid.Row="2" Background="#1e1e1e" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="6,3">
          <StackPanel Spacing="2">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                <TextBlock Foreground="#888" FontSize="11" VerticalAlignment="Center" Text="◉"/>
                <SelectableTextBlock Text="{Binding ViewModel.CurrentTitle}"
                                     Foreground="#cdd" FontSize="11" FontWeight="SemiBold"
                                     VerticalAlignment="Center"
                                     TextTrimming="CharacterEllipsis"/>
                <TextBlock Foreground="#666" FontSize="11" VerticalAlignment="Center"
                           Text="·" Margin="4,0,0,0"/>
                <!-- Obvious exits — clickable compass-direction buttons. Same
                     pattern and command wiring as the Less Obvious Paths strip
                     below; styled in blue so the two surfaces are visually
                     distinct (blue = "the game shows this exit", purple =
                     "hidden / requires a non-compass command"). -->
                <ItemsControl x:Name="ObviousExitsList"
                              ItemsSource="{Binding ViewModel.CurrentObviousExits}"
                              VerticalAlignment="Center">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="x:String">
                      <Button Content="{Binding}"
                              Padding="6,1" Margin="0,1,3,1" FontSize="11"
                              Background="#1a2838" Foreground="#8ac0e8"
                              BorderBrush="#3a5a7a" BorderThickness="1"
                              Command="{Binding $parent[ItemsControl].DataContext.ViewModel.WalkCompassCommand}"
                              CommandParameter="{Binding}"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
              <TextBlock Grid.Column="1"
                         Text="{Binding ViewModel.ZoneName}"
                         Foreground="#888" FontSize="11"
                         VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>
            <!-- Less Obvious Paths — clickable buttons for non-compass arcs
                 (go-doors, climb-walls, swim-rivers, etc.). ItemsControl
                 collapses to zero height when the collection is empty, so
                 no extra IsVisible binding is needed. Each button sends its
                 MoveCommand through the same input pipeline as a typed
                 command. Future: tooltip on hover will show the arc's
                 Requires hint (skill / class / level needed) once the
                 community starts populating that data in the maps repo. -->
            <ItemsControl x:Name="LessObviousList"
                          ItemsSource="{Binding ViewModel.CurrentLessObviousPaths}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:LessObviousPath">
                  <Button Content="{Binding MoveCommand}"
                          Padding="6,2" Margin="0,1,4,1" FontSize="11"
                          Background="#2d2238" Foreground="#d8c8e8"
                          BorderBrush="#5a4475" BorderThickness="1"
                          Command="{Binding $parent[ItemsControl].DataContext.ViewModel.WalkLessObviousCommand}"
                          CommandParameter="{Binding MoveCommand}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Diagnostic / auto-detect status — only visible when there's something to say -->
            <SelectableTextBlock Text="{Binding ViewModel.LoadStatus}"
                                 Foreground="#a8b8a8" FontSize="10"
                                 TextWrapping="Wrap"
                                 IsVisible="{Binding ViewModel.LoadStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          </StackPanel>
        </Border>

      </Grid>
    </DataTemplate>

    <!-- ── Backpack ────────────────────────────────────────────────────── -->
    <DataTemplate DataType="docking:BackpackTool">
      <Grid RowDefinitions="*" Background="{Binding ToolBackground}">
        <ScrollViewer x:Name="backpackScroll"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Width="{Binding $parent[Grid].Bounds.Width}"
                      Height="{Binding $parent[Grid].Bounds.Height}">
          <ItemsControl ItemsSource="{Binding ViewModel.Items}"
                        FontFamily="{Binding ToolFontFamily}"
                        FontSize="{Binding ToolFontSize}"
                        Foreground="{Binding ToolForeground}"
                        Margin="8">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:TextLine">
                <!-- Inherits Foreground from the ItemsControl (tool-scoped). -->
                <SelectableTextBlock TextWrapping="Wrap" Margin="0,1"
                                     controls:InlinesBehavior.Source="{Binding Inlines}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </DataTemplate>

    <!-- ── Streams (shared template for all 5 stream tools) ──────────────── -->
    <DataTemplate DataType="docking:StreamTool">
      <Grid Background="{Binding ToolBackground}">
        <ScrollViewer x:Name="streamScroll"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Width="{Binding $parent[Grid].Bounds.Width}"
                      Height="{Binding $parent[Grid].Bounds.Height}"
                      controls:AutoScrollBehavior.ItemsSource="{Binding Buffer.Lines}">
          <ItemsControl ItemsSource="{Binding Buffer.Lines}"
                        FontFamily="{Binding ToolFontFamily}"
                        FontSize="{Binding ToolFontSize}"
                        Foreground="{Binding ToolForeground}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:TextLine">
                <!-- Foreground inherits from the tool-scoped ItemsControl. -->
                <SelectableTextBlock TextWrapping="Wrap"
                                     controls:InlinesBehavior.Source="{Binding Inlines}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,20,8"
                IsVisible="{Binding #streamScroll.Tag.IsScrolledUp}"
                Command="{Binding #streamScroll.Tag.JumpToBottomCommand}"
                Content="↓ Bottom" FontSize="11" Padding="8,4" Opacity="0.85"/>
      </Grid>
    </DataTemplate>

    <DataTemplate DataType="docking:ExperienceTool">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <SelectableTextBlock Text="{Binding ViewModel.Content}"
                             FontFamily="{Binding ToolFontFamily}"
                             FontSize="{Binding ToolFontSize}"
                             Margin="8"
                             Foreground="{DynamicResource GameBrush}"/>
      </ScrollViewer>
    </DataTemplate>

    <!-- ── Plugin-created windows (generic) ───────────────────────────────── -->
    <!-- One template serves EVERY plugin window. A plugin calls               -->
    <!-- IPluginHost.SetWindow("My Panel", text) and the dock factory spins up -->
    <!-- a PluginWindowTool bound here. Monospaced for column-aligned plugin   -->
    <!-- output (inventory trees, tables).                                      -->
    <DataTemplate DataType="docking:PluginWindowTool">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <SelectableTextBlock Text="{Binding ViewModel.Content}"
                             FontFamily="{Binding ToolFontFamily}"
                             FontSize="{Binding ToolFontSize}"
                             Margin="8"
                             Foreground="{DynamicResource GameBrush}"/>
      </ScrollViewer>
    </DataTemplate>

    <!-- ── Scripts panel (running list + Start/Stop + output log) ─────────── -->
    <!-- The always-on bottom strip (ScriptBarViewModel) shows the same running  -->
    <!-- scripts compactly; this dockable panel adds the Start… picker, Stop All,-->
    <!-- and a scrollable [script] output log. Both .cmd and .js appear here.    -->
    <DataTemplate DataType="docking:ScriptsTool">
      <Grid RowDefinitions="Auto,Auto,*" Margin="4">

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6"
                    Margin="0,0,0,4">
          <Button Content="Start…" Command="{Binding ViewModel.StartScriptCommand}"
                  FontSize="11" Padding="8,2"
                  ToolTip.Tip="Run a .cmd / .inc / .js script via file picker"/>
          <Button Content="Stop All" Command="{Binding ViewModel.StopAllCommand}"
                  FontSize="11" Padding="8,2"/>
          <Button Content="Clear" Command="{Binding ViewModel.ClearOutputCommand}"
                  FontSize="11" Padding="8,2"
                  ToolTip.Tip="Clear the output log below"/>
          <TextBlock Text="{Binding ViewModel.StatusText}" Foreground="#8aa3b5"
                     FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Running scripts -->
        <Border Grid.Row="1" Background="#1f2429" BorderBrush="#3a4148"
                BorderThickness="1" CornerRadius="3" Padding="4" MaxHeight="160">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ViewModel.RunningScripts}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:RunningScriptRow">
                  <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,1">
                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12"
                               Foreground="#cfe0ee" VerticalAlignment="Center"/>
                    <!-- Language tag — only shown for .js scripts. -->
                    <Border Grid.Column="1" Background="#2d3b46" CornerRadius="2"
                            Padding="3,0" Margin="4,0" VerticalAlignment="Center"
                            IsVisible="{Binding IsJavaScript}">
                      <TextBlock Text="js" FontSize="9" Foreground="#e8c97a"/>
                    </Border>
                    <Button Grid.Column="2" Content="Stop" FontSize="10"
                            Padding="6,1" Command="{Binding StopCommand}"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!-- Output log -->
        <Border Grid.Row="2" Background="#15191d" BorderBrush="#3a4148"
                BorderThickness="1" CornerRadius="3" Margin="0,4,0,0">
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        controls:AutoScrollBehavior.ItemsSource="{Binding ViewModel.Output}">
            <ItemsControl ItemsSource="{Binding ViewModel.Output}"
                          FontFamily="Consolas,Menlo,monospace" FontSize="11"
                          Foreground="#9fb4c4" Margin="4">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:TextLine">
                  <SelectableTextBlock TextWrapping="Wrap"
                                       controls:InlinesBehavior.Source="{Binding Inlines}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </Grid>
    </DataTemplate>

  </Application.DataTemplates>

</Application>
