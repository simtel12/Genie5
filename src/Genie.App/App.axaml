<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:docking="using:Genie.App.Docking"
             xmlns:vm="using:Genie.App.ViewModels"
             xmlns:controls="using:Genie.App.Controls"
             xmlns:core="using:Dock.Model.Core"
             x:Class="Genie.App.App"
             RequestedThemeVariant="Dark">

  <!-- Genie 4-style skinned chrome for windowed (MDI) child windows. Overrides
       the default MdiDocumentWindow ControlTheme from DockFluentTheme, so it
       must be merged here in Application.Resources. -->
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- #20: design-time defaults for the Theme.* palette; ThemeService
             overwrites the same keys in Application.Resources at runtime. -->
        <ResourceInclude Source="avares://Genie5/Themes/ThemePalette.axaml" />
        <ResourceInclude Source="avares://Genie5/Themes/MdiDocumentWindowSkin.axaml" />
        <!-- #80: overrides the stock ToolControl theme with a cached, per-dockable
             content host so stacked tool tabs of different types each keep their own
             view instead of all showing the first-built one. Full writeup lives in
             the file header. -->
        <ResourceInclude Source="avares://Genie5/Themes/ToolControlCachedSkin.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <DockFluentTheme />
    <!-- ColorPicker ships its own theme in Avalonia.Controls.ColorPicker;
         without this include the picker renders as blank space. -->
    <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml"/>
    <!-- DataGrid likewise — used by the Configuration dialog's rule tables. -->
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>

    <!-- Tool header: just the title -->
    <Style Selector="ToolControl">
      <Setter Property="HeaderTemplate">
        <DataTemplate DataType="core:IDockable">
          <TextBlock Text="{Binding Title}" Padding="2"/>
        </DataTemplate>
      </Setter>
    </Style>

    <!-- Document header: title -->
    <Style Selector="DocumentControl">
      <Setter Property="HeaderTemplate">
        <DataTemplate DataType="core:IDockable">
          <TextBlock Text="{Binding Title}" Padding="2"/>
        </DataTemplate>
      </Setter>
    </Style>

    <!-- Local-echo lines: italic + echo colour, driven by DisplaySettings.
         Use :is(TextBlock) so SelectableTextBlock (which subclasses TextBlock)
         also picks up the .echo class style. -->
    <Style Selector=":is(TextBlock).echo">
      <Setter Property="Foreground" Value="{DynamicResource EchoBrush}"/>
      <Setter Property="FontStyle"  Value="{DynamicResource EchoFontStyle}"/>
    </Style>

    <!-- Menu font: 80% of FluentTheme default (14 → 11). Both selectors
         needed because popup submenus live in a separate visual tree, so
         a FontSize on the top-level Menu doesn't propagate to nested
         MenuItems opened in popups. -->
    <Style Selector="Menu">
      <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style Selector="MenuItem">
      <Setter Property="FontSize" Value="11"/>
      <!-- Tooltip timing tuned for menu navigation:
           • ShowDelay 1200ms — a tip only appears if you deliberately rest on
             an item, so sweeping through the menu doesn't pop tips that cover
             adjacent items / the window beneath.
           • BetweenShowDelay 0 — disables the "chain instantly" behavior, so
             every tip waits the full delay instead of flashing as you move
             from one item to the next (the main cause of the covering). -->
      <Setter Property="ToolTip.ShowDelay" Value="1200"/>
      <Setter Property="ToolTip.BetweenShowDelay" Value="0"/>
    </Style>
  </Application.Styles>

  <Application.DataTemplates>

    <!-- ── Game text ──────────────────────────────────────────────────────── -->
    <DataTemplate DataType="docking:GameTextDocument">
      <Grid Background="{Binding ToolBackground}">
        <!-- Suppress SelectableTextBlock's built-in Copy flyout so right-click on
             game text surfaces the window menu below (Ctrl+C / Ctrl+Shift+C still
             copy). -->
        <Grid.Styles>
          <Style Selector="SelectableTextBlock">
            <Setter Property="ContextFlyout" Value="{x:Null}" />
          </Style>
        </Grid.Styles>
        <!-- Per-window right-click menu (the game window is a Document, hosted
             outside the ToolControl theme that carries the menu for tool windows,
             so it gets its own copy). No "Close Window" — it's the primary
             document. -->
        <Grid.ContextMenu>
          <ContextMenu docking:WindowMenuBehavior.RefreshOnOpen="True">
            <MenuItem Header="Copy"
                      InputGesture="Ctrl+C"
                      Command="{x:Static docking:WindowMenuBehavior.CopySelectionCommand}"
                      IsVisible="{Binding WindowMenu.ShowCopyAll}" />
            <MenuItem Header="Copy All"
                      Command="{Binding WindowMenu.CopyAllCommand}"
                      IsVisible="{Binding WindowMenu.ShowCopyAll}" />
            <MenuItem Header="Save As…"
                      Command="{Binding WindowMenu.SaveAsCommand}"
                      IsVisible="{Binding WindowMenu.ShowSaveAs}" />
            <MenuItem Header="Find…"
                      InputGesture="Ctrl+F"
                      Command="{Binding WindowMenu.FindCommand}"
                      IsVisible="{Binding WindowMenu.ShowFind}" />
            <MenuItem Header="Clear"
                      Command="{Binding WindowMenu.ClearCommand}"
                      IsVisible="{Binding WindowMenu.ShowClear}" />
            <MenuItem Header="Time Stamp"
                      ToggleType="CheckBox"
                      IsChecked="{Binding WindowMenu.IsTimestampOn, Mode=TwoWay}"
                      IsVisible="{Binding WindowMenu.ShowTimestamp}" />
            <MenuItem Header="Name List Only"
                      ToggleType="CheckBox"
                      IsChecked="{Binding WindowMenu.IsNameListOnlyOn, Mode=TwoWay}"
                      IsVisible="{Binding WindowMenu.ShowNameListOnly}" />
            <!-- Stream windows only (ShowEchoToMain is false for this primary
                 game document, so it stays hidden here). -->
            <MenuItem Header="Show in Main Window"
                      ToggleType="CheckBox"
                      IsChecked="{Binding WindowMenu.IsEchoToMainOn, Mode=TwoWay}"
                      IsVisible="{Binding WindowMenu.ShowEchoToMain}" />
            <MenuItem Header="Word Wrap"
                      ToggleType="CheckBox"
                      IsChecked="{Binding WindowMenu.IsWordWrapOn, Mode=TwoWay}"
                      IsVisible="{Binding WindowMenu.ShowWordWrap}" />
            <MenuItem Header="Pause Scrolling"
                      ToggleType="CheckBox"
                      IsChecked="{Binding WindowMenu.IsScrollPaused, Mode=TwoWay}"
                      IsVisible="{Binding WindowMenu.ShowPauseScroll}" />
          </ContextMenu>
        </Grid.ContextMenu>
        <!-- PageScroll (#136): PageUp/PageDown page the last-clicked game
             window from the command bar; the main game window is the default
             target before any click. -->
        <ScrollViewer x:Name="gameScroll"
                      HorizontalScrollBarVisibility="{Binding ToolHScroll}"
                      VerticalScrollBarVisibility="Auto"
                      Width="{Binding $parent[Grid].Bounds.Width}"
                      Height="{Binding $parent[Grid].Bounds.Height}"
                      controls:PageScroll.IsTarget="True"
                      controls:PageScroll.IsDefaultTarget="True"
                      controls:FindInWindow.ScrollModel="{Binding Find}"
                      controls:AutoScrollBehavior.ItemsSource="{Binding ViewModel.Lines}"
                      controls:AutoScrollBehavior.Paused="{Binding IsScrollPaused}">
          <!-- Plain ItemsControl (keeps its default control-theme so it renders),
               with controls:LineSelection.Enabled adding browser-style selection
               ACROSS line items — Avalonia's per-control text selection can't
               span controls, so the behavior owns pointer input, drives each
               line's SelectionStart/End, and handles Ctrl+C / Ctrl+A. -->
          <ItemsControl ItemsSource="{Binding ViewModel.Lines}"
                        controls:LineSelection.Enabled="True"
                        FontFamily="{Binding ToolFontFamily}"
                        FontSize="{Binding ToolFontSize}"
                        Foreground="{Binding ToolForeground}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:TextLine">
                <!-- Foreground inherited from the control above (bound to the
                     tool's per-window setting). Highlight Inlines with their own
                     foreground still override; the .echo class style still wins
                     for typed-input echoes. SelectionBrush gives the cross-line
                     drag a visible highlight. -->
                <!-- ContextFlyout nulled as a LOCAL value (not a Style) — the
                     Fluent theme's built-in "Copy" flyout is set via a control-
                     theme setter that a Style-level null doesn't reliably beat,
                     so right-clicking text opened a second menu. A local null
                     wins unconditionally; with no flyout the right-click bubbles
                     up to the single window menu above. Ctrl+C still copies. -->
                <SelectableTextBlock TextWrapping="{Binding $parent[ItemsControl].DataContext.ToolTextWrapping}"
                                     ContextFlyout="{x:Null}"
                                     Classes.echo="{Binding IsEcho}"
                                     SelectionBrush="{DynamicResource Theme.Selection}"
                                     controls:InlinesBehavior.Source="{Binding Inlines}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,20,8"
                IsVisible="{Binding #gameScroll.Tag.IsScrolledUp}"
                Command="{Binding #gameScroll.Tag.JumpToBottomCommand}"
                Content="↓ Bottom" FontSize="11" Padding="8,4" Opacity="0.85"/>

        <!-- Find bar (#120) — overlays top-right so it never disturbs the
             MDI-workaround Width/Height pinning on the ScrollViewer. Ctrl+F
             or the window menu opens it; Enter walks older matches,
             Shift+Enter newer, Esc closes. -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,4,20,0" Padding="4,2" CornerRadius="3"
                Background="{DynamicResource Theme.ToolbarBg}"
                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                IsVisible="{Binding Find.IsOpen}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBox Text="{Binding Find.FindText}" Watermark="Find…"
                     AutomationProperties.Name="Find in window"
                     Width="160" FontSize="11" MinHeight="0" Padding="4,2"
                     controls:FindInWindow.BoxModel="{Binding Find}"/>
            <TextBlock Text="{Binding Find.Status}" FontSize="10"
                       Foreground="{DynamicResource Theme.TextMuted}"
                       VerticalAlignment="Center"/>
            <Button Content="▲" FontSize="10" Padding="4,1" MinHeight="0" MinWidth="0"
                    AutomationProperties.Name="Find previous"
                    AutomationProperties.HelpText="Older match (Enter)"
                    Command="{Binding Find.OlderCommand}"
                    ToolTip.Tip="Older match (Enter)"/>
            <Button Content="▼" FontSize="10" Padding="4,1" MinHeight="0" MinWidth="0"
                    AutomationProperties.Name="Find next"
                    AutomationProperties.HelpText="Newer match (Shift+Enter)"
                    Command="{Binding Find.NewerCommand}"
                    ToolTip.Tip="Newer match (Shift+Enter)"/>
            <Button Content="✕" FontSize="10" Padding="4,1" MinHeight="0" MinWidth="0"
                    Background="Transparent" BorderThickness="0"
                    AutomationProperties.Name="Close find bar"
                    AutomationProperties.HelpText="Close (Esc)"
                    Command="{Binding Find.CloseCommand}"
                    ToolTip.Tip="Close (Esc)"/>
          </StackPanel>
        </Border>
      </Grid>
    </DataTemplate>

    <!-- ── Vitals ─────────────────────────────────────────────────────────── -->
    <DataTemplate DataType="docking:VitalsTool">
      <ScrollViewer>
        <StackPanel Spacing="6" Margin="8">
          <Grid ColumnDefinitions="55,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Health"  Foreground="{DynamicResource Theme.TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
            <ProgressBar Grid.Row="0" Grid.Column="1" Value="{Binding ViewModel.Health}"        Maximum="100" Foreground="{DynamicResource Theme.HealthBar}" Height="10" AutomationProperties.Name="Health"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Mana"    Foreground="{DynamicResource Theme.TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
            <ProgressBar Grid.Row="1" Grid.Column="1" Value="{Binding ViewModel.Mana}"          Maximum="100" Foreground="{DynamicResource Theme.ManaBar}" Height="10" AutomationProperties.Name="Mana"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Spirit"  Foreground="{DynamicResource Theme.TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
            <ProgressBar Grid.Row="2" Grid.Column="1" Value="{Binding ViewModel.Spirit}"        Maximum="100" Foreground="{DynamicResource Theme.SpiritBar}" Height="10" AutomationProperties.Name="Spirit"/>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Stamina" Foreground="{DynamicResource Theme.TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
            <ProgressBar Grid.Row="3" Grid.Column="1" Value="{Binding ViewModel.Stamina}"       Maximum="100" Foreground="{DynamicResource Theme.StaminaBar}" Height="10" AutomationProperties.Name="Stamina"/>
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Conc"    Foreground="{DynamicResource Theme.TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
            <ProgressBar Grid.Row="4" Grid.Column="1" Value="{Binding ViewModel.Concentration}" Maximum="100" Foreground="{DynamicResource Theme.ConcBar}" Height="10" AutomationProperties.Name="Concentration"/>
          </Grid>
          <Separator/>
          <TextBlock Foreground="{DynamicResource Theme.TextSecondary}" FontSize="11"
                     AutomationProperties.Name="{Binding ViewModel.RoundTimeSeconds, StringFormat='Roundtime: {0:F1} seconds'}">
            <Run Text="RT: "/><Run Text="{Binding ViewModel.RoundTimeSeconds, StringFormat={}{0:F1}s}"/>
          </TextBlock>
          <TextBlock Foreground="{DynamicResource Theme.TextSecondary}" FontSize="11"
                     AutomationProperties.Name="{Binding ViewModel.PreparedSpell, StringFormat='Prepared spell: {0}'}"
                     AutomationProperties.LiveSetting="Polite">
            <Run Text="Spell: "/><Run Text="{Binding ViewModel.PreparedSpell}"/>
          </TextBlock>
          <TextBlock Foreground="{DynamicResource Theme.TextSecondary}" FontSize="11"
                     AutomationProperties.LiveSetting="Polite">
            <AutomationProperties.Name>
              <MultiBinding StringFormat="Left hand: {0}, right hand: {1}">
                <Binding Path="ViewModel.LeftHand"/>
                <Binding Path="ViewModel.RightHand"/>
              </MultiBinding>
            </AutomationProperties.Name>
            <Run Text="L: "/><Run Text="{Binding ViewModel.LeftHand}"/>
            <Run Text="   R: "/><Run Text="{Binding ViewModel.RightHand}"/>
          </TextBlock>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <!-- ── Room ───────────────────────────────────────────────────────────── -->
    <!-- Every field wraps (Genie5.Kzin parity). The Exits/Players/Objects
         section labels are intentionally omitted — the content is colour-coded
         (blue=exits, green=players, grey=objects) and the game text is already
         self-describing. Each field collapses when empty so the panel doesn't
         show blank rows for sections the current room lacks. -->
    <DataTemplate DataType="docking:RoomTool">
      <!-- Wrapped in a Grid with the ScrollViewer pinned to the Grid's actual
           bounds, mirroring the Game-text document (above). In MDI/windowed
           mode every panel is hosted by the DocumentControl MDI host, which
           measures content with INFINITE width — so a bare ScrollViewer hands
           its content unbounded width and TextWrapping="Wrap" never kicks in
           (regression #124, MDI only; docked mode's ToolControl host already
           constrains width). Pinning Width to $parent[Grid].Bounds.Width forces
           a finite width in both modes so every field wraps. -->
      <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Width="{Binding $parent[Grid].Bounds.Width}"
                      Height="{Binding $parent[Grid].Bounds.Height}">
        <StackPanel Spacing="4" Margin="8">
          <SelectableTextBlock Text="{Binding ViewModel.Title}"       FontWeight="Bold" Foreground="{DynamicResource Theme.TextPrimary}" TextWrapping="Wrap"/>
          <SelectableTextBlock Text="{Binding ViewModel.Description}" Foreground="{DynamicResource Theme.TextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                               IsVisible="{Binding ViewModel.Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          <SelectableTextBlock Text="{Binding ViewModel.Exits}"   Foreground="{DynamicResource Theme.Accent}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                               IsVisible="{Binding ViewModel.Exits,   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          <SelectableTextBlock Text="{Binding ViewModel.Players}" Foreground="{DynamicResource Theme.Success}" FontSize="11" TextWrapping="Wrap"
                               IsVisible="{Binding ViewModel.Players, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          <!-- #131: render room objects as inlines so <pushBold> creatures gold
               via the MonsterBold path; Foreground is the default for the rest. -->
          <SelectableTextBlock controls:InlinesBehavior.Source="{Binding ViewModel.ObjectsInlines}"
                               Foreground="{DynamicResource Theme.TextSecondary}" FontSize="11" TextWrapping="Wrap"
                               IsVisible="{Binding ViewModel.Objects, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>
        </ScrollViewer>
      </Grid>
    </DataTemplate>

    <!-- ── Mobs ───────────────────────────────────────────────────────────── -->
    <!-- Creatures in the room, one per line (issue #86). Sourced from the
         engine's ignore-filtered Creatures list, so ground items don't show.
         The gear button opens the ignore-list editor (the server bolds
         familiars/pets identically to hostile creatures, so filtering them is
         the user's call): one regex alternative per row, right-click a mob to
         ignore it exactly. Edits persist to settings.cfg via the same
         mechanism as `#config monstercountignorelist` and re-filter the list
         immediately. -->
    <DataTemplate DataType="docking:MobsTool">
      <Grid RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="8,6,8,2">
          <TextBlock Grid.Column="0" FontSize="10" VerticalAlignment="Center"
                     Foreground="{DynamicResource Theme.SectionHeader}" FontWeight="SemiBold"
                     Text="{Binding ViewModel.Count, StringFormat='MOBS ({0})'}"/>
          <ToggleButton Grid.Column="1" Content="⚙" FontSize="11"
                        Padding="4,0" MinHeight="0" MinWidth="0"
                        Background="Transparent" BorderThickness="0" Foreground="{DynamicResource Theme.SectionHeader}"
                        IsChecked="{Binding ViewModel.IsEditingIgnores}"
                        AutomationProperties.Name="Edit ignore list"
                        AutomationProperties.HelpText="Edit the ignore list (hide familiars, pets, …)"
                        ToolTip.Tip="Edit the ignore list (hide familiars, pets, …)"/>
        </Grid>
        <ScrollViewer Grid.Row="1">
          <StackPanel Margin="8,2,8,8">
            <TextBlock Text="No creatures here." Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"
                       IsVisible="{Binding ViewModel.IsEmpty}"/>
            <ItemsControl ItemsSource="{Binding ViewModel.Mobs}"
                          IsVisible="{Binding !ViewModel.IsEmpty}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:MobItem">
                  <SelectableTextBlock Text="{Binding Text}" Foreground="{DynamicResource Theme.Warning}"
                                       FontSize="12" TextWrapping="Wrap" Margin="0,1">
                    <SelectableTextBlock.ContextMenu>
                      <ContextMenu>
                        <MenuItem Header="Ignore this creature"
                                  Command="{Binding IgnoreCommand}"
                                  ToolTip.Tip="Adds the exact phrase to the ignore list"/>
                      </ContextMenu>
                    </SelectableTextBlock.ContextMenu>
                  </SelectableTextBlock>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="2" IsVisible="{Binding ViewModel.IsEditingIgnores}"
                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0"
                Background="{DynamicResource Theme.PanelBg}" Padding="8,6">
          <StackPanel Spacing="4">
            <TextBlock Text="IGNORE LIST" FontSize="10"
                       Foreground="{DynamicResource Theme.SectionHeader}" FontWeight="SemiBold"/>
            <TextBlock FontSize="10" Foreground="{DynamicResource Theme.TextMuted}" TextWrapping="Wrap"
                       Text="Creatures matching any pattern are hidden here and excluded from $monstercount. Patterns are case-insensitive regexes — right-click a mob above to ignore it exactly."/>
            <ItemsControl ItemsSource="{Binding ViewModel.IgnorePatterns}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:IgnorePatternItem">
                  <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                    <SelectableTextBlock Grid.Column="0" Text="{Binding Pattern}"
                                         FontSize="11" Foreground="{DynamicResource Theme.TextSecondary}"
                                         TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="✕" FontSize="10"
                            Padding="4,0" MinHeight="0" MinWidth="0"
                            Background="Transparent" BorderThickness="0" Foreground="{DynamicResource Theme.Danger}"
                            AutomationProperties.Name="Remove pattern"
                            AutomationProperties.HelpText="Remove this pattern"
                            Command="{Binding RemoveCommand}"
                            ToolTip.Tip="Remove this pattern"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Grid.Column="0" Text="{Binding ViewModel.NewPattern}"
                       Watermark="Add pattern…" FontSize="11" MinHeight="0" Padding="6,3">
                <TextBox.KeyBindings>
                  <KeyBinding Gesture="Enter" Command="{Binding ViewModel.AddPatternCommand}"/>
                </TextBox.KeyBindings>
              </TextBox>
              <Button Grid.Column="1" Content="Add" Margin="4,0,0,0"
                      FontSize="11" MinHeight="0" Padding="8,3"
                      Command="{Binding ViewModel.AddPatternCommand}"/>
            </Grid>
            <TextBlock Text="{Binding ViewModel.EditorError}" FontSize="10"
                       Foreground="{DynamicResource Theme.Danger}" TextWrapping="Wrap"
                       IsVisible="{Binding ViewModel.EditorError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <Button Content="Restore defaults" FontSize="10" MinHeight="0" Padding="6,2"
                    HorizontalAlignment="Left"
                    Command="{Binding ViewModel.RestoreDefaultsCommand}"
                    ToolTip.Tip="Reset to the Genie 4 default: appears dead|(dead)"/>
          </StackPanel>
        </Border>
      </Grid>
    </DataTemplate>

    <!-- ── Players ──────────────────────────────────────────────────────────── -->
    <!-- Other players in the room, one per line (issue #86). Parsed best-effort
         from DR's "Also here: …" room-players line. -->
    <DataTemplate DataType="docking:PlayersTool">
      <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0" Margin="8,6,8,2" FontSize="10"
                   Foreground="{DynamicResource Theme.SectionHeader}" FontWeight="SemiBold"
                   Text="{Binding ViewModel.Count, StringFormat='PLAYERS ({0})'}"/>
        <ScrollViewer Grid.Row="1">
          <StackPanel Margin="8,2,8,8">
            <TextBlock Text="No other players here." Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"
                       IsVisible="{Binding ViewModel.IsEmpty}"/>
            <ItemsControl ItemsSource="{Binding ViewModel.Players}"
                          IsVisible="{Binding !ViewModel.IsEmpty}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="x:String">
                  <SelectableTextBlock Text="{Binding}" Foreground="{DynamicResource Theme.Success}"
                                       FontSize="12" TextWrapping="Wrap" Margin="0,1"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </DataTemplate>

    <!-- ── Injuries ─────────────────────────────────────────────────────── -->
    <!-- Body-part sprite display (issue #18), fed by the server's injuries
         dialog. Each of the 16 regions renders its Assets/Injuries sprite in
         a colour variant baked by InjurySprites (natural ivory ghosted =
         healthy, yellow→orange→red = wound 1–3, steel blue = scar, purple =
         nerve damage); the list below repeats every reading in words, so
         colour is never the only carrier. Two layouts, toggled by the
         Figure-layout checkbox (persisted as #config injurieslayout):
           grid   — 4×4 part cells, same idea as Wrayth's injuries dialog;
                    RIGHT-side parts lead their pair (doll convention).
           figure — the parts assembled into a front-facing body, back +
                    nervous system beside it (rear/internal views). Canvas
                    coordinates come from the assembly worked out in the
                    sprite-sheet slicing pass; element order IS the stacking
                    order: legs → feet → abdomen → chest → arms → hands →
                    gorget → head → eyes. Arm/leg sprites are cropped at the
                    wrist/ankle (InjuryCell.FigureSprite) because they carry
                    built-in hands/feet that the dedicated parts replace. -->
    <DataTemplate DataType="docking:InjuriesTool">
      <ScrollViewer>
        <StackPanel Spacing="6" Margin="8">
          <TextBlock FontSize="10" Foreground="{DynamicResource Theme.SectionHeader}" FontWeight="SemiBold"
                     Text="{Binding ViewModel.Count, StringFormat='INJURIES ({0})'}"/>
          <ItemsControl ItemsSource="{Binding ViewModel.Cells}" MaxWidth="248" HorizontalAlignment="Left"
                        IsVisible="{Binding !ViewModel.FigureLayout}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="4"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:InjuriesViewModel+InjuryCell">
                <!-- transparent Background so the whole cell hit-tests for the tooltip -->
                <StackPanel Margin="2,3" Spacing="2" Background="Transparent" ToolTip.Tip="{Binding Tip}">
                  <Image Source="{Binding Sprite}" Height="52" Stretch="Uniform"
                         Opacity="{Binding SpriteOpacity}"/>
                  <TextBlock Text="{Binding Label}" FontSize="9" HorizontalAlignment="Center"
                             Foreground="{Binding Foreground}"/>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Viewbox MaxWidth="260" MaxHeight="330" Stretch="Uniform" HorizontalAlignment="Left"
                   IsVisible="{Binding ViewModel.FigureLayout}">
            <Canvas Width="920" Height="1125">
              <Image Canvas.Left="194" Canvas.Top="645" Width="127" Height="365" Stretch="Uniform"
                     Source="{Binding ViewModel.RightLeg.FigureSprite}" Opacity="{Binding ViewModel.RightLeg.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.RightLeg.Tip}"/>
              <Image Canvas.Left="318" Canvas.Top="645" Width="127" Height="365" Stretch="Uniform"
                     Source="{Binding ViewModel.LeftLeg.FigureSprite}" Opacity="{Binding ViewModel.LeftLeg.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.LeftLeg.Tip}"/>
              <!-- ankle cuffs sit over the legs' crop line -->
              <Image Canvas.Left="141" Canvas.Top="972" Width="134" Height="145" Stretch="Uniform"
                     Source="{Binding ViewModel.RightFoot.FigureSprite}" Opacity="{Binding ViewModel.RightFoot.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.RightFoot.Tip}"/>
              <Image Canvas.Left="365" Canvas.Top="972" Width="131" Height="145" Stretch="Uniform"
                     Source="{Binding ViewModel.LeftFoot.FigureSprite}" Opacity="{Binding ViewModel.LeftFoot.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.LeftFoot.Tip}"/>
              <Image Canvas.Left="226" Canvas.Top="455" Width="189" Height="220" Stretch="Uniform"
                     Source="{Binding ViewModel.Abdomen.FigureSprite}" Opacity="{Binding ViewModel.Abdomen.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.Abdomen.Tip}"/>
              <Image Canvas.Left="191" Canvas.Top="225" Width="258" Height="280" Stretch="Uniform"
                     Source="{Binding ViewModel.Chest.FigureSprite}" Opacity="{Binding ViewModel.Chest.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.Chest.Tip}"/>
              <!-- pauldrons over the chest's shoulder line -->
              <Image Canvas.Left="130" Canvas.Top="235" Width="116" Height="260" Stretch="Uniform"
                     Source="{Binding ViewModel.RightArm.FigureSprite}" Opacity="{Binding ViewModel.RightArm.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.RightArm.Tip}"/>
              <Image Canvas.Left="395" Canvas.Top="235" Width="114" Height="260" Stretch="Uniform"
                     Source="{Binding ViewModel.LeftArm.FigureSprite}" Opacity="{Binding ViewModel.LeftArm.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.LeftArm.Tip}"/>
              <Image Canvas.Left="132" Canvas.Top="477" Width="89" Height="150" Stretch="Uniform"
                     Source="{Binding ViewModel.RightHand.FigureSprite}" Opacity="{Binding ViewModel.RightHand.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.RightHand.Tip}"/>
              <Image Canvas.Left="414" Canvas.Top="477" Width="88" Height="150" Stretch="Uniform"
                     Source="{Binding ViewModel.LeftHand.FigureSprite}" Opacity="{Binding ViewModel.LeftHand.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.LeftHand.Tip}"/>
              <!-- gorget flares wider than the head's neck; head over its collar -->
              <Image Canvas.Left="229" Canvas.Top="185" Width="182" Height="170" Stretch="Uniform"
                     Source="{Binding ViewModel.Neck.FigureSprite}" Opacity="{Binding ViewModel.Neck.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.Neck.Tip}"/>
              <Image Canvas.Left="242" Canvas.Top="48" Width="155" Height="240" Stretch="Uniform"
                     Source="{Binding ViewModel.Head.FigureSprite}" Opacity="{Binding ViewModel.Head.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.Head.Tip}"/>
              <Image Canvas.Left="270" Canvas.Top="131" Width="49" Height="34" Stretch="Uniform"
                     Source="{Binding ViewModel.RightEye.FigureSprite}" Opacity="{Binding ViewModel.RightEye.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.RightEye.Tip}"/>
              <Image Canvas.Left="322" Canvas.Top="131" Width="48" Height="34" Stretch="Uniform"
                     Source="{Binding ViewModel.LeftEye.FigureSprite}" Opacity="{Binding ViewModel.LeftEye.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.LeftEye.Tip}"/>
              <!-- rear / internal views beside the figure -->
              <Image Canvas.Left="650" Canvas.Top="120" Width="260" Height="280" Stretch="Uniform"
                     Source="{Binding ViewModel.Back.FigureSprite}" Opacity="{Binding ViewModel.Back.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.Back.Tip}"/>
              <TextBlock Canvas.Left="748" Canvas.Top="408" Text="Back" FontSize="30"
                         Foreground="{Binding ViewModel.Back.Foreground}"/>
              <Image Canvas.Left="685" Canvas.Top="520" Width="190" Height="300" Stretch="Uniform"
                     Source="{Binding ViewModel.Nsys.FigureSprite}" Opacity="{Binding ViewModel.Nsys.SpriteOpacity}" ToolTip.Tip="{Binding ViewModel.Nsys.Tip}"/>
              <TextBlock Canvas.Left="730" Canvas.Top="828" Text="Nerves" FontSize="30"
                         Foreground="{Binding ViewModel.Nsys.Foreground}"/>
            </Canvas>
          </Viewbox>
          <CheckBox Content="Figure layout" FontSize="10" MinHeight="0" Padding="4,0"
                    IsChecked="{Binding ViewModel.FigureLayout}"
                    ToolTip.Tip="Show the body parts assembled into a figure instead of the 4×4 grid. Same setting as #config injurieslayout figure|grid."/>
          <!-- opt-in silent `health` poll cadence (#config injuriespoll) — the
               only way to tell nerve wound from nerve scar. Off by default. -->
          <StackPanel Orientation="Horizontal" Spacing="6"
                      ToolTip.Tip="Silently sends 'health' on this cadence to refine the nerve reading (wound vs scar) — the injuries dialog alone can't tell. Off by default; the response never shows in the game window, and polling pauses whenever this panel is closed. Same setting as #config injuriespoll.">
            <TextBlock Text="Auto-refresh" FontSize="10" Foreground="{DynamicResource Theme.TextSecondary}" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding ViewModel.RefreshOptions}"
                      SelectedIndex="{Binding ViewModel.RefreshIndex}"
                      FontSize="10" MinWidth="72" Padding="6,2"/>
          </StackPanel>
          <TextBlock Text="No injuries." Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"
                     IsVisible="{Binding ViewModel.IsEmpty}"/>
          <ItemsControl ItemsSource="{Binding ViewModel.Injured}"
                        IsVisible="{Binding !ViewModel.IsEmpty}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="x:String">
                <SelectableTextBlock Text="{Binding}" Foreground="#d0a0a0"
                                     FontSize="11" TextWrapping="Wrap" Margin="0,1"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </DataTemplate>

    <!-- ── Scene ─────────────────────────────────────────────────────────── -->
    <!-- DR room/scene artwork (the <resource picture> image). Empty for rooms
         without art (most), so a placeholder fills the panel until one loads. -->
    <DataTemplate DataType="docking:SceneTool">
      <Grid Margin="6">
        <TextBlock Text="No scene image for this room."
                   Foreground="{DynamicResource Theme.TextMuted}" FontSize="11" TextWrapping="Wrap"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsVisible="{Binding !ViewModel.HasImage}"/>
        <Image Source="{Binding ViewModel.Image}" Stretch="Uniform"
               IsVisible="{Binding ViewModel.HasImage}"/>
      </Grid>
    </DataTemplate>

    <!-- ── Mapper ────────────────────────────────────────────────────────── -->
    <!-- Map-dominant layout:                                                 -->
    <!--   row 0: thin toolbar (zone + level + zoom + pop-out)                -->
    <!--   row 1: 2-column split — map on left, Details panel on right        -->
    <!--          (separated by a draggable splitter so users can resize or   -->
    <!--          drag the Details column all the way closed)                 -->
    <!--   row 2: status strip (current room title + exits) — compact, spans  -->
    <!--          both columns                                                -->
    <DataTemplate DataType="docking:MapperTool">
      <Grid RowDefinitions="Auto,*,Auto" Margin="0">

        <!-- ── ROW 0: toolbar ────────────────────────────────────────── -->
        <!-- Pop-out button sits LEFT of the zone dropdown so it's clearly  -->
        <!-- a window-level action (move the panel) rather than a map-data -->
        <!-- action (zone / level / zoom). Keeping it in the right-side    -->
        <!-- cluster put it next to "zoom in" which made it easy to click  -->
        <!-- by accident while intending a zoom action.                    -->
        <Border Grid.Row="0" Background="{DynamicResource Theme.ToolbarBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,0,0,1" Padding="4,3">
          <StackPanel Spacing="3">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="4">
            <!-- Pop out (window-level action, separated from data-level cluster) -->
            <Button Grid.Column="0" Content="⬈" Padding="6,1" FontSize="11"
                    AutomationProperties.Name="Pop out mapper"
                    AutomationProperties.HelpText="Pop out to a separate window"
                    Command="{Binding ViewModel.FloatCommand}"
                    ToolTip.Tip="Pop out to a separate window"/>
            <!-- Zone selector — takes available width -->
            <ComboBox Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      ItemsSource="{Binding ViewModel.AvailableZones}"
                      SelectedItem="{Binding ViewModel.SelectedZoneFile}"
                      PlaceholderText="(pick a zone)"
                      MinHeight="24"
                      ToolTip.Tip="Pick a zone XML from the Maps directory. Auto-detect normally handles this for you when you connect and walk."/>
            <!-- Level -->
            <TextBlock Grid.Column="2" Text="{Binding ViewModel.Level, StringFormat='L{0}'}"
                       Foreground="{DynamicResource Theme.TextPrimary}" VerticalAlignment="Center" FontSize="11"/>
            <Button Grid.Column="3" Content="▲" Padding="6,1" FontSize="10"
                    AutomationProperties.Name="Z-level up"
                    Command="{Binding ViewModel.LevelUpCommand}"
                    ToolTip.Tip="Z-level up"/>
            <Button Grid.Column="4" Content="▼" Padding="6,1" FontSize="10"
                    AutomationProperties.Name="Z-level down"
                    Command="{Binding ViewModel.LevelDownCommand}"
                    ToolTip.Tip="Z-level down"/>
            <!-- Zoom -->
            <Button Grid.Column="5" Content="−" Padding="8,1" FontSize="11"
                    AutomationProperties.Name="Zoom out"
                    AutomationProperties.HelpText="Zoom out (or mouse-wheel down over the map)"
                    Command="{Binding ViewModel.ZoomOutCommand}"
                    ToolTip.Tip="Zoom out (or mouse-wheel down over the map)"/>
            <Button Grid.Column="6" Content="+" Padding="8,1" FontSize="11"
                    AutomationProperties.Name="Zoom in"
                    AutomationProperties.HelpText="Zoom in (or mouse-wheel up over the map)"
                    Command="{Binding ViewModel.ZoomInCommand}"
                    ToolTip.Tip="Zoom in (or mouse-wheel up over the map)"/>
          </Grid>

          <!-- Editor toolbar (Genie 4 AutoMapper edit tools). Edit + Record + -->
          <!-- New + Save are always available; the node-edit cluster (Remove / -->
          <!-- Reset IDs / Snap / Lock / Dup) only shows in Edit mode.          -->
          <WrapPanel Orientation="Horizontal">
            <ToggleButton Content="✎ Edit" IsChecked="{Binding ViewModel.EditMode}"
                          Margin="0,0,4,0" Padding="6,1" FontSize="11"
                          ToolTip.Tip="Edit mode: click a room to select it, drag to move it. Turn off to navigate (click = nothing, right-click = Go Here)."/>
            <ToggleButton Content="⏺ Record" IsChecked="{Binding ViewModel.AutoCreateEnabled}"
                          Margin="0,0,4,0" Padding="6,1" FontSize="11"
                          ToolTip.Tip="Record mode: add new rooms to the active zone as you walk into them (Genie 4 Record Mode)."/>
            <Button Content="New" Command="{Binding ViewModel.NewZoneCommand}"
                    Margin="0,0,4,0" Padding="6,1" FontSize="11"
                    ToolTip.Tip="Start a new, empty zone. Save writes it to the Maps directory."/>
            <Button Command="{Binding ViewModel.SaveMapCommand}"
                    Margin="0,0,8,0" Padding="6,1" FontSize="11"
                    AutomationProperties.Name="Save zone"
                    AutomationProperties.HelpText="Save the active zone to its XML file (Genie 4 compatible)."
                    ToolTip.Tip="Save the active zone to its XML file (Genie 4 compatible).">
              <StackPanel Orientation="Horizontal" Spacing="3">
                <TextBlock Text="Save"/>
                <TextBlock Text="●" Foreground="{DynamicResource Theme.Warning}"
                           IsVisible="{Binding ViewModel.IsZoneDirty}"
                           ToolTip.Tip="Unsaved edits"/>
              </StackPanel>
            </Button>
            <ToggleButton Content="Labels" IsChecked="{Binding ViewModel.FullLabels}"
                          Margin="8,0,0,0" Padding="6,1" FontSize="11"
                          ToolTip.Tip="OFF: show only each room's primary name. ON: show the full |-separated label list. Labels auto-place around rooms and skip when crowded; the full set is always in the hover tooltip."/>

            <!-- Edit-only cluster -->
            <StackPanel Orientation="Horizontal" Spacing="4"
                        IsVisible="{Binding ViewModel.EditMode}">
              <Button Content="Remove" Command="{Binding ViewModel.RemoveSelectedCommand}"
                      Padding="6,1" FontSize="11" Background="{DynamicResource Theme.DangerBg}" Foreground="{DynamicResource Theme.Danger}"
                      ToolTip.Tip="Delete the selected room (or press Delete on the map)."/>
              <Button Content="Reset IDs" Command="{Binding ViewModel.ResetMapIdsCommand}"
                      Padding="6,1" FontSize="11"
                      ToolTip.Tip="Renumber all room IDs to a dense 1..N sequence (fixes sparse ids after lots of add/remove)."/>
              <ToggleButton Content="Snap" IsChecked="{Binding ViewModel.SnapToGrid}"
                            Padding="6,1" FontSize="11"
                            ToolTip.Tip="Snap dragged rooms to the grid. Genie 5 maps are grid-based, so positions always align."/>
              <ToggleButton Content="Lock" IsChecked="{Binding ViewModel.LockPositions}"
                            Padding="6,1" FontSize="11"
                            ToolTip.Tip="Lock positions: rooms can be selected but not dragged."/>
              <ToggleButton Content="Dup" IsChecked="{Binding ViewModel.AllowDuplicate}"
                            Padding="6,1" FontSize="11"
                            ToolTip.Tip="Allow duplicate rooms while recording — don't merge a new room into an existing one that merely looks the same."/>
            </StackPanel>
          </WrapPanel>
          </StackPanel>
        </Border>

        <!-- ── ROW 1: map + auto-hiding Details flyout ───────────────── -->
        <!-- Single overlay cell: the map fills the row (less a thin strip  -->
        <!-- reserved on the right), and the Details panel is an auto-hiding -->
        <!-- flyout pinned to the right edge. Collapsed it shows a vertical  -->
        <!-- "DETAILS" strip; hovering the strip (or the open panel) slides  -->
        <!-- the full panel out OVER the map, and moving the pointer away    -->
        <!-- auto-hides it again. The pin button in the header keeps it open -->
        <!-- (ViewModel.DetailsPinned). -->
        <Grid Grid.Row="1">

          <!-- Map — background lives on the MapCanvas itself
               (user-customisable); leave the Border transparent so the
               chosen colour bleeds to the scroll viewport edges.
               The auto-walk indicator overlays the top of the column when a
               walk is active; visibility is gated on AutoWalk.Current.
               Right margin (24) reserves room for the always-present
               collapsed Details strip so it never covers the map scrollbar. -->
          <Grid RowDefinitions="Auto,Auto,*" Margin="0,0,24,0">
            <!-- Skills prompt — visible when a zone is loaded but we have
                 no skill data yet AND the user hasn't dismissed-forever.
                 Sits at the very top so it's visible before the user
                 clicks anything; auto-hides on Fetch / Skip / first
                 skill rank arriving from the parser. -->
            <Border Grid.Row="0"
                    IsVisible="{Binding ViewModel.ShowSkillsPrompt}"
                    Background="#2a3a1a" BorderBrush="#5a7a3a" BorderThickness="0,0,0,1"
                    Padding="8,5">
              <StackPanel Orientation="Vertical" Spacing="4">
                <TextBlock Text="ℹ Pathfinding uses your skill ranks"
                           Foreground="{DynamicResource Theme.TextPrimary}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource Theme.TextSecondary}" FontSize="11"
                           Text="The mapper filters out climbs/swims/etc you can't take. Genie 5 needs to read your `info` and `exp all` once to know your guild, circle, and skill ranks — otherwise every gated exit is assumed reachable."/>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,3,0,0">
                  <Button Content="Fetch skills now" FontSize="11" Padding="8,2"
                          Background="{DynamicResource Theme.SuccessBg}" Foreground="{DynamicResource Theme.TextPrimary}"
                          Command="{Binding ViewModel.FetchSkillsCommand}"
                          ToolTip.Tip="Sends `info` and `exp all` to the game now. The replies prime the pathfinder's guild, circle, and skill tables."/>
                  <Button Content="Skip" FontSize="11" Padding="8,2"
                          Command="{Binding ViewModel.DismissSkillsPromptCommand}"
                          ToolTip.Tip="Dismiss for this session — will prompt again next launch."/>
                  <Button Content="Don't ask again" FontSize="11" Padding="8,2"
                          Foreground="{DynamicResource Theme.TextSecondary}"
                          Command="{Binding ViewModel.DontAskAboutSkillsCommand}"
                          ToolTip.Tip="Hide this prompt permanently. Pathfinder will still work but exits gated by skills you actually lack may not error until you try to walk them."/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- AutoWalk indicator — appears at the top of the map when a
                 walk is in flight. Shows current progress, lets the user
                 see what's happening, and gives an explicit Cancel button.
                 Auto-hides when no session is active. Includes the boat-
                 wait countdown bar inline when a cross-zone hop is mid-
                 transit (matches the spell-cast bar visual pattern from
                 the Hands Strip — magenta draining bar). -->
            <Border Grid.Row="1"
                    IsVisible="{Binding ViewModel.AutoWalk.Current, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Background="#1a3344" BorderBrush="#3a6688" BorderThickness="0,0,0,1"
                    Padding="8,4">
              <StackPanel Spacing="4">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                              VerticalAlignment="Center">
                    <TextBlock Text="⚡" Foreground="#8ad8e8" FontSize="13"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ViewModel.AutoWalk.CurrentStatus}"
                               Foreground="{DynamicResource Theme.TextPrimary}" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <!-- Resume only visible while paused -->
                    <Button Content="Resume" FontSize="11" Padding="6,2"
                            IsVisible="{Binding ViewModel.AutoWalk.IsCurrentPaused}"
                            Command="{Binding ViewModel.AutoWalk.ResumeCommand}"/>
                    <Button Content="Cancel" FontSize="11" Padding="6,2"
                            Background="{DynamicResource Theme.DangerBg}" Foreground="{DynamicResource Theme.Danger}"
                            Command="{Binding ViewModel.AutoWalk.CancelCommand}"
                            ToolTip.Tip="Stop the current walk (Esc also cancels)"/>
                  </StackPanel>
                </Grid>

                <!-- Boat-wait countdown — visible only during a cross-zone
                     transit with a known wait window. Magenta to match the
                     spell-cast bar pattern from the Hands Strip. Bar drains
                     from full → empty over the expected wait; when 0 it
                     pegs and the walker keeps listening for the room
                     change (the actual ETA is fingerprint-driven). -->
                <Grid ColumnDefinitions="*,Auto"
                      IsVisible="{Binding ViewModel.AutoWalk.IsWaitingForCrossZone}">
                  <ProgressBar Grid.Column="0"
                               Value="{Binding ViewModel.AutoWalk.CurrentWaitSecondsLeft}"
                               Maximum="{Binding ViewModel.AutoWalk.CurrentWaitTotalSeconds}"
                               Minimum="0"
                               Foreground="#d066c8"
                               Background="#3a1a3a"
                               Height="14"
                               VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Margin="8,0,0,0"
                             VerticalAlignment="Center"
                             Foreground="#e0c0e8" FontSize="11"
                             FontFamily="Consolas,Courier New,monospace">
                    <Run Text="{Binding ViewModel.AutoWalk.CurrentWaitLabel}"/><Run Text=" · "/><Run Text="{Binding ViewModel.AutoWalk.CurrentWaitDisplay}"/>
                  </TextBlock>
                </Grid>
              </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="{Binding ViewModel.MapBackgroundBrush}">
              <ScrollViewer HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                <controls:MapCanvas Zone="{Binding ViewModel.ActiveZone}"
                                    CurrentNode="{Binding ViewModel.ActiveNode}"
                                    Level="{Binding ViewModel.Level}"
                                    RenderTick="{Binding ViewModel.RenderTick}"
                                    Zoom="{Binding ViewModel.ZoomLevel}"
                                    MapBackgroundBrush="{Binding ViewModel.MapBackgroundBrush}"
                                    LabelTextBrush="{Binding ViewModel.MapTextBrush}"
                                    AutoMapperAlpha="{Binding ViewModel.AutoMapperAlpha}"
                                    ShowLegend="{Binding ViewModel.ShowMapLegend}"
                                    NodeClickedCommand="{Binding ViewModel.GotoNodeCommand}"
                                    EditExitCommand="{Binding ViewModel.EditExitCommand}"
                                    EditMode="{Binding ViewModel.EditMode}"
                                    SnapToGrid="{Binding ViewModel.SnapToGrid}"
                                    LockPositions="{Binding ViewModel.LockPositions}"
                                    FullLabels="{Binding ViewModel.FullLabels}"
                                    SelectedNode="{Binding ViewModel.SelectedNode, Mode=TwoWay}"
                                    NodeMovedCommand="{Binding ViewModel.NodeMovedCommand}"
                                    RemoveNodeCommand="{Binding ViewModel.RemoveNodeCommand}"/>
              </ScrollViewer>
            </Border>
          </Grid>

          <!-- Auto-hiding Details flyout — pinned right, drawn OVER the    -->
          <!-- map (last child of the single-cell row). `DetailsFlyout` is   -->
          <!-- the hover host: its IsPointerOver, OR ViewModel.DetailsPinned, -->
          <!-- decides which child shows. Both the strip and the open panel  -->
          <!-- are children of this one host, so moving between them never   -->
          <!-- drops the hover — no open/close flicker. -->
          <Border x:Name="DetailsFlyout"
                  HorizontalAlignment="Right" VerticalAlignment="Stretch">
            <Grid>

              <!-- Collapsed strip — shown whenever the panel is hidden. -->
              <Border x:Name="DetailsStrip" Width="24"
                      Background="{DynamicResource Theme.PanelBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1,0,0,0"
                      IsVisible="{Binding !#DetailsPanel.IsVisible}"
                      ToolTip.Tip="Hover to open the Details panel; use the pin inside to keep it open.">
                <TextBlock Text="DETAILS" Foreground="{DynamicResource Theme.SectionHeader}" FontSize="10"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           RenderTransformOrigin="50%,50%">
                  <TextBlock.RenderTransform>
                    <RotateTransform Angle="-90"/>
                  </TextBlock.RenderTransform>
                </TextBlock>
              </Border>

              <!-- Expanded panel — visible while hovered or pinned. Wrapped  -->
              <!-- in a ScrollViewer so the content scrolls if the panel is   -->
              <!-- short / the user adds long Notes text. -->
              <Border x:Name="DetailsPanel" Width="260"
                      Background="{DynamicResource Theme.PanelBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1,0,0,0">
                <Border.IsVisible>
                  <MultiBinding Converter="{x:Static controls:BoolOrConverter.Instance}">
                    <Binding Path="#DetailsFlyout.IsPointerOver"/>
                    <Binding Path="ViewModel.DetailsPinned"/>
                  </MultiBinding>
                </Border.IsVisible>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              Padding="6,4">
              <StackPanel Spacing="10">

                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="DETAILS" Foreground="{DynamicResource Theme.TextPrimary}" FontSize="11"
                             FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <ToggleButton Grid.Column="1" Content="📌"
                                IsChecked="{Binding ViewModel.DetailsPinned}"
                                FontSize="11" Padding="5,0" MinHeight="0"
                                AutomationProperties.Name="Pin details panel"
                                AutomationProperties.HelpText="Pin the Details panel open. When unpinned, it auto-hides to a strip when the pointer leaves."
                                ToolTip.Tip="Pin the Details panel open. When unpinned, it auto-hides to a strip when the pointer leaves."/>
                </Grid>

                <!-- ── Current Room ─────────────────────────────────── -->
                <StackPanel Spacing="3">
                  <TextBlock Text="CURRENT ROOM" Foreground="{DynamicResource Theme.SectionHeader}" FontSize="9"
                             FontWeight="SemiBold" Margin="0,0,0,2"/>
                  <Grid ColumnDefinitions="60,*"
                        IsVisible="{Binding ViewModel.CurrentServerId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Grid.Column="0" Text="Server id" Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"/>
                    <SelectableTextBlock Grid.Column="1" Text="{Binding ViewModel.CurrentServerId}"
                                         Foreground="{DynamicResource Theme.TextPrimary}" FontSize="11" FontFamily="Consolas,monospace"
                                         TextWrapping="Wrap"/>
                  </Grid>
                  <TextBlock Text="Notes" Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"/>
                  <TextBox  Text="{Binding ViewModel.CurrentNotes}"
                            FontSize="11" MinHeight="60" MaxHeight="120"
                            AcceptsReturn="True" TextWrapping="Wrap"
                            Watermark="e.g. Pawnshop, Empath's Guild, Bank teller"
                            ToolTip.Tip="Short label for this room — shown as text next to the dot on the map canvas. Pick the gameplay-meaningful name (vendor / NPC role / dungeon entry / etc.)."/>
                  <Button Content="Save Notes" Padding="8,2" FontSize="11"
                          HorizontalAlignment="Right"
                          Command="{Binding ViewModel.SaveNotesCommand}"
                          ToolTip.Tip="Save the edited Notes back to the zone XML file. Updates immediately on disk and on the map."/>
                </StackPanel>

                <!-- ── Edit Room (edit mode only) ───────────────────── -->
                <!-- Genie 4 AutoMapper "Edit Panel": properties of the      -->
                <!-- selected node. Title/server-id feed the lookup index,   -->
                <!-- so Apply rebuilds it; Color is a hex like #FFAA00.      -->
                <StackPanel Spacing="3" IsVisible="{Binding ViewModel.EditMode}">
                  <TextBlock Text="EDIT ROOM" Foreground="{DynamicResource Theme.SectionHeader}" FontSize="9"
                             FontWeight="SemiBold" Margin="0,0,0,2"/>
                  <TextBlock Text="Click a room on the map to select it."
                             Foreground="{DynamicResource Theme.TextMuted}" FontSize="11" TextWrapping="Wrap"
                             IsVisible="{Binding ViewModel.SelectedNode, Converter={x:Static ObjectConverters.IsNull}}"/>
                  <StackPanel Spacing="3"
                              IsVisible="{Binding ViewModel.SelectedNode, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="Title" Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"/>
                    <TextBox Text="{Binding ViewModel.SelNodeTitle}" FontSize="11"/>
                    <TextBlock Text="Notes / label" Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"/>
                    <TextBox Text="{Binding ViewModel.SelNodeNotes}" FontSize="11"
                             Watermark="e.g. Bank|Teller (| separates #goto labels)"/>
                    <TextBlock Text="Color (hex)" Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"/>
                    <TextBox Text="{Binding ViewModel.SelNodeColor}" FontSize="11"
                             FontFamily="Consolas,monospace" Watermark="#FFAA00"/>
                    <TextBlock Text="Server id" Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"/>
                    <TextBox Text="{Binding ViewModel.SelNodeServerId}" FontSize="11"
                             FontFamily="Consolas,monospace"/>
                    <Button Content="Apply" Padding="8,2" FontSize="11"
                            HorizontalAlignment="Right"
                            Command="{Binding ViewModel.ApplyNodePropsCommand}"
                            ToolTip.Tip="Write these fields back into the room. Save the zone to persist to disk."/>
                  </StackPanel>
                </StackPanel>

                <!-- ── Zone ─────────────────────────────────────────── -->
                <StackPanel Spacing="3">
                  <TextBlock Text="ZONE" Foreground="{DynamicResource Theme.SectionHeader}" FontSize="9"
                             FontWeight="SemiBold" Margin="0,0,0,2"/>
                  <Grid ColumnDefinitions="60,*">
                    <TextBlock Grid.Column="0" Text="Rooms"      Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"/>
                    <TextBlock Grid.Column="1" Text="{Binding ViewModel.RoomCount}" Foreground="{DynamicResource Theme.TextPrimary}" FontSize="11"/>
                  </Grid>
                  <Grid ColumnDefinitions="60,*"
                        IsVisible="{Binding ViewModel.ZoneAgeDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Grid.Column="0" Text="Updated" Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding ViewModel.ZoneAgeDisplay}"
                                 Foreground="{DynamicResource Theme.TextPrimary}" FontSize="11" VerticalAlignment="Center"/>
                      <Border Background="{DynamicResource Theme.WarningBg}" CornerRadius="2" Padding="4,1"
                              VerticalAlignment="Center"
                              IsVisible="{Binding ViewModel.IsZoneStale}"
                              ToolTip.Tip="This zone hasn't been updated in over a month. The community Maps repo may have newer data — try File → Update Maps from Official Repo.">
                        <TextBlock Text="may be stale" Foreground="{DynamicResource Theme.Warning}" FontSize="9" FontWeight="SemiBold"/>
                      </Border>
                    </StackPanel>
                  </Grid>
                  <TextBlock Text="{Binding ViewModel.MapsDirectory, StringFormat='Maps: {0}'}"
                             Foreground="{DynamicResource Theme.TextMuted}" FontSize="10" TextWrapping="Wrap"/>
                  <Border Background="{DynamicResource Theme.SuccessBg}" CornerRadius="2" Padding="4,1"
                          HorizontalAlignment="Left"
                          IsVisible="{Binding ViewModel.IsGitManaged}"
                          ToolTip.Tip="This directory is a git working copy. Use your preferred git client to pull / commit / push / open pull requests — Genie does not run git itself.">
                    <TextBlock Text="git-managed" Foreground="{DynamicResource Theme.Success}" FontSize="9" FontWeight="SemiBold"/>
                  </Border>
                </StackPanel>

                <!-- ── Behavior + Appearance ────────────────────────── -->
                <StackPanel Spacing="3">
                  <TextBlock Text="BEHAVIOR" Foreground="{DynamicResource Theme.SectionHeader}" FontSize="9"
                             FontWeight="SemiBold" Margin="0,0,0,2"/>
                  <CheckBox Content="Auto-create new rooms"
                            IsChecked="{Binding ViewModel.AutoCreateEnabled}"
                            FontSize="11"
                            ToolTip.Tip="When ON, walking into an unmapped room adds a new node to the active zone. When OFF, the mapper only matches against existing zone data."/>
                  <TextBlock Text="Map background:" Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"/>
                  <ColorPicker Color="{Binding ViewModel.MapBackground, Mode=TwoWay}"
                               IsAlphaEnabled="False"
                               HorizontalAlignment="Left"
                               ToolTip.Tip="Pick any colour for the map canvas. Cream/tan (e.g. #F5EFD8) matches the Genie 4 AutoMapper look."/>
                  <TextBlock Text="Map text:" Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"/>
                  <ColorPicker Color="{Binding ViewModel.MapTextColor, Mode=TwoWay}"
                               IsAlphaEnabled="False"
                               HorizontalAlignment="Left"
                               ToolTip.Tip="Colour of the map's label text (landmark names). Black matches the Genie 4 AutoMapper look on a tan canvas."/>
                </StackPanel>

                <TextBlock Text="Tip: hover a room for details, right-click for a context menu, mouse-wheel to zoom."
                           Foreground="{DynamicResource Theme.TextMuted}" FontSize="10" TextWrapping="Wrap"/>
              </StackPanel>
                </ScrollViewer>
              </Border>
            </Grid>
          </Border>
        </Grid>

        <!-- ── ROW 2: compact status strip — current room + exits + diag ─ -->
        <Border Grid.Row="2" Background="{DynamicResource Theme.StripBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="0,1,0,0" Padding="6,3">
          <StackPanel Spacing="2">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                <TextBlock Foreground="{DynamicResource Theme.TextMuted}" FontSize="11" VerticalAlignment="Center" Text="◉"/>
                <SelectableTextBlock Text="{Binding ViewModel.CurrentTitle}"
                                     Foreground="{DynamicResource Theme.TextPrimary}" FontSize="11" FontWeight="SemiBold"
                                     VerticalAlignment="Center"
                                     TextTrimming="CharacterEllipsis"/>
                <TextBlock Foreground="{DynamicResource Theme.TextMuted}" FontSize="11" VerticalAlignment="Center"
                           Text="·" Margin="4,0,0,0"/>
                <!-- Obvious exits — clickable compass-direction buttons. Same
                     pattern and command wiring as the Less Obvious Paths strip
                     below; styled in blue so the two surfaces are visually
                     distinct (blue = "the game shows this exit", purple =
                     "hidden / requires a non-compass command"). -->
                <ItemsControl x:Name="ObviousExitsList"
                              ItemsSource="{Binding ViewModel.CurrentObviousExits}"
                              VerticalAlignment="Center">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="x:String">
                      <Button Content="{Binding}"
                              Padding="6,1" Margin="0,1,3,1" FontSize="11"
                              Background="{DynamicResource Theme.AccentBg}" Foreground="{DynamicResource Theme.Accent}"
                              BorderBrush="{DynamicResource Theme.AccentBorder}" BorderThickness="1"
                              Command="{Binding $parent[ItemsControl].DataContext.ViewModel.WalkCompassCommand}"
                              CommandParameter="{Binding}"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
              <TextBlock Grid.Column="1"
                         Text="{Binding ViewModel.ZoneName}"
                         Foreground="{DynamicResource Theme.TextMuted}" FontSize="11"
                         VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>
            <!-- Less Obvious Paths — clickable buttons for non-compass arcs
                 (go-doors, climb-walls, swim-rivers, etc.). ItemsControl
                 collapses to zero height when the collection is empty, so
                 no extra IsVisible binding is needed. Each button sends its
                 MoveCommand through the same input pipeline as a typed
                 command. Future: tooltip on hover will show the arc's
                 Requires hint (skill / class / level needed) once the
                 community starts populating that data in the maps repo. -->
            <ItemsControl x:Name="LessObviousList"
                          ItemsSource="{Binding ViewModel.CurrentLessObviousPaths}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:LessObviousPath">
                  <Button Content="{Binding MoveCommand}"
                          Padding="6,2" Margin="0,1,4,1" FontSize="11"
                          Background="#2d2238" Foreground="#d8c8e8"
                          BorderBrush="#5a4475" BorderThickness="1"
                          Command="{Binding $parent[ItemsControl].DataContext.ViewModel.WalkLessObviousCommand}"
                          CommandParameter="{Binding MoveCommand}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Diagnostic / auto-detect status — only visible when there's something to say -->
            <SelectableTextBlock Text="{Binding ViewModel.LoadStatus}"
                                 Foreground="#a8b8a8" FontSize="10"
                                 TextWrapping="Wrap"
                                 IsVisible="{Binding ViewModel.LoadStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          </StackPanel>
        </Border>

      </Grid>
    </DataTemplate>

    <!-- ── Backpack ────────────────────────────────────────────────────── -->
    <DataTemplate DataType="docking:BackpackTool">
      <Grid RowDefinitions="*" Background="{Binding ToolBackground}">
        <ScrollViewer x:Name="backpackScroll"
                      HorizontalScrollBarVisibility="{Binding ToolHScroll}"
                      VerticalScrollBarVisibility="Auto"
                      Width="{Binding $parent[Grid].Bounds.Width}"
                      Height="{Binding $parent[Grid].Bounds.Height}"
                      controls:FindInWindow.ScrollModel="{Binding Find}">
          <ItemsControl ItemsSource="{Binding ViewModel.Items}"
                        FontFamily="{Binding ToolFontFamily}"
                        FontSize="{Binding ToolFontSize}"
                        Foreground="{Binding ToolForeground}"
                        Margin="8">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:TextLine">
                <!-- Inherits Foreground from the ItemsControl (tool-scoped). -->
                <SelectableTextBlock TextWrapping="{Binding $parent[ItemsControl].DataContext.ToolTextWrapping}"
                                     Margin="0,1"
                                     controls:InlinesBehavior.Source="{Binding Inlines}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- Find bar (#120) — same overlay as the game window. -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,4,20,0" Padding="4,2" CornerRadius="3"
                Background="{DynamicResource Theme.ToolbarBg}"
                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                IsVisible="{Binding Find.IsOpen}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBox Text="{Binding Find.FindText}" Watermark="Find…"
                     AutomationProperties.Name="Find in window"
                     Width="160" FontSize="11" MinHeight="0" Padding="4,2"
                     controls:FindInWindow.BoxModel="{Binding Find}"/>
            <TextBlock Text="{Binding Find.Status}" FontSize="10"
                       Foreground="{DynamicResource Theme.TextMuted}"
                       VerticalAlignment="Center"/>
            <Button Content="▲" FontSize="10" Padding="4,1" MinHeight="0" MinWidth="0"
                    AutomationProperties.Name="Find previous"
                    AutomationProperties.HelpText="Older match (Enter)"
                    Command="{Binding Find.OlderCommand}"
                    ToolTip.Tip="Older match (Enter)"/>
            <Button Content="▼" FontSize="10" Padding="4,1" MinHeight="0" MinWidth="0"
                    AutomationProperties.Name="Find next"
                    AutomationProperties.HelpText="Newer match (Shift+Enter)"
                    Command="{Binding Find.NewerCommand}"
                    ToolTip.Tip="Newer match (Shift+Enter)"/>
            <Button Content="✕" FontSize="10" Padding="4,1" MinHeight="0" MinWidth="0"
                    Background="Transparent" BorderThickness="0"
                    AutomationProperties.Name="Close find bar"
                    AutomationProperties.HelpText="Close (Esc)"
                    Command="{Binding Find.CloseCommand}"
                    ToolTip.Tip="Close (Esc)"/>
          </StackPanel>
        </Border>
      </Grid>
    </DataTemplate>

    <!-- ── Streams (shared template for all 5 stream tools) ──────────────── -->
    <DataTemplate DataType="docking:StreamTool">
      <Grid Background="{Binding ToolBackground}">
        <ScrollViewer x:Name="streamScroll"
                      HorizontalScrollBarVisibility="{Binding ToolHScroll}"
                      VerticalScrollBarVisibility="Auto"
                      Width="{Binding $parent[Grid].Bounds.Width}"
                      Height="{Binding $parent[Grid].Bounds.Height}"
                      controls:PageScroll.IsTarget="True"
                      controls:FindInWindow.ScrollModel="{Binding Find}"
                      controls:AutoScrollBehavior.ItemsSource="{Binding Buffer.Lines}"
                      controls:AutoScrollBehavior.Paused="{Binding IsScrollPaused}">
          <ItemsControl ItemsSource="{Binding Buffer.Lines}"
                        FontFamily="{Binding ToolFontFamily}"
                        FontSize="{Binding ToolFontSize}"
                        Foreground="{Binding ToolForeground}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:TextLine">
                <!-- Foreground inherits from the tool-scoped ItemsControl.
                     ContextFlyout nulled locally so the built-in Copy flyout
                     doesn't pre-empt the tool's window menu (see game template). -->
                <SelectableTextBlock TextWrapping="{Binding $parent[ItemsControl].DataContext.ToolTextWrapping}"
                                     ContextFlyout="{x:Null}"
                                     controls:InlinesBehavior.Source="{Binding Inlines}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,20,8"
                IsVisible="{Binding #streamScroll.Tag.IsScrolledUp}"
                Command="{Binding #streamScroll.Tag.JumpToBottomCommand}"
                Content="↓ Bottom" FontSize="11" Padding="8,4" Opacity="0.85"/>

        <!-- Find bar (#120) — same overlay as the game window. -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,4,20,0" Padding="4,2" CornerRadius="3"
                Background="{DynamicResource Theme.ToolbarBg}"
                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                IsVisible="{Binding Find.IsOpen}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBox Text="{Binding Find.FindText}" Watermark="Find…"
                     AutomationProperties.Name="Find in window"
                     Width="160" FontSize="11" MinHeight="0" Padding="4,2"
                     controls:FindInWindow.BoxModel="{Binding Find}"/>
            <TextBlock Text="{Binding Find.Status}" FontSize="10"
                       Foreground="{DynamicResource Theme.TextMuted}"
                       VerticalAlignment="Center"/>
            <Button Content="▲" FontSize="10" Padding="4,1" MinHeight="0" MinWidth="0"
                    AutomationProperties.Name="Find previous"
                    AutomationProperties.HelpText="Older match (Enter)"
                    Command="{Binding Find.OlderCommand}"
                    ToolTip.Tip="Older match (Enter)"/>
            <Button Content="▼" FontSize="10" Padding="4,1" MinHeight="0" MinWidth="0"
                    AutomationProperties.Name="Find next"
                    AutomationProperties.HelpText="Newer match (Shift+Enter)"
                    Command="{Binding Find.NewerCommand}"
                    ToolTip.Tip="Newer match (Shift+Enter)"/>
            <Button Content="✕" FontSize="10" Padding="4,1" MinHeight="0" MinWidth="0"
                    Background="Transparent" BorderThickness="0"
                    AutomationProperties.Name="Close find bar"
                    AutomationProperties.HelpText="Close (Esc)"
                    Command="{Binding Find.CloseCommand}"
                    ToolTip.Tip="Close (Esc)"/>
          </StackPanel>
        </Border>
      </Grid>
    </DataTemplate>

    <DataTemplate DataType="docking:ExperienceTool">
      <DockPanel>
        <!-- Per-panel density slider (public #125) + Track-gain toggle (#144).   -->
        <!-- Each writes its #config value directly, so the controls, the command -->
        <!-- line, and settings.cfg stay in sync.                                 -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,2" Spacing="6">
          <TextBlock Text="Density" VerticalAlignment="Center"
                     FontSize="11" Opacity="0.7"/>
          <Slider Width="140" Minimum="0" Maximum="4"
                  TickFrequency="1" IsSnapToTickEnabled="True"
                  VerticalAlignment="Center"
                  Value="{Binding ViewModel.DensityValue, Mode=TwoWay}"/>
          <TextBlock Text="{Binding ViewModel.DensityLabel}"
                     VerticalAlignment="Center" FontSize="11" MinWidth="68"/>
          <CheckBox Content="Track gain" VerticalAlignment="Center" FontSize="11"
                    IsChecked="{Binding ViewModel.TrackGain, Mode=TwoWay}"
                    ToolTip.Tip="Show ranks gained this session per skill, plus a session total."/>
          <CheckBox Content="G4 layout" VerticalAlignment="Center" FontSize="11"
                    IsChecked="{Binding ViewModel.G4Layout, Mode=TwoWay}"
                    ToolTip.Tip="Genie 4 EXPTracker look: 'Learning Skills' summary as a footer below the list instead of a header on top."/>
        </StackPanel>
        <!-- One SelectableTextBlock per row (via Lines/Inlines) so user highlights -->
        <!-- fire on the Experience window (#144). No wrapping: keep columns aligned; -->
        <!-- an Auto h-scrollbar hands long rows their full width.                    -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding ViewModel.Lines}"
                        FontFamily="{Binding ToolFontFamily}"
                        FontSize="{Binding ToolFontSize}"
                        Margin="8"
                        Foreground="{DynamicResource GameBrush}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:TextLine">
                <SelectableTextBlock ContextFlyout="{x:Null}"
                                     controls:InlinesBehavior.Source="{Binding Inlines}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </DataTemplate>

    <DataTemplate DataType="docking:AnalyticsTool">
      <DockPanel>
        <!-- Header: character picker, refresh, and inline recording settings.  -->
        <!-- Settings write their #config values directly (density-slider idiom) -->
        <!-- so the panel, the command line, and settings.cfg stay in sync.      -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,2" Spacing="6">
          <TextBlock Text="Character" VerticalAlignment="Center" FontSize="11" Opacity="0.7"/>
          <ComboBox Width="150" FontSize="11" VerticalAlignment="Center"
                    AutomationProperties.Name="Analytics character"
                    ItemsSource="{Binding ViewModel.Characters}"
                    SelectedItem="{Binding ViewModel.SelectedCharacter, Mode=TwoWay}"/>
          <Button Content="Refresh" FontSize="11" VerticalAlignment="Center"
                  AutomationProperties.Name="Refresh analytics"
                  Command="{Binding ViewModel.RefreshCommand}"/>
          <CheckBox Content="Record" VerticalAlignment="Center" FontSize="11"
                    AutomationProperties.Name="Record skill history"
                    IsChecked="{Binding ViewModel.RecordingEnabled, Mode=TwoWay}"
                    ToolTip.Tip="Record skill history locally (#config analytics). Local-only — never uploaded."/>
          <TextBlock Text="Keep raw" VerticalAlignment="Center" FontSize="11" Opacity="0.7"/>
          <NumericUpDown Width="110" FontSize="11" Minimum="0" Maximum="3650" Increment="30"
                         AutomationProperties.Name="Raw history retention days"
                         Value="{Binding ViewModel.RetentionDays, Mode=TwoWay}"
                         ToolTip.Tip="Days of raw snapshots to keep before folding into permanent daily rollups (0 = forever). #config analyticsretentiondays"/>
          <TextBlock Text="days" VerticalAlignment="Center" FontSize="11" Opacity="0.7"/>
        </StackPanel>

        <TabControl Margin="4,0,4,4">
          <TabItem Header="This Session" FontSize="12">
            <DockPanel Margin="4">
              <TextBlock DockPanel.Dock="Top" Text="{Binding ViewModel.SessionHeadline}"
                         FontSize="12" Margin="4,2,4,6" TextWrapping="Wrap"/>
              <Grid RowDefinitions="*,Auto,*">
                <controls:ChartCanvas Grid.Row="0" MinHeight="80"
                                      Series="{Binding ViewModel.SessionBars}"
                                      RenderTick="{Binding ViewModel.RenderTick}"
                                      EmptyMessage="(no rank gains yet this session)"
                                      AxisBrush="{DynamicResource GameBrush}"
                                      GridBrush="{DynamicResource Theme.AccentBg}"
                                      LabelBrush="{DynamicResource GameBrush}"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="4,4">
                  <TextBlock Text="Rank over time" VerticalAlignment="Center" FontSize="11" Opacity="0.7"/>
                  <ComboBox Width="180" FontSize="11"
                            AutomationProperties.Name="Session chart skill"
                            ItemsSource="{Binding ViewModel.SessionSkills}"
                            SelectedItem="{Binding ViewModel.SelectedSessionSkill, Mode=TwoWay}"/>
                </StackPanel>
                <controls:ChartCanvas Grid.Row="2" MinHeight="80" XIsTime="True"
                                      Series="{Binding ViewModel.SessionLine}"
                                      RenderTick="{Binding ViewModel.RenderTick}"
                                      EmptyMessage="(pick a skill once data arrives)"
                                      AxisBrush="{DynamicResource GameBrush}"
                                      GridBrush="{DynamicResource Theme.AccentBg}"
                                      LabelBrush="{DynamicResource GameBrush}"/>
              </Grid>
            </DockPanel>
          </TabItem>

          <TabItem Header="History" FontSize="12">
            <DockPanel Margin="4">
              <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="4,2,4,6">
                <TextBlock Text="Skill" VerticalAlignment="Center" FontSize="11" Opacity="0.7"/>
                <ComboBox Width="180" FontSize="11"
                          AutomationProperties.Name="History skill"
                          ItemsSource="{Binding ViewModel.HistorySkills}"
                          SelectedItem="{Binding ViewModel.SelectedHistorySkill, Mode=TwoWay}"/>
                <TextBlock Text="Range" VerticalAlignment="Center" FontSize="11" Opacity="0.7"/>
                <ComboBox Width="110" FontSize="11"
                          AutomationProperties.Name="History range"
                          SelectedIndex="{Binding ViewModel.HistoryRangeIndex, Mode=TwoWay}">
                  <ComboBoxItem Content="7 days"/>
                  <ComboBoxItem Content="30 days"/>
                  <ComboBoxItem Content="90 days"/>
                  <ComboBoxItem Content="All"/>
                </ComboBox>
              </StackPanel>
              <controls:ChartCanvas XIsDate="True"
                                    Series="{Binding ViewModel.HistorySeries}"
                                    RenderTick="{Binding ViewModel.RenderTick}"
                                    EmptyMessage="(no history in this range yet — analytics records as you play)"
                                    AxisBrush="{DynamicResource GameBrush}"
                                    GridBrush="{DynamicResource Theme.AccentBg}"
                                    LabelBrush="{DynamicResource GameBrush}"/>
            </DockPanel>
          </TabItem>

          <TabItem Header="Sessions" FontSize="12">
            <Grid RowDefinitions="Auto,*,*" Margin="4">
              <CheckBox Grid.Row="0" Content="Show replay sessions" FontSize="11" Margin="4,2"
                        AutomationProperties.Name="Show replay sessions"
                        IsChecked="{Binding ViewModel.ShowReplay, Mode=TwoWay}"
                        ToolTip.Tip="Include DevReplay sessions (fake timestamps) in the list."/>
              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ViewModel.Sessions}" Margin="4,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="24,130,70,70,70,140,90" Margin="0,1">
                        <CheckBox Grid.Column="0"
                                  AutomationProperties.Name="Compare session"
                                  IsChecked="{Binding Compare, Mode=TwoWay}"
                                  ToolTip.Tip="Compare up to 3 sessions on the chart below."/>
                        <TextBlock Grid.Column="1" Text="{Binding Start}"      FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding Duration}"   FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{Binding TotalGain}"  FontSize="11" VerticalAlignment="Center"
                                   ToolTip.Tip="Total fractional ranks gained"/>
                        <TextBlock Grid.Column="4" Text="{Binding GainPerHour}" FontSize="11" VerticalAlignment="Center"
                                   ToolTip.Tip="Ranks per hour"/>
                        <TextBlock Grid.Column="5" Text="{Binding TopSkill}"   FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="{Binding Flags}"      FontSize="11" VerticalAlignment="Center" Opacity="0.6"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
              <controls:ChartCanvas Grid.Row="2" MinHeight="90" XIsTime="True"
                                    Series="{Binding ViewModel.CompareSeries}"
                                    RenderTick="{Binding ViewModel.RenderTick}"
                                    EmptyMessage="(tick up to 3 sessions above to compare their gain curves)"
                                    AxisBrush="{DynamicResource GameBrush}"
                                    GridBrush="{DynamicResource Theme.AccentBg}"
                                    LabelBrush="{DynamicResource GameBrush}"/>
            </Grid>
          </TabItem>
        </TabControl>
      </DockPanel>
    </DataTemplate>

    <DataTemplate DataType="docking:ActiveSpellsTool">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <SelectableTextBlock Text="{Binding ViewModel.Content}"
                             FontFamily="{Binding ToolFontFamily}"
                             FontSize="{Binding ToolFontSize}"
                             Margin="8"
                             Foreground="{DynamicResource GameBrush}"/>
      </ScrollViewer>
    </DataTemplate>

    <DataTemplate DataType="docking:TimeTrackerTool">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <SelectableTextBlock Text="{Binding ViewModel.Content}"
                             FontFamily="{Binding ToolFontFamily}"
                             FontSize="{Binding ToolFontSize}"
                             Margin="8"
                             Foreground="{DynamicResource GameBrush}"/>
      </ScrollViewer>
    </DataTemplate>

    <!-- ── Plugin-created windows (generic) ───────────────────────────────── -->
    <!-- One template serves EVERY plugin window. A plugin calls               -->
    <!-- IPluginHost.SetWindow("My Panel", text) and the dock factory spins up -->
    <!-- a PluginWindowTool bound here. Monospaced for column-aligned plugin   -->
    <!-- output (inventory trees, tables).                                      -->
    <DataTemplate DataType="docking:PluginWindowTool">
      <!-- Horizontal scrolling must stay DISABLED: an Auto h-scrollbar hands
           the lines unbounded width, so their TextWrapping="Wrap" never kicks
           in and long menu-script text runs off the edge (same trap as the
           stream panels, documented above). Genie 4 named windows word-wrap. -->
      <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      controls:FindInWindow.ScrollModel="{Binding Find}"
                      controls:AutoScrollBehavior.ItemsSource="{Binding ViewModel.Lines}">
          <ItemsControl ItemsSource="{Binding ViewModel.Lines}"
                        FontFamily="{Binding ToolFontFamily}"
                        FontSize="{Binding ToolFontSize}"
                        Margin="8"
                        Foreground="{DynamicResource GameBrush}">
            <ItemsControl.ItemTemplate>
              <!-- Same link-capable line rendering as the stream panels: TextLine
                   .Inlines carries clickable #link / <d cmd> links + highlights. -->
              <DataTemplate DataType="vm:TextLine">
                <SelectableTextBlock TextWrapping="Wrap"
                                     ContextFlyout="{x:Null}"
                                     controls:InlinesBehavior.Source="{Binding Inlines}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- Find bar (#120) — same overlay as the game window. -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,4,20,0" Padding="4,2" CornerRadius="3"
                Background="{DynamicResource Theme.ToolbarBg}"
                BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1"
                IsVisible="{Binding Find.IsOpen}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBox Text="{Binding Find.FindText}" Watermark="Find…"
                     AutomationProperties.Name="Find in window"
                     Width="160" FontSize="11" MinHeight="0" Padding="4,2"
                     controls:FindInWindow.BoxModel="{Binding Find}"/>
            <TextBlock Text="{Binding Find.Status}" FontSize="10"
                       Foreground="{DynamicResource Theme.TextMuted}"
                       VerticalAlignment="Center"/>
            <Button Content="▲" FontSize="10" Padding="4,1" MinHeight="0" MinWidth="0"
                    AutomationProperties.Name="Find previous"
                    AutomationProperties.HelpText="Older match (Enter)"
                    Command="{Binding Find.OlderCommand}"
                    ToolTip.Tip="Older match (Enter)"/>
            <Button Content="▼" FontSize="10" Padding="4,1" MinHeight="0" MinWidth="0"
                    AutomationProperties.Name="Find next"
                    AutomationProperties.HelpText="Newer match (Shift+Enter)"
                    Command="{Binding Find.NewerCommand}"
                    ToolTip.Tip="Newer match (Shift+Enter)"/>
            <Button Content="✕" FontSize="10" Padding="4,1" MinHeight="0" MinWidth="0"
                    Background="Transparent" BorderThickness="0"
                    AutomationProperties.Name="Close find bar"
                    AutomationProperties.HelpText="Close (Esc)"
                    Command="{Binding Find.CloseCommand}"
                    ToolTip.Tip="Close (Esc)"/>
          </StackPanel>
        </Border>
      </Grid>
    </DataTemplate>

    <!-- ── Scripts panel (running list + Start/Stop + output log) ─────────── -->
    <!-- The always-on bottom strip (ScriptBarViewModel) shows the same running  -->
    <!-- scripts compactly; this dockable panel adds the Start… picker, Stop All,-->
    <!-- and a scrollable [script] output log. Both .cmd and .js appear here.    -->
    <DataTemplate DataType="docking:ScriptsTool">
      <Grid RowDefinitions="Auto,Auto,*" Margin="4">

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6"
                    Margin="0,0,0,4">
          <Button Content="Start…" Command="{Binding ViewModel.StartScriptCommand}"
                  FontSize="11" Padding="8,2"
                  ToolTip.Tip="Run a .cmd / .inc / .js script via file picker"/>
          <Button Content="Stop All" Command="{Binding ViewModel.StopAllCommand}"
                  FontSize="11" Padding="8,2"/>
          <Button Content="Clear" Command="{Binding ViewModel.ClearOutputCommand}"
                  FontSize="11" Padding="8,2"
                  ToolTip.Tip="Clear the output log below"/>
          <TextBlock Text="{Binding ViewModel.StatusText}" Foreground="{DynamicResource Theme.SectionHeader}"
                     FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Running scripts -->
        <Border Grid.Row="1" Background="{DynamicResource Theme.ToolbarBg}" BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1" CornerRadius="3" Padding="4" MaxHeight="160">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ViewModel.RunningScripts}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:RunningScriptRow">
                  <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,1">
                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12"
                               Foreground="{DynamicResource Theme.TextPrimary}" VerticalAlignment="Center"/>
                    <!-- Language tag — only shown for .js scripts. -->
                    <Border Grid.Column="1" Background="#2d3b46" CornerRadius="2"
                            Padding="3,0" Margin="4,0" VerticalAlignment="Center"
                            IsVisible="{Binding IsJavaScript}">
                      <TextBlock Text="js" FontSize="9" Foreground="#e8c97a"/>
                    </Border>
                    <Button Grid.Column="2" Content="Stop" FontSize="10"
                            Padding="6,1" Command="{Binding StopCommand}"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!-- Output log -->
        <Border Grid.Row="2" Background="{DynamicResource Theme.PanelBgDeep}" BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1" CornerRadius="3" Margin="0,4,0,0">
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        controls:AutoScrollBehavior.ItemsSource="{Binding ViewModel.Output}">
            <ItemsControl ItemsSource="{Binding ViewModel.Output}"
                          FontFamily="Consolas,Menlo,monospace" FontSize="11"
                          Foreground="{DynamicResource Theme.TextSecondary}" Margin="4">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:TextLine">
                  <SelectableTextBlock TextWrapping="Wrap"
                                       controls:InlinesBehavior.Source="{Binding Inlines}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </Grid>
    </DataTemplate>

    <!-- ── Raw XML window (#14) — verbatim live server stream ─────────────── -->
    <!-- Read-only protocol dump for parser development / "where did that come   -->
    <!-- from?" debugging. Capped rolling buffer, auto-scroll, default hidden.    -->
    <!-- Monospaced + horizontal scroll so long tags stay on one line.           -->
    <DataTemplate DataType="docking:RawXmlTool">
      <Grid RowDefinitions="Auto,*" Margin="4">

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6"
                    Margin="0,0,0,4">
          <Button Content="Clear" Command="{Binding ViewModel.ClearCommand}"
                  FontSize="11" Padding="8,2"
                  ToolTip.Tip="Clear the buffer"/>
          <TextBlock Text="Live raw server XML — local view only."
                     Foreground="{DynamicResource Theme.SectionHeader}" FontSize="11" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource Theme.PanelBgDeep}" BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1" CornerRadius="3">
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto"
                        controls:AutoScrollBehavior.ItemsSource="{Binding ViewModel.Lines}">
            <ItemsControl ItemsSource="{Binding ViewModel.Lines}"
                          FontFamily="{Binding ToolFontFamily}"
                          FontSize="{Binding ToolFontSize}"
                          Foreground="#7fc4a0" Margin="4">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="x:String">
                  <SelectableTextBlock Text="{Binding}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </Grid>
    </DataTemplate>

  </Application.DataTemplates>

</Application>
